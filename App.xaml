<Application x:Class="OverWatchELD.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">


    <Application.Resources>

        <!-- =========================
             MOTIVE-DARK (READABLE)
             ========================= -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Core colors -->
        <Color x:Key="WindowBackground">#0F141B</Color>
        <Color x:Key="PanelBackground">#141B24</Color>
        <Color x:Key="CardBackground">#18212C</Color>
        <Color x:Key="CardBorder">#2A3442</Color>

        <Color x:Key="TextMain">#E7EEF8</Color>
        <Color x:Key="TextMuted">#AFC0D7</Color>

        <Color x:Key="Accent">#2F81F7</Color>
        <Color x:Key="Link">#5AA7FF</Color>
        <Color x:Key="Success">#2EC27E</Color>
        <Color x:Key="Warning">#F5C542</Color>
        <Color x:Key="Danger">#FF5A67</Color>

        <!-- Brushes -->
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackground}" />
        <SolidColorBrush x:Key="PanelBackgroundBrush"  Color="{StaticResource PanelBackground}" />
        <SolidColorBrush x:Key="CardBackgroundBrush"   Color="{StaticResource CardBackground}" />
        <SolidColorBrush x:Key="CardBorderBrush"       Color="{StaticResource CardBorder}" />
        <SolidColorBrush x:Key="CardBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMainBrush"  Color="{StaticResource TextMain}" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
        <SolidColorBrush x:Key="AccentBrush"  Color="{StaticResource Accent}" />
        <SolidColorBrush x:Key="LinkBrush"    Color="{StaticResource Link}" />
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
        <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
        <SolidColorBrush x:Key="DangerBrush"  Color="{StaticResource Danger}" />

        <!-- Window default -->
        <Style TargetType="{x:Type Window}">
            <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
        </Style>

        <!-- Text -->
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
        </Style>

        <!-- Buttons -->
        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="#1F2A38" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>



        <!-- =========================
             GLOBAL DARK COMBOBOX
             ========================= -->
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="#1B2430" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="#1B2430" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinHeight" Value="28" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#263447" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2F81F7" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2563EB" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid dark theme -->
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="RowBackground" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource CardBorderBrush}"/>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Application.Resources>
</Application>