<Window x:Class="OverWatchELD.Views.FirstTimeSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="First Time Setup"
        Width="620"
        Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0B1220">

    <Grid Margin="28">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <TextBlock Text="OverWatch ELD Setup"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Choose how this driver will use OverWatch ELD."
                           FontSize="15"
                           Foreground="#AAB6C8"
                           TextAlignment="Center"
                           Margin="0,0,0,22"/>

                <!-- TELEMETRY SETUP -->
                <Border Background="#111827"
                        BorderBrush="#374151"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14"
                        Margin="0,0,0,18">

                    <StackPanel>

                        <TextBlock Text="Telemetry Reader Required"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"/>

                        <TextBlock Text="Before using OverWatch ELD with American Truck Simulator, install and run the telemetry reader."
                                   FontSize="13"
                                   Foreground="#D1D5DB"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,10"/>

                        <TextBlock Text="1. Download the telemetry reader from the OverWatch ELD downloads page."
                                   Foreground="#EAF2FF"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,5"/>

                        <TextBlock Text="2. Extract the ZIP file to a folder on your computer."
                                   Foreground="#EAF2FF"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,5"/>

                        <TextBlock Text="3. Run Ets2Telemetry.exe."
                                   Foreground="#EAF2FF"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,5"/>

                        <TextBlock Text="4. Start American Truck Simulator after telemetry is running."
                                   Foreground="#EAF2FF"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,5"/>

                        <TextBlock Text="5. Then open or continue into OverWatch ELD."
                                   Foreground="#EAF2FF"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Border>

                <!-- VTC WARNING -->
                <Border Background="#3B2A17"
                        BorderBrush="#C2410C"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14"
                        Margin="0,0,0,18">

                    <StackPanel>

                        <TextBlock Text="Important VTC Linking Note"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="#FED7AA"/>

                        <TextBlock Text="DO NOT use the !link command in the Gas Monkey Creations Discord."
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#FED7AA"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,4"/>

                        <TextBlock Text="Use your own VTC Discord server to run the !link command for this step."
                                   FontSize="14"
                                   Foreground="#FED7AA"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Border>

                <!-- VTC OPTION -->
                <Button Content="Link to a VTC"
                        Height="54"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Margin="0,0,0,14"
                        Click="LinkVtc_Click"/>

                <TextBlock Text="Use this if your company/server gave you a Discord !link code."
                           Foreground="#8794A8"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,22"/>

                <!-- STANDALONE OPTION -->
                <Button Content="Use Standalone"
                        Height="54"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Click="Standalone_Click"/>

                <TextBlock Text="Use this if you are not linking to a VTC right now."
                           Foreground="#8794A8"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</Window>