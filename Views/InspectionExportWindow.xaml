<Window x:Class="OverWatchELD.Views.InspectionExportWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:OverWatchELD.Controls">

    <Grid Background="#FFF3F5F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Background="White">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Content="←" Width="26" Height="26"
                        Background="Transparent" BorderBrush="{x:Null}"
                        Command="{Binding BackCommand}"/>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="16"
                           Foreground="#FF222220"
                           Text="Hours of Service"/>

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="#FF1E63D0"
                           Text="Settings"/>
            </Grid>
        </Border>

        <!-- Mode row -->
        <Border Grid.Row="1" Margin="12,10,12,10" Padding="10"
                CornerRadius="12" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="#FF222220" CornerRadius="8" Padding="8,3" VerticalAlignment="Center">
                    <TextBlock Foreground="White" FontWeight="SemiBold" Text="{Binding ModePillShort}"/>
                </Border>

                <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                           Foreground="#FF222220" Text="{Binding ModePillText}"/>

                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="#FF808A90" Text="›"/>
            </Grid>
        </Border>

        <!-- Clocks -->
        <Border Grid.Row="2" Margin="12" Padding="14" Background="White" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Margin="0,8">
                    <ctrl:CircularRing Width="120" Height="120" StrokeThickness="10"
                                      ProgressValue="{Binding BreakProgress}"
                                      CenterText="{Binding BreakText}"/>
                    <TextBlock Text="Until break" Margin="0,8,0,0" Foreground="#FF303740" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Margin="0,8">
                    <ctrl:CircularRing Width="120" Height="120" StrokeThickness="10"
                                      ProgressValue="{Binding DriveProgress}"
                                      CenterText="{Binding DriveText}"/>
                    <TextBlock Text="Drive" Margin="0,8,0,0" Foreground="#FF303740" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" Margin="0,22,0,8">
                    <ctrl:CircularRing Width="120" Height="120" StrokeThickness="10"
                                      ProgressValue="{Binding ShiftProgress}"
                                      CenterText="{Binding ShiftText}"/>
                    <TextBlock Text="Total Shift" Margin="0,8,0,0" Foreground="#FF303740" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Margin="0,22,0,8">
                    <ctrl:CircularRing Width="120" Height="120" StrokeThickness="10"
                                      ProgressValue="{Binding CycleProgress}"
                                      CenterText="{Binding CycleText}"/>
                    <TextBlock Text="Cycle" Margin="0,8,0,0" Foreground="#FF303740" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
