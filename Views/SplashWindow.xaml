<Window x:Class="OverWatchELD.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#11161D"
        Width="520"
        Height="520"
        ShowInTaskbar="False"
        Topmost="True">

    <Border CornerRadius="22"
            Background="#11161D"
            BorderBrush="#2A3442"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Margin="24,20,24,8"
                    CornerRadius="18"
                    Background="#0D1218">
                <Image Source="pack://application:,,,/Assets/splash.png"
                       Stretch="Uniform"
                       Margin="18"/>
            </Border>

            <Border Grid.Row="1"
                    Margin="18,0,18,18"
                    Padding="14"
                    CornerRadius="16"
                    Background="#18212C"
                    BorderBrush="#2A3442"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="OverWatch ELD"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="StatusText"
                               Text="Starting system..."
                               Margin="0,6,0,10"
                               FontSize="13"
                               Foreground="#BFE4FF"
                               HorizontalAlignment="Center"/>

                    <ProgressBar Height="7"
                                 IsIndeterminate="True"
                                 Margin="0,0,0,10"/>

                    <TextBlock x:Name="VersionText"
                               Text="Version 1.0.0"
                               FontSize="11"
                               Foreground="#8FA3BD"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>