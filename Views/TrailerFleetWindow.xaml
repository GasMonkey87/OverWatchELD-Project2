<Window x:Class="OverWatchELD.Views.TrailerFleetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trailer Fleet Command"
        Height="900"
        Width="1460"
        MinHeight="780"
        MinWidth="1260"
        WindowStartupLocation="CenterOwner"
        Background="#0B1220">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CaretBrush" Value="#60A5FA"/>
            <Setter Property="SelectionBrush" Value="#2563EB"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="RowBackground" Value="#0B1220"/>
            <Setter Property="AlternatingRowBackground" Value="#111827"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#334155"/>
            <Setter Property="VerticalGridLinesBrush" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#182235"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Trailer Fleet Command" Foreground="#E5E7EB" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="Trailer management, driver assignment, load tracking, service, inspection, and active trailer selection." Foreground="#94A3B8" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Refresh" Width="110" Height="34" Margin="0,0,10,0" Click="Refresh_Click"/>
                    <Button Content="Close" Width="110" Height="34" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" Columns="6">
            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                <StackPanel><TextBlock Text="Total Trailers" Foreground="#94A3B8"/><TextBlock Text="{Binding TotalFleetText}" Foreground="#E5E7EB" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel>
            </Border>
            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                <StackPanel><TextBlock Text="Assigned" Foreground="#94A3B8"/><TextBlock Text="{Binding AssignedText}" Foreground="#86EFAC" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel>
            </Border>
            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                <StackPanel><TextBlock Text="Unassigned" Foreground="#94A3B8"/><TextBlock Text="{Binding UnassignedText}" Foreground="#FCD34D" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel>
            </Border>
            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                <StackPanel><TextBlock Text="Needs Service" Foreground="#94A3B8"/><TextBlock Text="{Binding NeedsServiceText}" Foreground="#FCA5A5" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel>
            </Border>
            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                <StackPanel><TextBlock Text="Needs Inspection" Foreground="#94A3B8"/><TextBlock Text="{Binding NeedsInspectionText}" Foreground="#FCA5A5" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel>
            </Border>
            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14">
                <StackPanel><TextBlock Text="Active Drivers" Foreground="#94A3B8"/><TextBlock Text="{Binding ActiveDriversText}" Foreground="#93C5FD" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="410"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="12"/><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Height="34" VerticalContentAlignment="Center" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <ComboBox Grid.Column="2" Height="34" ItemsSource="{Binding Filters}" SelectedItem="{Binding SelectedFilter}"/>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Trailers}"
                              SelectedItem="{Binding SelectedTrailer}"
                              SelectionChanged="TrailerGrid_SelectionChanged"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Use this trailer for my tracking" Click="UseTrailerTracking_Click"/>
                                <Separator/>
                                <MenuItem Header="Mark Service Complete" Click="ServiceComplete_Click"/>
                                <MenuItem Header="Mark Inspection Complete" Click="InspectionComplete_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{Binding RowBackground}"/>
                                <Setter Property="BorderBrush" Value="{Binding RowBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Trailer ID" Binding="{Binding TrailerNumber}" Width="1.0*"/>
                            <DataGridTextColumn Header="Plate" Binding="{Binding PlateNumber}" Width="0.9*"/>
                            <DataGridTextColumn Header="Trailer" Binding="{Binding TrailerName}" Width="1.2*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TrailerType}" Width="0.9*"/>
                            <DataGridTextColumn Header="Driver" Binding="{Binding AssignedDriver}" Width="1.2*"/>
                            <DataGridTextColumn Header="Load" Binding="{Binding CurrentLoadNumber}" Width="0.9*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.0*"/>
                            <DataGridTextColumn Header="Health" Binding="{Binding HealthText}" Width="0.7*"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="1.2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Trailer Details" Foreground="#E5E7EB" FontSize="19" FontWeight="SemiBold"/>
                        <TextBlock Text="Add trailers, assign drivers/loads, and maintain trailer service/inspection state." Foreground="#94A3B8" Margin="0,6,0,12" TextWrapping="Wrap"/>

                        <TextBlock Text="Trailer ID" Foreground="#E5E7EB"/>
                        <ComboBox x:Name="TrailerNumberBox" IsEditable="True" IsTextSearchEnabled="False" Margin="0,6,0,0" Height="34" ItemsSource="{Binding Trailers}" DisplayMemberPath="TrailerNumber"/>

                        <TextBlock Text="Assigned Driver" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <ComboBox x:Name="DriverBox" IsEditable="False" IsTextSearchEnabled="True" Margin="0,6,0,0" Height="34"/>

                        <TextBlock Text="Load Number" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <ComboBox x:Name="LoadNumberBox" IsEditable="True" IsTextSearchEnabled="False" Margin="0,6,0,0" Height="34" ItemsSource="{Binding LoadOptions}"/>

                        <TextBlock Text="Trailer Name" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="TrailerNameBox" Margin="0,6,0,0" Height="34"/>

                        <TextBlock Text="Model" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="ModelBox" Margin="0,6,0,0" Height="34"/>

                        <TextBlock Text="Trailer Type" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="TrailerTypeBox" Margin="0,6,0,0" Height="34"/>

                        <TextBlock Text="Plate" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="PlateBox" Margin="0,6,0,0" Height="34"/>

                        <TextBlock Text="Location" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="LocationBox" Margin="0,6,0,0" Height="34"/>

                        <TextBlock Text="Condition %" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="ConditionBox" Margin="0,6,0,0" Height="34" Text="100"/>

                        <TextBlock Text="Odometer Miles" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="OdometerBox" Margin="0,6,0,0" Height="34" Text="0"/>

                        <UniformGrid Columns="2" Margin="0,18,0,0">
                            <Button Content="Save Trailer" Height="38" Margin="0,0,6,0" Click="SaveTrailer_Click"/>
                            <Button Content="Assign Driver + Load" Height="38" Margin="6,0,0,0" Click="AssignDriver_Click"/>
                        </UniformGrid>
                        <UniformGrid Columns="2" Margin="0,10,0,0">
                            <Button Content="Service Complete" Height="38" Margin="0,0,6,0" Click="ServiceComplete_Click"/>
                            <Button Content="Inspection Complete" Height="38" Margin="6,0,0,0" Click="InspectionComplete_Click"/>
                        </UniformGrid>
                        <UniformGrid Columns="2" Margin="0,10,0,0">
                            <Button Content="Unassign" Height="38" Margin="0,0,6,0" Click="Unassign_Click"/>
                            <Button Content="Delete" Height="38" Margin="6,0,0,0" Click="Delete_Click"/>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
