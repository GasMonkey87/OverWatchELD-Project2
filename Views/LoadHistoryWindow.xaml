<Window x:Class="OverWatchELD.Views.LoadHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load History"
        Width="1280"
        Height="760"
        MinWidth="1100"
        MinHeight="650"
        WindowStartupLocation="CenterOwner"
        Background="#07111F">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#163B65"/>
            <Setter Property="BorderBrush" Value="#3B79B9"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="RowBackground" Value="#0B1220"/>
            <Setter Property="AlternatingRowBackground" Value="#111827"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#334155"/>
            <Setter Property="VerticalGridLinesBrush" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#182235"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0D1A2B"
                BorderBrush="#263E5C"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Load History"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="Saved Company Loads and history of Individual Loads created/exported from Create Load."
                               Foreground="#9FB3CC"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"/>
                    <Button Content="Clear Individual History"
                            Command="{Binding ClearIndividualHistoryCommand}"
                            Background="#991B1B"
                            BorderBrush="#DC2626"/>
                    <Button Content="Close"
                            Click="Close_Click"
                            Background="#2A3444"
                            BorderBrush="#4E6077"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#0D1A2B"
                BorderBrush="#263E5C"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14">

            <DataGrid ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                    <DataGridTextColumn Header="Load #" Binding="{Binding LoadNumber}" Width="120"/>
                    <DataGridTextColumn Header="Route" Binding="{Binding Route}" Width="*"/>
                    <DataGridTextColumn Header="Cargo" Binding="{Binding Cargo}" Width="180"/>
                    <DataGridTextColumn Header="Trailer" Binding="{Binding Trailer}" Width="180"/>
                    <DataGridTextColumn Header="Driver" Binding="{Binding Driver}" Width="140"/>
                    <DataGridTextColumn Header="Truck" Binding="{Binding Truck}" Width="100"/>
                    <DataGridTextColumn Header="Miles" Binding="{Binding Miles}" Width="80"/>
                    <DataGridTextColumn Header="Weight" Binding="{Binding WeightLbs}" Width="90"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                    <DataGridTextColumn Header="Created" Binding="{Binding CreatedDisplay}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusText}"
                   Foreground="#A7F3D0"
                   Margin="4,12,0,0"/>
    </Grid>
</Window>