<Window x:Class="OverWatchELD.Views.EventPageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Events"
        Height="840"
        Width="1280"
        MinHeight="760"
        MinWidth="1120"
        WindowStartupLocation="CenterOwner"
        Background="#111111">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Events"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Calendar view, event management, and upcoming events."
                               Foreground="#BFBFBF"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="Today"
                            Width="90"
                            Margin="0,0,8,0"
                            Click="Today_Click"/>
                    <Button Content="Create Event"
                            Width="120"
                            Margin="0,0,8,0"
                            Click="CreateEvent_Click"/>
                    <Button Content="Refresh"
                            Width="100"
                            Click="Refresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <!-- Calendar -->
            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="◀"
                                Width="36"
                                Height="30"
                                Click="PrevMonth_Click"/>

                        <TextBlock Grid.Column="1"
                                   x:Name="MonthTitleText"
                                   Text="Month Year"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="2"
                                Content="▶"
                                Width="36"
                                Height="30"
                                Click="NextMonth_Click"/>
                    </Grid>

                    <UniformGrid Grid.Row="2" Columns="7">
                        <Border Background="#181818" Margin="2" Padding="6">
                            <TextBlock Text="Sun" Foreground="#BFBFBF" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Background="#181818" Margin="2" Padding="6">
                            <TextBlock Text="Mon" Foreground="#BFBFBF" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Background="#181818" Margin="2" Padding="6">
                            <TextBlock Text="Tue" Foreground="#BFBFBF" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Background="#181818" Margin="2" Padding="6">
                            <TextBlock Text="Wed" Foreground="#BFBFBF" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Background="#181818" Margin="2" Padding="6">
                            <TextBlock Text="Thu" Foreground="#BFBFBF" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Background="#181818" Margin="2" Padding="6">
                            <TextBlock Text="Fri" Foreground="#BFBFBF" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Background="#181818" Margin="2" Padding="6">
                            <TextBlock Text="Sat" Foreground="#BFBFBF" HorizontalAlignment="Center"/>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Grid.Row="4"
                                 x:Name="CalendarDaysGrid"
                                 Rows="6"
                                 Columns="7"/>
                </Grid>
            </Border>

            <!-- Selected day events -->
            <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SelectedDateLabelText"
                               Text="Selected Date"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <ListBox Grid.Row="2"
                             x:Name="SelectedDateEventsList"
                             Background="#141414"
                             Foreground="White"
                             BorderBrush="#2A2A2A"
                             BorderThickness="1"
                             Padding="8"
                             SelectionChanged="SelectedDateEventsList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#181818"
                                        BorderBrush="#2A2A2A"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Meta}"
                                                   Foreground="#BFBFBF"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Upcoming/details -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Upcoming Events"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <ListBox Grid.Row="2"
                                 x:Name="UpcomingEventsList"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="8"
                                 SelectionChanged="UpcomingEventsList_SelectionChanged"
                                 Height="220">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#181818"
                                            BorderBrush="#2A2A2A"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Meta}"
                                                       Foreground="#BFBFBF"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="10" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Event Details"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="2"
                                   x:Name="DetailTitleText"
                                   Text="No event selected"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="4"
                                   x:Name="DetailMetaText"
                                   Text="--"
                                   Foreground="#DADADA"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="6"
                                   x:Name="DetailAttendeesText"
                                   Text="Attendees: 0"
                                   Foreground="#6FCF97"
                                   FontWeight="SemiBold"/>

                        <TextBox Grid.Row="8"
                                 x:Name="DetailNotesTextBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="10"/>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Background="#1E1E1E" CornerRadius="10" Padding="14">
                    <WrapPanel>
                        <Button Content="Edit Event"
                                Width="110"
                                Margin="0,0,8,8"
                                Click="EditEvent_Click"/>
                        <Button Content="Delete Event"
                                Width="110"
                                Margin="0,0,8,8"
                                Click="DeleteEvent_Click"/>
                        <Button Content="Post to Discord"
                                Width="120"
                                Margin="0,0,8,8"
                                Click="PostEvent_Click"/>
                    </WrapPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer -->
        <DockPanel Grid.Row="4">
            <TextBlock x:Name="FooterTextBlock"
                       Text="Events ready."
                       Foreground="#8A8A8A"
                       VerticalAlignment="Center"/>

            <Button Content="Close"
                    Width="110"
                    Height="34"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    Click="Close_Click"/>
        </DockPanel>
    </Grid>
</Window>