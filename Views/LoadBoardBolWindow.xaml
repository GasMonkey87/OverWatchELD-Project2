<Window x:Class="OverWatchELD.Views.LoadBoardBolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load Board BOL"
        Height="720"
        Width="820"
        WindowStartupLocation="CenterOwner"
        Background="#0B1220"
        Loaded="LoadBoardBolWindow_Loaded">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="#E5E7EB"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Bill of Lading" Foreground="#E5E7EB" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="Fill manually or import from telemetry. Completing sends to the VTC linked ELD-BOL channel." Foreground="#94A3B8" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"><TextBlock Text="Load #" Foreground="#94A3B8"/><TextBox x:Name="LoadNumberBox"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Date / Time" Foreground="#94A3B8"/><TextBox x:Name="DateTimeBox"/></StackPanel>
                </Grid>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"><TextBlock Text="Driver" Foreground="#94A3B8"/><ComboBox x:Name="DriverBox" IsEditable="False"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Truck" Foreground="#94A3B8"/><TextBox x:Name="TruckBox"/></StackPanel>
                </Grid>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"><TextBlock Text="Trailer" Foreground="#94A3B8"/><TextBox x:Name="TrailerBox"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Weight LBS" Foreground="#94A3B8"/><TextBox x:Name="WeightBox"/></StackPanel>
                </Grid>
                <TextBlock Text="Commodity" Foreground="#94A3B8" Margin="0,10,0,0"/><TextBox x:Name="CommodityBox"/>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"><TextBlock Text="Shipper" Foreground="#94A3B8"/><TextBox x:Name="ShipperBox"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Shipper City" Foreground="#94A3B8"/><TextBox x:Name="ShipperCityBox"/></StackPanel>
                </Grid>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"><TextBlock Text="Receiver" Foreground="#94A3B8"/><TextBox x:Name="ReceiverBox"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Receiver City" Foreground="#94A3B8"/><TextBox x:Name="ReceiverCityBox"/></StackPanel>
                </Grid>
                <TextBlock Text="Notes" Foreground="#94A3B8" Margin="0,10,0,0"/><TextBox x:Name="NotesBox" MinHeight="90" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Import Telemetry" Width="130" Height="36" Margin="0,0,8,0" Click="ImportTelemetry_Click"/>
            <Button Content="Save Draft" Width="110" Height="36" Margin="0,0,8,0" Click="SaveDraft_Click"/>
            <Button Content="Complete BOL + Send" Width="170" Height="36" Margin="0,0,8,0" Click="CompleteBol_Click"/>
            <Button Content="Close" Width="90" Height="36" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
