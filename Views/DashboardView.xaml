<UserControl x:Class="OverWatchELD.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:OverWatchELD.Views"
             mc:Ignorable="d"
             Loaded="DashboardView_Loaded"
             Unloaded="DashboardView_Unloaded"
             Background="#020915">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TextMain" Color="#F4F8FF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#A7BDD8"/>
        <SolidColorBrush x:Key="Blue" Color="#008CFF"/>
        <SolidColorBrush x:Key="Green" Color="#5CFF37"/>
        <SolidColorBrush x:Key="Yellow" Color="#FFD400"/>
        <SolidColorBrush x:Key="PanelStroke" Color="#0B83D8"/>

        <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#081A30" Offset="0"/>
            <GradientStop Color="#020915" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="CyberCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="#0B83D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#002A55" Opacity="0.55"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="56"/>
            <Setter Property="Foreground" Value="#F4F8FF"/>
            <Setter Property="Background" Value="#061525"/>
            <Setter Property="BorderBrush" Value="#1F6FB2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A2A4A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00A3FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0B4F91"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Invisible dashboard scrollbar. Mouse wheel/touchpad still works. -->
        <Style x:Key="InvisibleScrollBar" TargetType="{x:Type ScrollBar}">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Width" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#020915">
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly">
            <ScrollViewer.Resources>
                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource InvisibleScrollBar}"/>
            </ScrollViewer.Resources>

            <Grid Margin="0,0,0,18" MinHeight="780">
                <Grid.RowDefinitions>
                    <RowDefinition Height="58"/>
                    <RowDefinition Height="158"/>
                    <RowDefinition Height="84"/>
                    <RowDefinition Height="230"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- FMCSA/GPS strip -->
                <Border Grid.Row="0"
                        Margin="0,0,0,12"
                        CornerRadius="10"
                        Background="#061525"
                        BorderBrush="#0B83D8"
                        BorderThickness="1">
                    <Grid Margin="18,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="♨" Foreground="{StaticResource Green}" FontSize="24" Margin="0,0,14,0"/>
                            <TextBlock Text="GPS Connected" Foreground="{StaticResource Green}" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🛡" Foreground="{StaticResource Green}" FontSize="24" Margin="0,0,14,0"/>
                            <TextBlock Text="FMCSA Ready" Foreground="{StaticResource Green}" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="◷" Foreground="{StaticResource TextMain}" FontSize="24" Margin="0,0,14,0"/>
                            <TextBlock Text="{Binding Snapshot.GeneratedLocal, StringFormat={}{0:dddd, MMM d, yyyy   h:mm tt}, FallbackValue=OverWatch Ready}"
                                       Foreground="{StaticResource TextMain}"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Vehicle information -->
                <Border Grid.Row="1" Style="{StaticResource CyberCard}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="VEHICLE CONNECTION"
                                       Foreground="{StaticResource TextMain}"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TruckConnectionStatusText"
                                       Text="Disconnected"
                                       Foreground="#22C55E"
                                       FontSize="32"
                                       FontWeight="Black"/>
                            <TextBlock x:Name="TruckNumberText"
                                       Text="Truck #: N/A"
                                       Foreground="{StaticResource TextMain}"
                                       FontSize="16"
                                       Margin="0,10,0,0"/>
                            <TextBlock x:Name="TruckNameText"
                                       Text="Truck: No Vehicle Connected"
                                       Foreground="{StaticResource TextMain}"
                                       FontSize="16"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Fill="#1F6FB2" Opacity="0.75"/>

                        <Grid Grid.Column="2" Margin="24,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="TRUCK INFORMATION"
                                       Foreground="{StaticResource TextMain}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,14"/>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="TruckDamageText"
                                               Text="Damage: Truck - - - Trailer - -"
                                               Foreground="{StaticResource TextMain}"
                                               FontSize="16"
                                               Margin="0,0,0,14"/>
                                    <TextBlock x:Name="TruckFuelText"
                                               Text="Fuel: - -"
                                               Foreground="{StaticResource TextMain}"
                                               FontSize="16"
                                               Margin="0,0,0,14"/>
                                    <TextBlock x:Name="TruckWarningsText"
                                               Text="Warnings: None"
                                               Foreground="{StaticResource Yellow}"
                                               FontSize="16"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="TruckSpeedText"
                                               Text="Speed: - -"
                                               Foreground="{StaticResource TextMain}"
                                               FontSize="16"
                                               Margin="0,0,0,18"/>
                                    <TextBlock x:Name="MilesToDestinationText"
                                               Text="Destination: - -"
                                               Foreground="{StaticResource TextMain}"
                                               FontSize="16"/>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <Border Grid.Column="3"
                                CornerRadius="8"
                                BorderBrush="#2B6EA8"
                                BorderThickness="1"
                                Height="38"
                                Width="84"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                            <TextBlock x:Name="TruckConnectionBadgeText"
                                       Text="OFFLINE"
                                       Foreground="{StaticResource TextMain}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Logs card -->
                <Border Grid.Row="2" Style="{StaticResource CyberCard}" Margin="0,0,0,12" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="▤" Foreground="{StaticResource Blue}" FontSize="42" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="UNCERTIFIED LOGS" Foreground="{StaticResource TextMain}" FontSize="14"/>
                            <TextBlock Text="{Binding UnsignedLogsCount, FallbackValue=0}"
                                       Foreground="{StaticResource Blue}"
                                       FontSize="34"
                                       FontWeight="Black"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="All logs certified  ⊙"
                                   Foreground="{StaticResource TextMain}"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Margin="24,0,0,0"/>
                        <Button Grid.Column="4"
                                Content="Review &amp; Certify"
                                Height="44"
                                Click="OpenUnsignedLogs_Click"/>
                    </Grid>
                </Border>

                <!-- Clocks -->
                <UniformGrid Grid.Row="3" Columns="4" Margin="0,0,0,14">
                    <Border Style="{StaticResource CyberCard}" Margin="0,0,12,0">
                        <Grid>
                            <TextBlock Text="◉  DRIVE" Foreground="{StaticResource TextMain}" FontSize="18" VerticalAlignment="Top"/>
                            <Grid Width="142" Height="142" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Stroke="#06203B" StrokeThickness="14"/>
                                <Ellipse Stroke="{StaticResource Blue}" StrokeThickness="14" StrokeDashArray="235 999" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#008CFF" Opacity="0.85"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DriveTime, FallbackValue=--:--}"
                                               Foreground="{StaticResource TextMain}"
                                               FontSize="25"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="AVAILABLE" Foreground="#D8E7F8" FontSize="13" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Limit:  11:00:00" Foreground="{StaticResource TextMain}" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CyberCard}" Margin="0,0,12,0">
                        <Grid>
                            <TextBlock Text="◷  SHIFT" Foreground="{StaticResource TextMain}" FontSize="18" VerticalAlignment="Top"/>
                            <Grid Width="142" Height="142" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Stroke="#06203B" StrokeThickness="14"/>
                                <Ellipse Stroke="{StaticResource Blue}" StrokeThickness="14" StrokeDashArray="235 999" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#008CFF" Opacity="0.85"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ShiftTime, FallbackValue=--:--}"
                                               Foreground="{StaticResource TextMain}"
                                               FontSize="25"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="AVAILABLE" Foreground="#D8E7F8" FontSize="13" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Limit:  14:00:00" Foreground="{StaticResource TextMain}" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CyberCard}" Margin="0,0,12,0">
                        <Grid>
                            <TextBlock Text="☕  BREAK" Foreground="{StaticResource TextMain}" FontSize="18" VerticalAlignment="Top"/>
                            <Grid Width="142" Height="142" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Stroke="#06203B" StrokeThickness="14"/>
                                <Ellipse Stroke="{StaticResource Blue}" StrokeThickness="14" StrokeDashArray="235 999" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#008CFF" Opacity="0.85"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding BreakTime, FallbackValue=--:--}"
                                               Foreground="{StaticResource TextMain}"
                                               FontSize="25"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="AVAILABLE" Foreground="#D8E7F8" FontSize="13" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Limit:  08:00:00" Foreground="{StaticResource TextMain}" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CyberCard}">
                        <Grid>
                            <TextBlock Text="⟳  CYCLE" Foreground="{StaticResource TextMain}" FontSize="18" VerticalAlignment="Top"/>
                            <Grid Width="142" Height="142" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Stroke="#06203B" StrokeThickness="14"/>
                                <Ellipse Stroke="{StaticResource Blue}" StrokeThickness="14" StrokeDashArray="235 999" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#008CFF" Opacity="0.85"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CycleTime, FallbackValue=--:--}"
                                               Foreground="{StaticResource TextMain}"
                                               FontSize="25"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="AVAILABLE" Foreground="#D8E7F8" FontSize="13" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Limit:  70:00:00" Foreground="{StaticResource TextMain}" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <TextBlock Grid.Row="4"
                           Text="DUTY STATUS *"
                           Foreground="{StaticResource TextMain}"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Margin="8,0,0,8"/>

                <views:DutyStatusView Grid.Row="5" Margin="0,0,0,12"/>

                <Grid Grid.Row="6" Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border CornerRadius="9"
                            Background="#061525"
                            BorderBrush="#0B83D8"
                            BorderThickness="1"
                            Padding="12,8">
                        <TextBlock Text="⊙  System Ready"
                                   Foreground="{StaticResource Green}"
                                   FontSize="16"/>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Connect Vehicle"
                                Margin="12,0,0,0"
                                Click="ConnectVehicle_Click"/>
                        <Button x:Name="ResetClocksButton"
                                Content="Reset Clocks"
                                Margin="8,0,0,0"
                                Click="ResetClocks_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Hidden toast host used by DashboardView.xaml.cs -->
        <Border x:Name="DashboardToast"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,18,18,0"
                Background="#061525"
                BorderBrush="#00A3FF"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14"
                Width="360"
                Panel.ZIndex="999">
            <StackPanel>
                <TextBlock x:Name="DashboardToastTitle"
                           Text="OverWatch ELD"
                           Foreground="{StaticResource TextMain}"
                           FontSize="15"
                           FontWeight="Bold"/>
                <TextBlock x:Name="DashboardToastMessage"
                           Text=""
                           Foreground="{StaticResource TextMuted}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>