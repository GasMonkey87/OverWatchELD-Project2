<Window x:Class="OverWatchELD.Views.CleanCreateLoadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OverWatchELD.ViewModels"
        Title="Create Load"
        Width="900"
        Height="860"
        WindowStartupLocation="CenterOwner"
        Background="#07111F">



    <Window.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- FULL DARK ELD THEMED COMBOBOX WITH VISIBLE CLOSED SELECTION -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="Background" Value="#132238"/>
            <Setter Property="BorderBrush" Value="#385476"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="IsTextSearchEnabled" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>

                            <Border x:Name="ComboBorder"
                                    Background="#132238"
                                    BorderBrush="#385476"
                                    BorderThickness="1"
                                    CornerRadius="3">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- CLOSED SELECTED ITEM DISPLAY -->
                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Margin="10,0,4,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      RecognizesAccessKey="True"/>

                                    <Border Grid.Column="1"
                                            Background="#163B65"
                                            BorderBrush="#385476"
                                            BorderThickness="1,0,0,0">

                                        <Path Width="10"
                                              Height="6"
                                              Stretch="Fill"
                                              Fill="#EAF2FF"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M 0 0 L 10 0 L 5 6 Z"/>
                                    </Border>

                                    <ToggleButton Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  ClickMode="Press"
                                                  IsChecked="{Binding IsDropDownOpen,
                                                                      RelativeSource={RelativeSource TemplatedParent},
                                                                      Mode=TwoWay}"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">

                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="400">

                                    <Border Background="#132238"
                                            BorderBrush="#385476"
                                            BorderThickness="1">

                                        <ScrollViewer CanContentScroll="True"
                                                      VerticalScrollBarVisibility="Auto"
                                                      MaxHeight="400">

                                            <ItemsPresenter/>

                                        </ScrollViewer>

                                    </Border>

                                </Grid>

                            </Popup>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PART_Popup"
                                        Property="MinHeight"
                                        Value="95"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder"
                                        Property="Opacity"
                                        Value="0.55"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder"
                                        Property="BorderBrush"
                                        Value="#4A91D0"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder"
                                        Property="BorderBrush"
                                        Value="#4A91D0"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type ComboBoxItem}">
                        <Setter Property="Foreground" Value="#EAF2FF"/>
                        <Setter Property="Background" Value="#132238"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">

                                        <ContentPresenter/>

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder"
                                                    Property="Background"
                                                    Value="#245B8F"/>
                                        </Trigger>

                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder"
                                                    Property="Background"
                                                    Value="#1F7A4D"/>
                                        </Trigger>

                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="Background" Value="#132238"/>
            <Setter Property="BorderBrush" Value="#385476"/>
            <Setter Property="Padding" Value="8,7"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="125"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#163B65"/>
            <Setter Property="BorderBrush" Value="#3B79B9"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>


        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,4,18,12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

    </Window.Resources>

    <Grid Margin="18">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#0D1A2B"
                BorderBrush="#263E5C"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16"
                Margin="0,0,0,14">

            <DockPanel>

                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Create Load"
                               FontSize="25"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding ContentSummary}"
                               Foreground="#9FB3CC"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">

                    <Button Content="Refresh"
                            Command="{Binding RefreshModsCommand}"/>

                    <Button Content="Mod Folder"
                            Command="{Binding OpenModFolderCommand}"/>

                    <Button Content="Load History"
                            Click="OpenLoadHistory_Click"
                            Background="#0F766E"
                            BorderBrush="#14B8A6"/>

                    <Button Content="Open Save"
                            Command="{Binding OpenSelectedAtsSaveFolderCommand}"/>

                    <Button Content="Refresh Saves"
                            Command="{Binding RefreshAtsProfilesCommand}"/>

                </StackPanel>

            </DockPanel>

        </Border>

        <!-- BODY -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <Border Background="#0D1A2B"
                        BorderBrush="#263E5C"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Load Type"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Orientation="Horizontal">
                            <CheckBox Content="Individual Load"
                                      IsChecked="{Binding IsIndividualLoad, Mode=TwoWay}"/>
                            <CheckBox Content="Company Load"
                                      IsChecked="{Binding IsCompanyLoad, Mode=TwoWay}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="ATS Profile"
                                   VerticalAlignment="Center"/>

                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  ItemsSource="{Binding AtsProfiles}"
                                  SelectedItem="{Binding SelectedAtsProfile}"
                                  DisplayMemberPath="DisplayName"/>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="ATS Save"
                                   VerticalAlignment="Center"/>

                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  ItemsSource="{Binding AtsSaves}"
                                  SelectedItem="{Binding SelectedAtsSave}"
                                  DisplayMemberPath="DisplayName"/>

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="Mod Folder / Source"
                                   VerticalAlignment="Center"/>

                        <ComboBox Grid.Row="3"
                                  Grid.Column="1"
                                  ItemsSource="{Binding SourceOptions}"
                                  SelectedItem="{Binding SelectedLoadSource}"
                                  DisplayMemberPath="DisplayName"/>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Text="Load Number"
                                   VerticalAlignment="Center"/>

                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                 Text="{Binding LoadNumber, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Text="Cargo"
                                   VerticalAlignment="Center"/>

                        <ComboBox Grid.Row="5"
                                  Grid.Column="1"
                                  ItemsSource="{Binding CargoOptions}"
                                  SelectedItem="{Binding SelectedCargo}"
                                  DisplayMemberPath="Name"/>

                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Text="Trailer"
                                   VerticalAlignment="Center"/>

                        <ComboBox Grid.Row="6"
                                  Grid.Column="1"
                                  ItemsSource="{Binding TrailerOptions}"
                                  SelectedItem="{Binding SelectedTrailer}"
                                  DisplayMemberPath="Name"/>

                        <TextBlock Grid.Row="7"
                                   Grid.Column="0"
                                   Text="Pickup Company"
                                   VerticalAlignment="Center"/>

                        <ComboBox Grid.Row="7"
                                  Grid.Column="1"
                                  ItemsSource="{Binding PickupCompaniesView}"
                                  SelectedItem="{Binding SelectedPickupCompany}"
                                  DisplayMemberPath="DisplayName"/>

                        <TextBlock Grid.Row="8"
                                   Grid.Column="0"
                                   Text="Drop-off Company"
                                   VerticalAlignment="Center"/>

                        <ComboBox Grid.Row="8"
                                  Grid.Column="1"
                                  ItemsSource="{Binding DestinationCompaniesView}"
                                  SelectedItem="{Binding SelectedDestinationCompany}"
                                  DisplayMemberPath="DisplayName"/>

                        <TextBlock Grid.Row="9"
                                   Grid.Column="0"
                                   Text="Weight"
                                   VerticalAlignment="Center"/>

                        <TextBox Grid.Row="9"
                                 Grid.Column="1"
                                 Text="{Binding WeightLbs, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="10"
                                   Grid.Column="0"
                                   Text="Miles"
                                   VerticalAlignment="Center"/>

                        <TextBox Grid.Row="10"
                                 Grid.Column="1"
                                 Text="{Binding Miles, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="11"
                                   Grid.Column="0"
                                   Text="Driver"
                                   VerticalAlignment="Center"/>

                        <ComboBox Grid.Row="11"
                                  Grid.Column="1"
                                  ItemsSource="{Binding DriverOptions}"
                                  SelectedItem="{Binding SelectedDriver}"
                                  DisplayMemberPath="DisplayName"/>

                        <TextBlock Grid.Row="12"
                                   Grid.Column="0"
                                   Text="Truck"
                                   VerticalAlignment="Center"/>

                        <ComboBox Grid.Row="12"
                                  Grid.Column="1"
                                  ItemsSource="{Binding TruckOptions}"
                                  SelectedItem="{Binding SelectedTruck}"
                                  DisplayMemberPath="DisplayName"/>

                    </Grid>

                </Border>

                <Border Background="#07111F"
                        BorderBrush="#263E5C"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,12,0,14">
                    <StackPanel>
                        <TextBlock Text="Selected ATS save target"
                                   Foreground="#9FB3CC"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedAtsSavePath}"
                                   Foreground="#EAF2FF"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Refresh Profiles/Saves"
                                    Command="{Binding RefreshAtsProfilesCommand}"
                                    Background="#163B65"
                                    BorderBrush="#4A91D0"/>
                            <Button Content="Open Selected Save"
                                    Command="{Binding OpenSelectedAtsSaveFolderCommand}"
                                    Background="#1F7A4D"
                                    BorderBrush="#35B474"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ATS RELOAD ASSISTANT -->
                <Border Background="#0D1A2B"
                        BorderBrush="#35B474"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14"
                        Margin="0,0,0,14">

                    <StackPanel>

                        <TextBlock Text="ATS Reload Assistant"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#DCFCE7"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="{Binding LastExportStatus}"
                                   Foreground="#A7F3D0"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>

                        <TextBox Text="{Binding LastExportReloadSteps}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="118"
                                 MaxHeight="170"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#07111F"
                                 Foreground="#EAF2FF"
                                 BorderBrush="#263E5C"
                                 Padding="10"
                                 Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">

                            <Button Content="Open ATS Save Folder"
                                    Command="{Binding OpenLastExportSaveFolderCommand}"
                                    Background="#163B65"
                                    BorderBrush="#4A91D0"
                                    Margin="0,0,8,0"/>

                            <Button Content="Copy Reload Steps"
                                    Command="{Binding CopyReloadStepsCommand}"
                                    Background="#1F7A4D"
                                    BorderBrush="#35B474"/>

                        </StackPanel>

                    </StackPanel>

                </Border>

                <!-- ADVANCED -->
                <Expander Header="Advanced Scanner Details"
                          IsExpanded="False">

                    <Border Background="#0B1626"
                            BorderBrush="#263E5C"
                            BorderThickness="1"
                            Padding="12"
                            MaxHeight="150">

                        <ScrollViewer VerticalScrollBarVisibility="Auto">

                            <ItemsControl ItemsSource="{Binding TechnicalLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#FFD28A"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </ScrollViewer>

                    </Border>

                </Expander>

            </StackPanel>

        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2"
                Background="#07111F"
                Padding="0,14,0,0">

            <DockPanel LastChildFill="False">

                <Button Content="Cancel"
                        DockPanel.Dock="Right"
                        Click="Cancel_Click"
                        Background="#2A3444"
                        BorderBrush="#4E6077"/>

                <Button Content="Export To ATS"
                        DockPanel.Dock="Right"
                        Command="{Binding ExportToAtsCommand}"
                        Background="#245B8F"
                        BorderBrush="#4A91D0"/>

                <Button Content="Create Load"
                        DockPanel.Dock="Right"
                        Command="{Binding CreateLoadCommand}"
                        Background="#1F7A4D"
                        BorderBrush="#35B474"/>

            </DockPanel>

        </Border>

    </Grid>

</Window>