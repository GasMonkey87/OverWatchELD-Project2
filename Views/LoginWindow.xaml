<Window x:Class="OverWatchELD.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OverWatch ELD"
        Width="420"
        Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#0E1117"
        Foreground="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="24">
            <Border Background="#141A23"
                    BorderBrush="#2F3B4C"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="24">

                <StackPanel>

                    <!-- LOGO -->
                    <Image Source="/Assets/splash.png"
                           Width="100"
                           Height="100"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>

                    <TextBlock Text="OverWatch ELD"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <!-- VERSION -->
                    <TextBlock x:Name="VersionText"
                               Text="Version"
                               Foreground="#7FA7FF"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,18"/>

                    <!-- DRIVER -->
                    <TextBlock Text="Driver Name"/>
                    <TextBox x:Name="DriverNameBox"
                             Height="38"
                             Padding="10"
                             Background="#202632"
                             BorderBrush="#3A4556"
                             Margin="0,6,0,14"/>

                    <!-- LINK SECTION -->
                    <StackPanel x:Name="LinkSection">

                        <TextBlock Text="Link Code"/>
                        <TextBox x:Name="LinkCodeBox"
                                 Height="38"
                                 Padding="10"
                                 Background="#202632"
                                 BorderBrush="#3A4556"
                                 Margin="0,6,0,6"/>

                        <TextBlock Text="Paste Discord !link code"
                                   FontSize="11"
                                   Foreground="#8FA3BF"
                                   Margin="0,0,0,12"/>
                    </StackPanel>

                    <!-- LINKED INFO -->
                    <Border x:Name="LinkedSection"
                            Background="#101722"
                            BorderBrush="#26354A"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,0,0,12"
                            Visibility="Collapsed">

                        <StackPanel>
                            <TextBlock x:Name="LinkedNameText"
                                       Text="Linked: -"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="LinkedRoleText"
                                       Text="Role: -"
                                       Foreground="#7FFFC4"
                                       Margin="0,4,0,6"/>

                            <Button Content="Unlink Discord"
                                    Height="32"
                                    Background="#FF5C5C"
                                    Click="Unlink_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- STATUS -->
                    <TextBlock x:Name="StatusText"
                               Text=""
                               Foreground="#7FFFC4"
                               Margin="0,0,0,10"/>

                    <!-- BUTTONS -->
                    <Button x:Name="LoginButton"
                            Content="Login"
                            Height="42"
                            Margin="0,0,0,10"
                            Click="Login_Click"/>

                    <Button Content="Exit"
                            Height="36"
                            Click="Exit_Click"/>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>