<Window x:Class="OverWatchELD.Views.ShiftDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shift Debug"
        Height="320"
        Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}">

    <Border Padding="16"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">

        <StackPanel>

            <!-- Header -->
            <TextBlock Text="Shift Debug"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <!-- PAUSED REMOVED (kept hidden safely) -->
            <TextBlock Visibility="Collapsed"
                       Text="Paused (Simulation)"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="12"
                       FontWeight="SemiBold"/>

            <!-- Status -->
            <StackPanel Margin="0,8,0,12">
                <TextBlock Text="Status"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"/>
                <TextBlock Text="{Binding Paused}"
                           Foreground="{StaticResource TextMainBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Debug info -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Debug Info"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"/>

                <TextBlock Text="{Binding DebugInfo}"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Close -->
            <Button Content="Close"
                    HorizontalAlignment="Right"
                    Width="90"
                    Click="Close_Click"/>

        </StackPanel>
    </Border>
</Window>
