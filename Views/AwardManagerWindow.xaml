<Window x:Class="OverWatchELD.Views.AwardManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Award Manager"
        Height="680"
        Width="980"
        MinHeight="620"
        MinWidth="920"
        WindowStartupLocation="CenterOwner"
        Background="#111111">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10" Padding="16">
            <StackPanel>
                <TextBlock Text="Award Manager"
                           FontSize="24"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="HeaderText"
                           Text="Create awards and assign them to this driver."
                           Foreground="#BFBFBF"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="10" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Create New Award"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Award Name" Foreground="#9CA3AF" Margin="0,12,0,0"/>
                        <TextBox x:Name="AwardNameTextBox"
                                 Text="{Binding AwardName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Emoji Icon" Foreground="#9CA3AF" Margin="0,12,0,0"/>
                        <TextBox x:Name="AwardEmojiTextBox"
                                 Width="100"
                                 Text="{Binding AwardEmoji, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Description" Foreground="#9CA3AF" Margin="0,12,0,0"/>
                        <TextBox x:Name="AwardDescriptionTextBox"
                                 Height="110"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding AwardDescription, UpdateSourceTrigger=PropertyChanged}"/>

                        <CheckBox x:Name="IsAchievementCheckBox"
                                  Content="This is an achievement"
                                  Foreground="White"
                                  Margin="0,12,0,0"
                                  IsChecked="{Binding IsAchievement}"/>

                        <Button Content="Create Award"
                                Width="140"
                                Margin="0,16,0,0"
                                Click="CreateAward_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Assign To Driver"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="DriverText"
                                   Foreground="#BFBFBF"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <ListBox Grid.Row="2"
                             x:Name="AwardsListBox"
                             ItemsSource="{Binding Awards}"
                             SelectedItem="{Binding SelectedAward}"
                             Background="#141414"
                             Foreground="White"
                             BorderBrush="#2A2A2A"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#181818"
                                        BorderBrush="#2A2A2A"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,0,0,8"
                                        Padding="10">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold">
                                            <Run Text="{Binding IconEmoji}" />
                                            <Run Text="  " />
                                            <Run Text="{Binding Name}" />
                                        </TextBlock>

                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="#C9C9C9"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Foreground="#8E8E8E"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"
                                                   Text="{Binding IsAchievement, StringFormat=Achievement: {0}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="4">
                        <TextBlock Text="Optional Note" Foreground="#9CA3AF"/>
                        <TextBox x:Name="NoteTextBox"
                                 Height="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,12,0,0">
                            <Button Content="Assign Award"
                                    Width="130"
                                    Margin="0,0,8,0"
                                    Click="AssignAward_Click"/>
                            <Button Content="Close"
                                    Width="110"
                                    Click="Close_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Background="#111827"
                CornerRadius="10"
                Padding="12">
            <TextBlock x:Name="StatusText"
                       Text="Ready."
                       Foreground="#CBD5E1"/>
        </Border>
    </Grid>
</Window>