<Window x:Class="OverWatchELD.Views.ProfileSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Driver" Height="420" Width="520"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select a Driver Profile" FontSize="18" FontWeight="SemiBold"/>

        <ListBox Grid.Row="1"
         Margin="0,10,0,10"
         ItemsSource="{Binding Profiles}"
         SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
         SelectionMode="Single"
         IsSynchronizedWithCurrentItem="True"
         Background="White"
         BorderBrush="Gray"
         BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DriverId}" Opacity="0.7"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="2"
           Margin="0,0,0,6"
           Text="{Binding SelectedProfile.DisplayName}"
           Opacity="0.8"/>


        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Create" Margin="0,0,8,0" Padding="14,6" Command="{Binding CreateCommand}"/>
            <Button Content="Delete" Margin="0,0,8,0" Padding="14,6" Command="{Binding DeleteCommand}"/>
            <Button Content="Continue" Padding="14,6" Command="{Binding ContinueCommand}"/>
        </StackPanel>
    </Grid>
</Window>
