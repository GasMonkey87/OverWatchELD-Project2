<Window x:Class="OverWatchELD.Views.ConvoyPageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Convoy Page"
        Height="780"
        Width="1180"
        MinHeight="700"
        MinWidth="1040"
        WindowStartupLocation="CenterOwner"
        Background="#111111">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Convoy Management"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="History, editing, status actions, and attendee management."
                               Foreground="#BFBFBF"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#1F2A36"
                        CornerRadius="10"
                        Padding="12,6"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="SelectedStatusBadgeText"
                               Text="No Convoy Selected"
                               Foreground="White"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- Main -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.35*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: convoy history -->
            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Convoy History"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <DataGrid x:Name="ConvoyHistoryGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Background="#141414"
                              Foreground="White"
                              BorderBrush="#2A2A2A"
                              BorderThickness="1"
                              SelectionChanged="ConvoyHistoryGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2.1*"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding DateDisplay}" Width="1.1*"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding TimeDisplay}" Width="1.0*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.0*"/>
                            <DataGridTextColumn Header="Attendees" Binding="{Binding AttendeeCount}" Width="0.9*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Refresh"
                                Width="110"
                                Margin="0,0,8,0"
                                Click="Refresh_Click"/>
                        <Button Content="New Convoy"
                                Width="120"
                                Margin="0,0,8,0"
                                Click="NewConvoy_Click"/>
                        <Button Content="Edit Selected"
                                Width="120"
                                Click="EditSelected_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right: details/actions -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Snapshot -->
                <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Selected Convoy"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="3"
                                       x:Name="DetailTitleText"
                                       Text="No convoy selected"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Start" Foreground="#8E8E8E" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Destination" Foreground="#8E8E8E" Margin="0,10,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" x:Name="DetailStartText" Text="--" Foreground="#DADADA" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="DetailDestinationText" Text="--" Foreground="#DADADA" Margin="0,4,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" x:Name="DetailDateTimeText" Text="--" Foreground="#9FD3FF" FontWeight="SemiBold" Margin="0,12,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="DetailAttendeesText" Text="Attendees: 0" Foreground="#6FCF97" FontWeight="SemiBold" Margin="0,12,0,0"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Actions -->
                <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="10" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Actions"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <Button Grid.Row="2"
                                Content="Open Attendees"
                                Height="34"
                                Click="OpenAttendees_Click"/>

                        <Button Grid.Row="4"
                                Content="Mark Planned"
                                Height="34"
                                Click="MarkPlanned_Click"/>

                        <Button Grid.Row="6"
                                Content="Mark Live"
                                Height="34"
                                Click="MarkLive_Click"/>

                        <Button Grid.Row="8"
                                Content="Mark Completed"
                                Height="34"
                                Click="MarkCompleted_Click"/>

                        <Button Grid.Row="10"
                                Content="Delete Selected"
                                Height="34"
                                Click="DeleteSelected_Click"/>
                    </Grid>
                </Border>

                <!-- Details / notes -->
                <Border Grid.Row="4" Background="#1E1E1E" CornerRadius="10" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Details"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="2" Text="Meet / Depart / Server / Lead" Foreground="#8E8E8E"/>
                        <TextBlock Grid.Row="4" x:Name="DetailMetaText" Text="--" Foreground="#DADADA" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="6" Text="Notes" Foreground="#8E8E8E"/>
                        <TextBox Grid.Row="8"
                                 x:Name="DetailNotesTextBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="10"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer -->
        <DockPanel Grid.Row="4">
            <TextBlock x:Name="FooterTextBlock"
                       Text="Convoy tools ready."
                       Foreground="#8A8A8A"
                       VerticalAlignment="Center"/>

            <Button Content="Close"
                    Width="110"
                    Height="34"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    Click="Close_Click"/>
        </DockPanel>
    </Grid>
</Window>