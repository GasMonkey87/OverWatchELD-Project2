<Window x:Class="OverWatchELD.Views.CreateConvoyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Convoy"
        Height="720"
        Width="760"
        MinHeight="640"
        MinWidth="680"
        WindowStartupLocation="CenterOwner"
        Background="#111111">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#162133"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2C3E55"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#162133"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2C3E55"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10" Padding="14">
            <StackPanel>
                <TextBlock Text="Create Convoy"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Create or update the current convoy card."
                           Foreground="#BFBFBF"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="10" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                        <TextBlock Text="Convoy Title" Foreground="#8E8E8E"/>
                        <TextBox x:Name="TitleTextBox"
                                 Height="32"
                                 Margin="0,6,0,0"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="8"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Start Location" Foreground="#8E8E8E"/>
                        <TextBox x:Name="StartLocationTextBox"
                                 Height="32"
                                 Margin="0,6,0,0"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="8"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="Destination" Foreground="#8E8E8E"/>
                        <TextBox x:Name="DestinationTextBox"
                                 Height="32"
                                 Margin="0,6,0,0"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="8"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <TextBlock Text="Date Display" Foreground="#8E8E8E"/>
                        <TextBox x:Name="DateDisplayTextBox"
                                 Height="32"
                                 Margin="0,6,0,0"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="8"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="2">
                        <TextBlock Text="Time Display" Foreground="#8E8E8E"/>
                        <TextBox x:Name="TimeDisplayTextBox"
                                 Height="32"
                                 Margin="0,6,0,0"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="8"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.Column="0">
                        <TextBlock Text="Meet Time" Foreground="#8E8E8E"/>
                        <TextBox x:Name="MeetTimeTextBox"
                                 Height="32"
                                 Margin="0,6,0,0"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="8"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.Column="2">
                        <TextBlock Text="Departure Time" Foreground="#8E8E8E"/>
                        <TextBox x:Name="DepartureTimeTextBox"
                                 Height="32"
                                 Margin="0,6,0,0"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="8"/>
                    </StackPanel>

                    <StackPanel Grid.Row="8" Grid.Column="0">
                        <TextBlock Text="Server" Foreground="#8E8E8E"/>
                        <TextBox x:Name="ServerTextBox"
                                 Height="32"
                                 Margin="0,6,0,0"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="8"/>
                    </StackPanel>

                    <StackPanel Grid.Row="8" Grid.Column="2">
                        <TextBlock Text="Lead Driver" Foreground="#8E8E8E"/>
                        <ComboBox x:Name="LeadDriverTextBox"
                                  Height="32"
                                  Margin="0,6,0,0"
                                  Background="#141414"
                                  Foreground="White"
                                  BorderBrush="#2A2A2A"
                                  BorderThickness="1"
                                  Padding="8"
                                  IsEditable="False"/>
                    </StackPanel>

                    <StackPanel Grid.Row="10" Grid.Column="0">
                        <TextBlock Text="Status" Foreground="#8E8E8E"/>
                        <ComboBox x:Name="StatusComboBox"
                                  Height="32"
                                  Margin="0,6,0,0"
                                  Background="#141414"
                                  Foreground="White"
                                  BorderBrush="#2A2A2A"
                                  BorderThickness="1"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Planned"/>
                            <ComboBoxItem Content="Live"/>
                            <ComboBoxItem Content="Completed"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="12" Grid.ColumnSpan="3">
                        <TextBlock Text="Notes" Foreground="#8E8E8E"/>
                        <TextBox x:Name="NotesTextBox"
                                 Height="140"
                                 Margin="0,6,0,0"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#141414"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 BorderThickness="1"
                                 Padding="10"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="4">
            <TextBlock x:Name="StatusTextBlock"
                       Text=""
                       Foreground="#8A8A8A"
                       VerticalAlignment="Center"/>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save Convoy"
                        Width="130"
                        Height="34"
                        Margin="0,0,10,0"
                        Click="Save_Click"/>
                <Button Content="Close"
                        Width="110"
                        Height="34"
                        Click="Close_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>