<UserControl x:Class="OverWatchELD.Views.MessagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OverWatchELD.ViewModels"
             Background="#F7F8FA"
             Foreground="#111827">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Simple button styles -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#111827"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F2937"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0B1220"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Message bubble template -->
        <DataTemplate DataType="{x:Type vm:MessagesViewModel+MessageVm}">
            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ✅ Avatar (Discord avatar if AvatarUrl present; fallback to initials) -->
                <Grid Grid.Column="0"
                      Width="34"
                      Height="34"
                      Margin="0,0,10,0"
                      VerticalAlignment="Top"
                      Visibility="{Binding ShowAvatar, Converter={StaticResource BoolToVis}}">

                    <Ellipse Fill="#E5E7EB"/>

                    <Ellipse>
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AvatarUrl}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AvatarUrl}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <TextBlock Text="{Binding SenderInitials}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="#111827"
                               FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AvatarUrl}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AvatarUrl}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- ✅ Dispatcher badge overlay -->
                    <Border Width="16"
                            Height="16"
                            CornerRadius="8"
                            Background="#111827"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,-2,-2,0"
                            Visibility="Collapsed">
                        <TextBlock Text="🛡"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#FFFFFF"/>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDispatcher}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                </Grid>

                <!-- Bubble stack -->
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="{Binding BubbleAlign}">

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,3"
                                Visibility="{Binding ShowHeader, Converter={StaticResource BoolToVis}}">

                        <TextBlock Text="{Binding SenderName}"
                                   Foreground="#111827"
                                   FontWeight="SemiBold"/>

                        <!-- ✅ Dispatcher badge inline -->
                        <Border Background="#111827"
                                CornerRadius="7"
                                Padding="6,2"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛡"
                                           Foreground="#FFFFFF"
                                           FontSize="11"/>
                                <TextBlock Text=" DISPATCH"
                                           Foreground="#FFFFFF"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDispatcher}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <TextBlock Text=" • " Foreground="#9CA3AF" Margin="8,0,0,0"/>
                        <TextBlock Text="{Binding MetaText}" Foreground="#6B7280"/>
                    </StackPanel>

                    <Border Background="{Binding BubbleBackground}"
                            CornerRadius="14"
                            Padding="12"
                            MaxWidth="540"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1">
                        <StackPanel>
                            <Border CornerRadius="12"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                                <Image Source="{Binding ImagePath}"
                                       Stretch="UniformToFill"
                                       Height="180"
                                       Width="260"/>
                            </Border>

                            <TextBlock Text="{Binding Text}"
                                       TextWrapping="Wrap"
                                       Foreground="#111827"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <!-- KEEP the rest of your layout exactly as you had it -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="310"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="14">
                    <TextBlock Text="Messages" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Messages / Driver comms" Margin="0,2,0,0" Foreground="#6B7280"/>
                    <CheckBox Content="Archived" Margin="0,8,0,0" IsChecked="{Binding ShowArchived}" Foreground="#111827"/>
                </StackPanel>

                <ListBox Grid.Row="1"
                         Margin="8"
                         ItemsSource="{Binding Conversations}"
                         SelectedItem="{Binding SelectedConversation}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:MessagesViewModel+ConversationVm}">
                            <Border Padding="12"
                                    CornerRadius="12"
                                    Margin="0,0,0,8"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    Background="#FFFFFF">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="40" Height="40" CornerRadius="20"
                                            Background="#111827"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Initials}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#111827"/>
                                        <TextBlock Text="{Binding LastSnippet}"
                                                   Foreground="#6B7280"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding LastTimeText}"
                                               Foreground="#6B7280"
                                               VerticalAlignment="Top"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="14" Orientation="Horizontal">
                    <Button Style="{StaticResource GhostButton}" Content="New" Width="80"/>
                    <Button Style="{StaticResource GhostButton}" Content="Delete" Width="80" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CENTER -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid Margin="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding SelectedConversation.Title}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                        <TextBlock Text="{Binding BridgeStatusText}"
                                   Foreground="#6B7280"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <CheckBox Grid.Column="1"
                              Content="Inbound"
                              IsChecked="{Binding DiscordInboundEnabled}"
                              Foreground="#111827"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding SelectedConversation.Messages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Margin="18,12,18,18"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="To:" VerticalAlignment="Center" Foreground="#6B7280" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding RecipientText}"
                                 Height="32"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 Background="#F9FAFB"
                                 BorderBrush="#E5E7EB"
                                 BorderThickness="1"
                                 Margin="0,0,10,0"/>
                        <Button Grid.Column="2"
                                Style="{StaticResource GhostButton}"
                                Content="Apply"
                                Width="70"
                                Click="ApplyRecipient_Click"/>
                    </Grid>

                    <TextBox x:Name="ComposerBox"
                             Grid.Row="1"
                             Text="{Binding ComposerText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             MinHeight="44"
                             MaxHeight="120"
                             Padding="10"
                             Background="#F9FAFB"
                             BorderBrush="#E5E7EB"
                             BorderThickness="1"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource GhostButton}" Content="Attach" Width="86" Click="Attach_Click"/>
                            <Button Style="{StaticResource GhostButton}" Content="Clear" Width="86" Margin="10,0,0,0" Click="ClearAttach_Click"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource PrimaryButton}"
                                Content="Send"
                                Width="96"
                                Click="Send_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- RIGHT -->
        <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1,0,0,0">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Diagnostics" FontSize="16" FontWeight="Bold" Foreground="#111827"/>

                <TextBlock Grid.Row="1" Text="{Binding LastPollAt}" Foreground="#6B7280" Margin="0,8,0,6"/>
                <TextBlock Grid.Row="2" Text="{Binding LastPollUrl}" Foreground="#6B7280" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>

                <TextBox Grid.Row="3"
                         Text="{Binding LastPollError, Mode=OneWay}"
                         IsReadOnly="True"
                         Background="#FFF7ED"
                         Foreground="#9A3412"
                         BorderBrush="#FDBA74"
                         BorderThickness="1"
                         Padding="8"
                         Margin="0,0,0,8"
                         TextWrapping="Wrap">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LastPollError}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LastPollError}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <TextBox Grid.Row="4"
                         Text="{Binding LastPollJson, Mode=OneWay}"
                         IsReadOnly="True"
                         Height="120"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         Background="#F9FAFB"
                         BorderBrush="#E5E7EB"
                         BorderThickness="1"
                         Padding="8"/>

                <ListBox Grid.Row="5"
                         ItemsSource="{Binding DebugLines}"
                         Background="#FFFFFF"
                         BorderBrush="#E5E7EB"
                         BorderThickness="1"
                         Margin="0,10,0,0"
                         FontFamily="Consolas"
                         FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
