<Window x:Class="OverWatchELD.Views.ConvoyAttendeesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Convoy Attendees"
        Height="700"
        Width="920"
        MinHeight="620"
        MinWidth="820"
        WindowStartupLocation="CenterOwner"
        Background="#111111">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10" Padding="14">
            <StackPanel>
                <TextBlock x:Name="ConvoyTitleTextBlock"
                           Text="Convoy Attendees"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Manage convoy attendance."
                           Foreground="#BFBFBF"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="10" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Name" Foreground="#8E8E8E"/>
                    <TextBox x:Name="AttendeeNameTextBox"
                             Height="32"
                             Margin="0,6,0,0"
                             Background="#141414"
                             Foreground="White"
                             BorderBrush="#2A2A2A"
                             BorderThickness="1"
                             Padding="8"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Truck" Foreground="#8E8E8E"/>
                    <TextBox x:Name="AttendeeTruckTextBox"
                             Height="32"
                             Margin="0,6,0,0"
                             Background="#141414"
                             Foreground="White"
                             BorderBrush="#2A2A2A"
                             BorderThickness="1"
                             Padding="8"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Role" Foreground="#8E8E8E"/>
                    <ComboBox x:Name="AttendeeRoleComboBox"
                              Height="32"
                              Margin="0,6,0,0"
                              Background="#141414"
                              Foreground="White"
                              BorderBrush="#2A2A2A"
                              BorderThickness="1"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Driver"/>
                        <ComboBoxItem Content="Lead"/>
                        <ComboBoxItem Content="Tail"/>
                        <ComboBoxItem Content="Staff"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="6">
                    <TextBlock Text="Status" Foreground="#8E8E8E"/>
                    <ComboBox x:Name="AttendeeStatusComboBox"
                              Height="32"
                              Margin="0,6,0,0"
                              Background="#141414"
                              Foreground="White"
                              BorderBrush="#2A2A2A"
                              BorderThickness="1"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Attending"/>
                        <ComboBoxItem Content="Maybe"/>
                        <ComboBoxItem Content="Unavailable"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="#1E1E1E" CornerRadius="10" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="AttendeesGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="#141414"
                          Foreground="White"
                          BorderBrush="#2A2A2A"
                          BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                        <DataGridTextColumn Header="Truck" Binding="{Binding Truck}" Width="1.2*"/>
                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="1.2*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.2*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Add Attendee"
                            Width="120"
                            Margin="0,0,8,0"
                            Click="AddAttendee_Click"/>
                    <Button Content="Remove Selected"
                            Width="130"
                            Click="RemoveSelected_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel Grid.Row="6">
            <TextBlock x:Name="StatusTextBlock"
                       Text=""
                       Foreground="#8A8A8A"
                       VerticalAlignment="Center"/>

            <Button Content="Close"
                    Width="110"
                    Height="34"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    Click="Close_Click"/>
        </DockPanel>
    </Grid>
</Window>