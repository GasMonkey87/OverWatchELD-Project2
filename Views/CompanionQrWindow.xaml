<Window x:Class="OverWatchELD.Views.CompanionQrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Companion QR"
        Height="520"
        Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0B1220"
        Foreground="#E5E7EB">
    <Border Margin="12"
            Padding="16"
            Background="#111827"
            BorderBrush="#22314A"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Open Companion on Phone"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1"
                       Text="Scan this QR code while your phone and PC are on the same Wi-Fi."
                       Foreground="#9CA3AF"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>

            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Image x:Name="QrImage"
                       Width="260"
                       Height="260"
                       Stretch="Uniform"/>
            </Border>

            <TextBox x:Name="UrlTextBox"
                     Grid.Row="3"
                     Margin="0,16,0,0"
                     Padding="10"
                     IsReadOnly="True"
                     Background="#0F172A"
                     Foreground="#E5E7EB"
                     BorderBrush="#334155"
                     TextWrapping="Wrap"/>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button Content="Copy Link"
                        Width="92"
                        Margin="0,0,8,0"
                        Click="CopyLink_Click"/>
                <Button Content="Open in Browser"
                        Width="110"
                        Margin="0,0,8,0"
                        Click="OpenBrowser_Click"/>
                <Button Content="Close"
                        Width="80"
                        Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>