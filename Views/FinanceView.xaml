<UserControl x:Class="OverWatchELD.Views.FinanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111111"
             Foreground="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Company Finance"
                       FontSize="20"
                       FontWeight="SemiBold"/>
            <TextBlock x:Name="FinanceStatusText"
                       Text="Company-wide finance ledger."
                       Opacity="0.75"
                       Margin="0,3,0,0"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,12">
            <Border Background="#1A1A1A" CornerRadius="10" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Balance" Opacity="0.7"/>
                    <TextBlock x:Name="BalanceText" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Background="#1A1A1A" CornerRadius="10" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Income" Opacity="0.7"/>
                    <TextBlock x:Name="IncomeText" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Background="#1A1A1A" CornerRadius="10" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Expenses" Opacity="0.7"/>
                    <TextBlock x:Name="ExpenseText" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Background="#1A1A1A" CornerRadius="10" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Fuel" Opacity="0.7"/>
                    <TextBlock x:Name="FuelText" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Background="#1A1A1A" CornerRadius="10" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Maintenance" Opacity="0.7"/>
                    <TextBlock x:Name="MaintenanceText" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Background="#1A1A1A" CornerRadius="10" Padding="12">
                <StackPanel>
                    <TextBlock Text="Repairs" Opacity="0.7"/>
                    <TextBlock x:Name="RepairsText" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Background="#1A1A1A"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="EntryTypeComboBox"
                          Grid.Column="0"
                          Margin="0,0,8,0"
                          Height="34"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Expense"/>
                    <ComboBoxItem Content="Income"/>
                </ComboBox>

                <ComboBox x:Name="CategoryComboBox"
                          Grid.Column="1"
                          Margin="0,0,8,0"
                          Height="34"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Fuel"/>
                    <ComboBoxItem Content="Maintenance"/>
                    <ComboBoxItem Content="Repairs"/>
                    <ComboBoxItem Content="Tolls"/>
                    <ComboBoxItem Content="Fines"/>
                    <ComboBoxItem Content="Truck Purchase"/>
                    <ComboBoxItem Content="Trailer Purchase"/>
                    <ComboBoxItem Content="Payroll"/>
                    <ComboBoxItem Content="Delivery Revenue"/>
                    <ComboBoxItem Content="Misc"/>
                </ComboBox>

                <TextBox x:Name="AmountTextBox"
                         Grid.Column="2"
                         Margin="0,0,8,0"
                         Height="34"
                         VerticalContentAlignment="Center"/>

                <TextBox x:Name="TruckTextBox"
                         Grid.Column="3"
                         Margin="0,0,8,0"
                         Height="34"
                         VerticalContentAlignment="Center"/>

                <TextBox x:Name="UserTextBox"
                         Grid.Column="4"
                         Margin="0,0,8,0"
                         Height="34"
                         VerticalContentAlignment="Center"
                         IsReadOnly="True"/>

                <TextBox x:Name="DescriptionTextBox"
                         Grid.Column="5"
                         Margin="0,0,8,0"
                         Height="34"
                         VerticalContentAlignment="Center"/>

                <Button x:Name="AddFinanceEntryButton"
                        Grid.Column="6"
                        Content="Add Entry"
                        Margin="0,0,8,0"
                        Padding="14,8"
                        Click="AddFinanceEntryButton_Click"/>

                <Button x:Name="DeleteFinanceEntryButton"
                        Grid.Column="7"
                        Content="Delete Selected"
                        Padding="14,8"
                        Click="DeleteFinanceEntryButton_Click"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="3"
                  x:Name="FinanceGrid"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  Background="#161616"
                  Foreground="White"
                  BorderBrush="#2A2A2A"
                  RowBackground="#161616"
                  AlternatingRowBackground="#1D1D1D"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date UTC" Binding="{Binding DateUtc}" Width="1.3*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding EntryType}" Width="0.8*"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1*"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="0.9*"/>
                <DataGridTextColumn Header="Truck" Binding="{Binding TruckName}" Width="1*"/>
                <DataGridTextColumn Header="User" Binding="{Binding DiscordUsername}" Width="1.1*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="1.8*"/>
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="0.8*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>