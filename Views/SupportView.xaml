<UserControl x:Class="OverWatchELD.Views.SupportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBgBrush" Color="#111827"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="CardBgAltBrush" Color="#243041"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#374151"/>
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="BodyTextBrush" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#60A5FA"/>
        <SolidColorBrush x:Key="WarnBgBrush" Color="#3B2A17"/>
        <SolidColorBrush x:Key="WarnBorderBrush" Color="#C2410C"/>
        <SolidColorBrush x:Key="WarnTextBrush" Color="#FED7AA"/>

        <Style TargetType="Border" x:Key="CardBorderStyle">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionHeaderStyle">
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="BodyTextStyle">
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>


        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="Background" Value="#132238"/>
            <Setter Property="BorderBrush" Value="#385476"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="IsTextSearchEnabled" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="#132238"
                                    BorderBrush="#385476"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="10,0,4,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      RecognizesAccessKey="True"/>

                                    <Border Grid.Column="1"
                                            Background="#163B65"
                                            BorderBrush="#385476"
                                            BorderThickness="1,0,0,0">
                                        <Path Width="10"
                                              Height="6"
                                              Stretch="Fill"
                                              Fill="#EAF2FF"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M 0 0 L 10 0 L 5 6 Z"/>
                                    </Border>

                                    <ToggleButton Grid.ColumnSpan="2"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  ClickMode="Press"
                                                  IsChecked="{Binding IsDropDownOpen,
                                                                      RelativeSource={RelativeSource TemplatedParent},
                                                                      Mode=TwoWay}"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="400">
                                    <Border Background="#132238"
                                            BorderBrush="#385476"
                                            BorderThickness="1">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      MaxHeight="400">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder"
                                        Property="BorderBrush"
                                        Value="#4A91D0"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder"
                                        Property="BorderBrush"
                                        Value="#4A91D0"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder"
                                        Property="Opacity"
                                        Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type ComboBoxItem}">
                        <Setter Property="Foreground" Value="#EAF2FF"/>
                        <Setter Property="Background" Value="#132238"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder"
                                                    Property="Background"
                                                    Value="#245B8F"/>
                                            <Setter Property="Foreground"
                                                    Value="#FFFFFF"/>
                                        </Trigger>

                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder"
                                                    Property="Background"
                                                    Value="#1F7A4D"/>
                                            <Setter Property="Foreground"
                                                    Value="#FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Margin" Value="0,12,0,12"/>
            <Setter Property="Background" Value="#374151"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBgBrush}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Style="{StaticResource CardBorderStyle}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Support"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource HeaderTextBrush}"/>
                    <TextBlock Text="Help, troubleshooting, diagnostics, setup guidance, and support tools for OverWatch ELD."
                               Margin="0,4,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="User Guide"
                            Margin="0,0,8,0"
                            Click="OpenGuide_Click"/>
                    <Button Content="Open Logs Folder"
                            Margin="0,0,8,0"
                            Command="{Binding OpenLogsFolderCommand}"/>
                    <Button Content="Export Diagnostics"
                            Command="{Binding ExportDiagnosticsCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="410"/>
            </Grid.ColumnDefinitions>

            <!-- Left -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Support Status -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0">
                                <TextBlock Text="Support Status" Style="{StaticResource SectionHeaderStyle}"/>
                                <Button DockPanel.Dock="Right"
                                        Content="Refresh Status"
                                        Padding="10,5"
                                        Command="{Binding RefreshStatusCommand}"/>
                            </DockPanel>

                            <Border Grid.Row="1"
                                    Background="#0F172A"
                                    CornerRadius="10"
                                    Padding="10"
                                    Margin="0,10,0,0"
                                    BorderBrush="#334155"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding StatusReport}"
                                           Style="{StaticResource BodyTextStyle}"/>
                            </Border>

                            <TextBlock Grid.Row="2"
                                       Text="{Binding StatusLine}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <!-- Quick Help -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Quick Help / First Things to Check"
                                       Style="{StaticResource SectionHeaderStyle}"/>

                            <Border Background="#0F172A"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="• Make sure American Truck Simulator is running."/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="• Make sure the telemetry server/plugin is installed and running."/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="• Make sure OverWatch ELD was started after ATS and telemetry."/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="• If using VTC features, verify the Bot API URL and guild pairing."/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="• If dispatch messages fail, verify pairing, routing, and bot status."/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="• If something looks stuck, refresh status, reopen the page, or restart the ELD."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Telemetry Requirement -->
                    <Border Background="{StaticResource WarnBgBrush}"
                            BorderBrush="{StaticResource WarnBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="⚠ Telemetry Reader Required"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Foreground="{StaticResource WarnTextBrush}"/>

                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource WarnTextBrush}">
                                OverWatch ELD requires the external telemetry reader/plugin to be installed and running.
                                Without it, truck data, speed, status detection, map updates, and HOS-related features
                                may not function correctly.
                            </TextBlock>

                            <TextBlock Margin="0,10,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource WarnTextBrush}"
                                       Text="Required Telemetry Plugin:"/>

                            <TextBlock Margin="0,2,0,0"
                                       Text="Funbit ETS2 / ATS Telemetry Server"
                                       Foreground="#93C5FD"/>

                            <Button Content="Open Telemetry Download Page"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding OpenTelemetryDownloadCommand}"/>

                            <Separator/>

                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{StaticResource WarnTextBrush}"
                                       Text="Installation Instructions:"/>

                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource WarnTextBrush}">
1. Download the telemetry server/plugin.
2. Extract the files if needed.
3. Install it or copy it into the ATS plugin folder.
4. Start American Truck Simulator.
5. Start the telemetry server and confirm it is listening.
6. Launch OverWatch ELD after ATS is already running.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Telemetry Settings -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Telemetry Settings" Style="{StaticResource SectionHeaderStyle}"/>

                            <TextBlock Grid.Row="1"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource BodyTextStyle}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Set the path to the telemetry server executable so OverWatch ELD can auto-start it if enabled."/>

                            <Grid Grid.Row="2" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="TelemetryExePathTextBox"
         Grid.Column="0"
         Height="30"
         VerticalContentAlignment="Center"
         Text="{Binding TelemetryExePath, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

                                <Button Grid.Column="1"
        Margin="10,0,0,0"
        Content="Browse"
        Click="BrowseTelemetryExe_Click"/>
                            </Grid>

                            <Border Grid.Row="3"
                                    Margin="0,10,0,0"
                                    Padding="10"
                                    CornerRadius="8"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    Background="#0F172A">
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="{Binding TelemetryStatusBrush}"
                                           FontWeight="SemiBold"
                                           Text="{Binding TelemetryStatusText}" />
                            </Border>

                            <StackPanel Grid.Row="4"
                                        Orientation="Horizontal"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Right">
                                <CheckBox Content="Auto-start telemetry with ELD"
                                          IsChecked="{Binding AutoStartTelemetry}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>

                                <Button Content="Start Telemetry Now"
                                        Margin="0,0,8,0"
                                        Command="{Binding StartTelemetryNowCommand}"/>

                                <Button Content="Save"
                                        Command="{Binding SaveTelemetrySettingsCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Normal ELD Support Tools -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="ELD Support Tools"
                                       Style="{StaticResource SectionHeaderStyle}"/>

                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource BodyTextStyle}"
                                       Text="Use these areas when troubleshooting common ELD issues:"/>

                            <Border Background="#0F172A"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="• Logs and daily log export"/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="• Inspections and DVIR-style entries"/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="• Compliance and log correction/review screens"/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="• Dispatch messaging and conversation sync"/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="• Fleet assignment, maintenance status, and truck data"/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="• Diagnostics export for troubleshooting support tickets"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Report Issue -->
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Report an Issue" Style="{StaticResource SectionHeaderStyle}"/>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="Category"
                                           Width="90"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource BodyTextBrush}"/>
                                <ComboBox Width="240"
                                          ItemsSource="{Binding Categories}"
                                          SelectedItem="{Binding SelectedCategory}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="Severity"
                                           Width="90"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource BodyTextBrush}"/>
                                <ComboBox Width="240"
                                          ItemsSource="{Binding Severities}"
                                          SelectedItem="{Binding SelectedSeverity}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="Your Email"
                                           Width="90"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource BodyTextBrush}"/>
                                <TextBox Width="420"
                                         Text="{Binding SenderEmail, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="Title"
                                           Width="90"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource BodyTextBrush}"/>
                                <TextBox Width="420"
                                         Text="{Binding TicketTitle, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="5" Margin="0,10,0,0">
                                <TextBlock Text="Describe what happened"
                                           Foreground="{StaticResource BodyTextBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBox Height="140"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding TicketDescription, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="6"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,12,0,0">
                                <CheckBox Content="Include diagnostics package"
                                          IsChecked="{Binding IncludeDiagnostics}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>
                                <Button Content="Create Ticket"
                                        Padding="14,7"
                                        Command="{Binding CreateTicketCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Right -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- FAQ -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="FAQ" Style="{StaticResource SectionHeaderStyle}"/>

                            <Expander Header="Why do clocks not update?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="Usually telemetry is not running. Install the Funbit telemetry plugin/server, start ATS, confirm the telemetry reader is active, then launch OverWatch ELD."/>
                                </Border>
                            </Expander>

                            <Expander Header="What is OverWatch ELD?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="OverWatch ELD is a trucking operations app for American Truck Simulator VTC use. It combines logs, inspections, dispatch messaging, maintenance, fleet tools, documents, and VTC-connected features in one place."/>
                                </Border>
                            </Expander>

                            <Expander Header="How do I connect the ELD to my VTC?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="Open Settings, enter the Bot API URL, choose or confirm the guild/VTC, then complete pairing using your Discord link code. Once paired, VTC name, announcements, dispatch, and other linked features can load."/>
                                </Border>
                            </Expander>

                            <Expander Header="How do I send messages to dispatch?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="Go to Dispatch, open your inbox or conversation, type your message, and send it through the linked bot connection. Make sure the Bot API URL, guild pairing, and thread routing are set correctly first."/>
                                </Border>
                            </Expander>

                            <Expander Header="Why is my VTC page empty or not loading?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="This usually means the Bot API URL is missing, the bot is offline, the guild is not selected, or the ELD has not been paired correctly. Check Settings and verify the connection details."/>
                                </Border>
                            </Expander>

                            <Expander Header="How do I export logs?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="Use the Logs page or export actions in the app to generate your daily logs output. Depending on your setup, logs can be saved locally or sent through configured webhook/export destinations."/>
                                </Border>
                            </Expander>

                            <Expander Header="How do inspections work?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="The Inspections page is used for pre-trip, post-trip, and other inspection entries. Enter the inspection details, save them, and export or submit them based on how your ELD is configured."/>
                                </Border>
                            </Expander>

                            <Expander Header="What does the Fleet page do?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="The Fleet page helps manage trucks, assignments, drivers, maintenance status, and vehicle-related information. It acts like a fleet command center inside the ELD."/>
                                </Border>
                            </Expander>

                            <Expander Header="How does maintenance tracking work?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="Maintenance tracking is used to record service events, inspections, and condition updates. It helps keep a usable history of truck upkeep and service needs."/>
                                </Border>
                            </Expander>

                            <Expander Header="What is the Documents page for?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="The Documents page is a place for company instructions, driver guidance, ELD help information, and internal support documentation."/>
                                </Border>
                            </Expander>

                            <Expander Header="Can I use keyboard shortcuts in the ELD?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="Yes. Hotkeys can be added for things like minimizing the app, going to dispatch, opening fleet, logs, documents, and other pages. These help speed up navigation."/>
                                </Border>
                            </Expander>

                            <Expander Header="Why are messages not sending?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="If messages fail to send, check the Bot API URL, guild pairing, dispatch setup, and bot health. A bad request usually means the bot did not receive the message in the format it expected."/>
                                </Border>
                            </Expander>

                            <Expander Header="How do I update the app?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="Use the built-in updater if available, or install the latest release package from your configured release source. Verify the version file and installer URL are correct."/>
                                </Border>
                            </Expander>

                            <Expander Header="Why is the truck not showing speed, city, or live data?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="That usually means telemetry is not connected, ATS is not running, or the telemetry server/plugin is not active. Check telemetry setup first before looking for other issues."/>
                                </Border>
                            </Expander>

                            <Expander Header="Why is my log or compliance page missing data?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="Missing log/compliance data can happen when telemetry is not connected, the session was not started correctly, or the underlying log source was not refreshed. Check clocks, telemetry, and your current duty/session status."/>
                                </Border>
                            </Expander>

                            <Expander Header="What should I include in a support ticket?">
                                <Border Background="#1F2937" Padding="12" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="Include what page you were on, what you clicked, what you expected to happen, what actually happened, and whether telemetry, VTC, or dispatch was connected at the time. Diagnostics are highly recommended."/>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <!-- Resources -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Resources" Style="{StaticResource SectionHeaderStyle}"/>

                            <Button Content="Open Settings / Vehicle Connect"
                                    Margin="0,10,0,0"
                                    Command="{Binding OpenConnectVehicleCommand}"/>

                            <Button Content="Open Compliance Help"
                                    Margin="0,8,0,0"
                                    Command="{Binding OpenComplianceHelpCommand}"/>

                            <Button Content="Open Logs Folder"
                                    Margin="0,8,0,0"
                                    Command="{Binding OpenLogsFolderCommand}"/>

                            <Button Content="Export Diagnostics"
                                    Margin="0,8,0,0"
                                    Command="{Binding ExportDiagnosticsCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- Troubleshooting -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Troubleshooting Checklist" Style="{StaticResource SectionHeaderStyle}"/>

                            <Border Background="#0F172A"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="1. Confirm ATS is running."/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="2. Confirm telemetry/plugin is installed and active."/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="3. Confirm the ELD launched after ATS."/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="4. Refresh status on this page."/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="5. Check Settings and linked VTC configuration."/>
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,0"
                                               Text="6. Export diagnostics before opening a ticket."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Support Output -->
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Support Output" Style="{StaticResource SectionHeaderStyle}"/>

                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Last Ticket ID"/>

                            <Border Background="#0F172A"
                                    CornerRadius="10"
                                    Padding="10"
                                    Margin="0,6,0,0"
                                    BorderBrush="#334155"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding LastTicketId}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource BodyTextBrush}"/>
                            </Border>

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Latest Result"/>

                            <Border Background="#0F172A"
                                    CornerRadius="10"
                                    Padding="10"
                                    Margin="0,6,0,0"
                                    BorderBrush="#334155"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding LastTicketResult}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource BodyTextBrush}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Recent Tickets -->
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Recent Tickets" Style="{StaticResource SectionHeaderStyle}"/>

                            <Border Background="#0F172A"
                                    CornerRadius="10"
                                    Padding="0"
                                    Margin="0,8,0,0"
                                    BorderBrush="#334155"
                                    BorderThickness="1">
                                <ListBox ItemsSource="{Binding RecentTickets}"
                                         MinHeight="180"
                                         BorderThickness="0"
                                         Background="Transparent"/>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>