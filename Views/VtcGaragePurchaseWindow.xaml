<Window x:Class="OverWatchELD.Views.VtcGaragePurchaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add VTC Garage"
        Width="900"
        Height="680"
        WindowStartupLocation="CenterOwner"
        Background="#0B1220">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

    </Window.Resources>

    <Grid Margin="18">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP -->
        <DockPanel Margin="0,0,0,14">

            <TextBlock Text="Purchase ATS Garage"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       DockPanel.Dock="Left"/>

            <Button Content="Refresh ATS Garages"
                    Width="180"
                    Height="40"
                    DockPanel.Dock="Right"
                    Command="{Binding RefreshCommand}"/>

        </DockPanel>

        <!-- GARAGE LIST -->
        <Border Grid.Row="1"
                Background="#111827"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12">

            <ListView ItemsSource="{Binding GarageView}"
                      SelectedItem="{Binding SelectedGarage}"
                      Background="#111827"
                      Foreground="White"
                      BorderThickness="0">

                <!-- GROUP BY STATE -->
                <ListView.GroupStyle>

                    <GroupStyle>

                        <GroupStyle.HeaderTemplate>

                            <DataTemplate>

                                <Border Background="#1E293B"
                                        Padding="10"
                                        Margin="0,12,0,6"
                                        CornerRadius="8">

                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="Bold"/>

                                </Border>

                            </DataTemplate>

                        </GroupStyle.HeaderTemplate>

                    </GroupStyle>

                </ListView.GroupStyle>

                <!-- COLUMNS -->
                <ListView.View>

                    <GridView>

                        <GridViewColumn Header="City"
                                        Width="260"
                                        DisplayMemberBinding="{Binding CityName}"/>

                        <GridViewColumn Header="Garage Size"
                                        Width="120"
                                        DisplayMemberBinding="{Binding Size}"/>

                        <GridViewColumn Header="Capacity"
                                        Width="90"
                                        DisplayMemberBinding="{Binding TruckCapacity}"/>

                        <GridViewColumn Header="Price"
                                        Width="140"
                                        DisplayMemberBinding="{Binding PurchasePrice}"/>

                        <GridViewColumn Header="Action"
                                        Width="130">

                            <GridViewColumn.CellTemplate>

                                <DataTemplate>

                                    <Button Content="Purchase"
                                            Width="100"
                                            Height="32"
                                            Command="{Binding DataContext.PurchaseCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"/>

                                </DataTemplate>

                            </GridViewColumn.CellTemplate>

                        </GridViewColumn>

                    </GridView>

                </ListView.View>

            </ListView>

        </Border>

    </Grid>

</Window>