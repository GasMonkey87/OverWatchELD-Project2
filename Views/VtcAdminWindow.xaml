<Window x:Class="OverWatchELD.Views.VtcAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VTC Admin"
        Height="880"
        Width="1320"
        MinHeight="680"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        Background="#111111">

    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="RowBackground" Value="#141414"/>
            <Setter Property="AlternatingRowBackground" Value="#181818"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2A2A2A"/>
            <Setter Property="VerticalGridLinesBrush" Value="#2A2A2A"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="34"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="#111111">

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="VTC Admin Panel"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="SubtitleText"
                                   Text="Manage roster, truck assignments, admin actions, and managers."
                                   Foreground="#BFBFBF"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#1F2A36"
                            CornerRadius="10"
                            Padding="12,6"
                            VerticalAlignment="Top">
                        <TextBlock x:Name="RoleBadgeText"
                                   Text="Admin Access"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="10" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Driver Management"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <Border Grid.Row="2"
                                Background="#141414"
                                BorderBrush="#2A2A2A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Height="520">

                            <DataGrid x:Name="AdminRosterGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      RowHeaderWidth="0"
                                      BorderThickness="0"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.CanContentScroll="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Driver" Binding="{Binding Driver}" Width="2*"/>
                                    <DataGridTextColumn Header="Truck" Binding="{Binding Truck}" Width="1.1*"/>
                                    <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="1*"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*"/>
                                    <DataGridTextColumn Header="Discord ID" Binding="{Binding DiscordUserId}" Width="1.4*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <StackPanel Grid.Row="4"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button x:Name="RefreshRosterButton"
                                    Content="Refresh"
                                    Width="110"
                                    Margin="0,0,8,0"
                                    Click="Refresh_Click"/>
                            <Button x:Name="OpenProfileButton"
                                    Content="Open Driver Profile"
                                    Width="160"
                                    Margin="0,0,8,0"
                                    Click="OpenProfile_Click"/>
                            <Button x:Name="AssignTruckButton"
                                    Content="Assign Truck"
                                    Width="120"
                                    Margin="0,0,8,0"
                                    Click="AssignTruck_Click"/>
                            <Button x:Name="SaveRoleButton"
                                    Content="Save Role"
                                    Width="120"
                                    Margin="0,0,8,0"
                                    Click="ChangeRole_Click"/>
                            <Button x:Name="TruckApprovalButton"
                                    Content="Truck Approval"
                                    Width="120"
                                    Margin="0,0,8,0"
                                    Click="TruckApprovals_Click"/>
                            <Button x:Name="DriverEndorsementButton"
                                    Content="Endorsements"
                                    Width="120"
                                    Click="DriverEndorsements_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Quick Actions"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <Button x:Name="QuickRefreshButton" Content="Refresh Roster" Margin="0,12,0,0" Click="Refresh_Click"/>
                            <Button x:Name="OpenDispatchButton" Content="Open Dispatch" Margin="0,8,0,0" Click="OpenDispatch_Click"/>
                            <Button x:Name="PayRollButton" Content="Payroll" Margin="0,8,0,0" Click="RealDriverPayroll_Click"/>
                            <Button x:Name="ProfitLeaderboardsButton" Content="Profit / Leaderboards" Margin="0,8,0,0" Click="ProfitLeaderboards_Click"/>
                            <Button x:Name="OpenMaintenanceButton" Content="Open Maintenance" Margin="0,8,0,0" Click="OpenMaintenance_Click"/>
                            <Button x:Name="OperationsCommandCenterButton" Content="Operations Command Center" Margin="0,8,0,0" Click="OperationsCommandCenter_Click" FontWeight="SemiBold"/>
                            <Button x:Name="FuelMaintenanceButton" Content="Fuel / Maintenance" Margin="0,8,0,0" Click="FuelMaintenance_Click"/>
                            <Button x:Name="DriverScoresButton" Content="Driver Scores" Margin="0,8,0,0" Click="DriverScores_Click"/>
                            <Button Content="Operations Hub" Margin="0,8,0,0" Padding="12,8" Click="OpenOperationsHub_Click"/>
                            <Button x:Name="DispatchContractsButton" Content="Dispatch Contracts" Margin="0,8,0,0" Click="DispatchContracts_Click"/>
                            <Button x:Name="FleetAnalyticsButton" Content="Fleet Analytics" Margin="0,8,0,0" Click="FleetAnalytics_Click"/>
                            <Button x:Name="NotificationSettingsButton" Content="Notification Settings" Margin="0,8,0,0" Click="NotificationSettings_Click" FontWeight="SemiBold"/>
                            <Button Content="Auto Create Discord Channels/Webhooks" Height="42" Margin="0,8,0,0" Click="AutoSetupDiscord_Click"/>
                            <Button Content="Inspection Compliance" Height="42" Margin="0,8,0,0" Click="InspectionCompliance_Click"/>
                            <Button Content="Repair / Sync Discord Setup" Height="42" Margin="0,8,0,0" Click="RepairDiscordSetup_Click"/>
                            <Button x:Name="SyncDriverScoreButton" Content="Sync Driver Score" Margin="0,8,0,0" Click="SyncDriverScore_Click"/>
                            <Button x:Name="FleetCommandButton"
        Content="Fleet Command Center"
        Margin="0,8,0,0"
        Height="34"
        Click="FleetCommand_Click"
        FontWeight="SemiBold"/>
                            <Button x:Name="AdminAllBolsButton"
        Content="View All BOLs"
        Margin="0,8,0,0"
        Height="34"
        Click="OpenAdminAllBols_Click"
        FontWeight="SemiBold"/>
                            <Button x:Name="WipeAllVtcDataButton"
                                    Content="Wipe All Data"
                                    Margin="0,8,0,0"
                                    Height="38"
                                    Background="#7F1D1D"
                                    BorderBrush="#991B1B"
                                    FontWeight="Bold"
                                    Click="WipeAllVtcData_Click"/>
                            <CheckBox x:Name="AutoLockDefectTruckCheckBox"
                                      Content="Auto-lock truck when inspection defect is reported"
                                      Foreground="White"
                                      Margin="0,12,0,0"
                                      Checked="AutoLockDefectTruck_Changed"
                                      Unchecked="AutoLockDefectTruck_Changed"/>

                            <TextBlock x:Name="AutoSetupStatusText"
                                       Text=""
                                       Foreground="#9CA3AF"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="10" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Roster Editor" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="2" Text="Selected Driver" Foreground="#8E8E8E"/>
                            <TextBox x:Name="SelectedDriverTextBox" Grid.Row="4" Height="32" IsReadOnly="True"/>
                            <TextBlock Grid.Row="6" Text="Truck Number" Foreground="#8E8E8E"/>
                            <TextBox x:Name="TruckNumberTextBox" Grid.Row="8" Height="32"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4" Background="#1E1E1E" CornerRadius="10" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Role / Admin Status" Foreground="White" FontSize="16" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="2" Text="Change Role" Foreground="#8E8E8E"/>
                            <ComboBox x:Name="RoleComboBox"
                                      Grid.Row="4"
                                      Height="32"
                                      Background="#141414"
                                      Foreground="White"
                                      BorderBrush="#2A2A2A"
                                      BorderThickness="1"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Owner"/>
                                <ComboBoxItem Content="Admin"/>
                                <ComboBoxItem Content="Manager"/>
                                <ComboBoxItem Content="Dispatcher"/>
                                <ComboBoxItem Content="Driver"/>
                            </ComboBox>

                            <TextBlock Grid.Row="6" Text="Managers" Foreground="#8E8E8E"/>
                            <ListBox x:Name="ManagersListBox" Grid.Row="8" MinHeight="110"/>

                            <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBox x:Name="ManagerNameTextBox" Width="180" Height="32" Margin="0,0,8,0"/>
                                <Button x:Name="AddManagerButton" Content="Add" Width="80" Margin="0,0,8,0" Click="AddManager_Click"/>
                                <Button x:Name="RemoveManagerButton" Content="Remove" Width="100" Click="RemoveManager_Click"/>
                            </StackPanel>

                            <TextBox x:Name="AdminLogTextBox"
                                     Grid.Row="12"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="120"
                                     Background="#141414"
                                     Foreground="White"
                                     BorderBrush="#2A2A2A"
                                     BorderThickness="1"
                                     Padding="10"/>

                            <Button Grid.Row="14"
                                    Content="Clear Log"
                                    Width="120"
                                    HorizontalAlignment="Right"
                                    Click="ClearLog_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <DockPanel Grid.Row="4">
                <TextBlock x:Name="FooterText"
                           Text="Owner / Admin / Manager tools"
                           Foreground="#8A8A8A"
                           VerticalAlignment="Center"/>

                <Button Content="Close"
                        Width="120"
                        Height="34"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        Click="Close_Click"/>
            </DockPanel>
        </Grid>
    </ScrollViewer>
</Window>