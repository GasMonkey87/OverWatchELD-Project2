<Window x:Class="OverWatchELD.Views.ConnectVehicleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to vehicle" Height="320" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}">

    <!-- Local resources so this window never crashes on missing keys -->
    <Window.Resources>

        <!-- Alias keys expected by this window -->
        <StaticResource x:Key="UiBgBrush" ResourceKey="WindowBackgroundBrush"/>
        <StaticResource x:Key="TextMainBrush" ResourceKey="TextMainBrush"/>
        <StaticResource x:Key="TextMutedBrush" ResourceKey="TextMutedBrush"/>
        <StaticResource x:Key="AccentBrush" ResourceKey="AccentBrush"/>
        <StaticResource x:Key="CardBackgroundBrush" ResourceKey="CardBackgroundBrush"/>
        <StaticResource x:Key="CardBorderBrush" ResourceKey="CardBorderBrush"/>

        <!-- Dim text brush -->
        <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextMuted}" Opacity="0.75"/>

        <!-- Card style used by this window -->
        <Style x:Key="Card" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <!-- Nav button style used by Cancel -->
        <Style x:Key="NavButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button used by Connect -->
        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Connect to vehicle"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextMainBrush}"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Telemetry endpoint URL"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="EndpointBox"
                         Height="32"
                         Text="http://localhost:25555/api/ets2/telemetry"/>
                <TextBlock Text="Requires Funbit Telemetry Server running."
                           Foreground="{StaticResource TextDimBrush}"
                           FontSize="11"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="12">
            <StackPanel>
                <TextBlock Text="Status" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                <TextBlock x:Name="StatusText"
                           Text="Not connected"
                           Foreground="{StaticResource TextMainBrush}"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="DetailText"
                           Text=""
                           Foreground="{StaticResource TextDimBrush}"
                           FontSize="11"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource NavButtonStyle}" MinWidth="90" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Connect" Style="{StaticResource PrimaryButton}" MinWidth="110" Click="Connect_Click"/>
        </StackPanel>
    </Grid>
</Window>