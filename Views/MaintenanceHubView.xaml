<UserControl x:Class="OverWatchELD.Views.MaintenanceHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F1012"
             Foreground="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Maintenance Hub"
                       FontSize="24"
                       FontWeight="SemiBold"/>
            <TextBlock x:Name="HubStatusText"
                       Text="Fleet maintenance alerts and billing overview."
                       Margin="0,4,0,0"
                       Foreground="#C7D0DB"/>
        </StackPanel>

        <!-- Summary cards -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,12">
            <Border Background="#15181D" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Total Fleet Cost" Foreground="#BFD0E5"/>
                    <TextBlock x:Name="TotalCostText" Text="$0.00" FontSize="22" FontWeight="SemiBold" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#15181D" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="This Month" Foreground="#BFD0E5"/>
                    <TextBlock x:Name="MonthCostText" Text="$0.00" FontSize="22" FontWeight="SemiBold" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#15181D" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Open Alerts" Foreground="#BFD0E5"/>
                    <TextBlock x:Name="OpenAlertsText" Text="0" FontSize="22" FontWeight="SemiBold" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#15181D" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Overdue" Foreground="#BFD0E5"/>
                    <TextBlock x:Name="OverdueText" Text="0" FontSize="22" FontWeight="SemiBold" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#15181D" CornerRadius="12" Padding="14">
                <StackPanel>
                    <TextBlock Text="Tickets / Damage" Foreground="#BFD0E5"/>
                    <TextBlock x:Name="IssuesText" Text="0 / 0" FontSize="22" FontWeight="SemiBold" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Alerts / actions -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1.0*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#15181D" CornerRadius="14" Padding="10" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Open Maintenance Alerts"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <Button DockPanel.Dock="Right"
                                x:Name="RefreshHubButton"
                                Content="Refresh"
                                Padding="14,8"
                                Click="RefreshHubButton_Click"/>
                    </DockPanel>

                    <DataGrid x:Name="AlertsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              Background="#11151B"
                              Foreground="White"
                              BorderThickness="0"
                              RowBackground="#11151B"
                              AlternatingRowBackground="#171C24"
                              HorizontalGridLinesBrush="#2A3442"
                              VerticalGridLinesBrush="#2A3442"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#202734"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#334052"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Truck" Binding="{Binding TruckDisplay}" Width="1.5*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding BillType}" Width="0.9*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountText}" Width="0.8*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.9*"/>
                            <DataGridTextColumn Header="Due Miles" Binding="{Binding DueMilesText}" Width="0.9*"/>
                            <DataGridTextColumn Header="Due Date" Binding="{Binding DueDateLocalText}" Width="0.9*"/>
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2.0*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#15181D" CornerRadius="14" Padding="14">
                <StackPanel>
                    <TextBlock Text="Actions"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <Button x:Name="OpenLedgerButton"
                            Content="Open Maintenance Ledger"
                            Padding="14,10"
                            Margin="0,0,0,10"
                            Click="OpenLedgerButton_Click"/>

                    <Button x:Name="OpenLedgerAlertsButton"
                            Content="Open Ledger (Alerts Only)"
                            Padding="14,10"
                            Margin="0,0,0,10"
                            Click="OpenLedgerAlertsButton_Click"/>

                    <TextBlock Text="Alert Rules"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,8,0,8"/>

                    <TextBlock Text="• Due mileage reached"
                               Foreground="#C7D0DB"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="• Due date passed"
                               Foreground="#C7D0DB"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="• Follow-up required"
                               Foreground="#C7D0DB"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="• Unresolved damage"
                               Foreground="#C7D0DB"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="• Unresolved tickets"
                               Foreground="#C7D0DB"
                               Margin="0,0,0,4"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>