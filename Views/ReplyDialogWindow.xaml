<Window x:Class="OverWatchELD.Views.ReplyDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reply"
        Width="520"
        Height="240"
        WindowStartupLocation="CenterOwner"
        Background="#111111"
        Foreground="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Reply message:" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <TextBox x:Name="ReplyBox"
                 Grid.Row="1"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="#151515"
                 BorderBrush="#2A2A2A"
                 BorderThickness="1"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Width="90" Margin="0,0,10,0" IsCancel="True"/>
            <Button Content="Send" Width="90" IsDefault="True" Click="Send_Click"/>
        </StackPanel>
    </Grid>
</Window>
