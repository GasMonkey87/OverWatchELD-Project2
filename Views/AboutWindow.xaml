<Window x:Class="OverWatchELD.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About OverWatch ELD" Height="360" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="OverWatch ELD" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Virtual ELD + VTC Dispatch + Companion Dashboard"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,14,0,14"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <StackPanel>
                <TextBlock x:Name="VersionText" Text="Version:"/>
                <TextBlock x:Name="BuildText" Text="Build:" Margin="0,6,0,0"/>
                <TextBlock Text="Notes:" FontWeight="SemiBold" Margin="0,12,0,0"/>
                <TextBlock Text="• Companion web dashboard now receives numeric HOS seconds (fixes “--:--” clocks).&#x0a;• Documents tab includes BOL creation + Discord export.&#x0a;• VTC Bot config includes AutoPost section."
                           Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button Content="Close" Padding="12,6" IsCancel="True" DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
