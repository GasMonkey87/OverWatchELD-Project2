<UserControl x:Class="OverWatchELD.Views.DailyLogsExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF0B1220">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Select Logs to Export"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="#FFE5E7EB"/>
            <TextBlock Text="Pick the days you want included, then export to a file or send the selected logs to Discord."
                       Margin="0,6,0,0"
                       Foreground="#FF9CA3AF"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,14,0,0"
                Background="#FF111827"
                BorderBrush="#22314A"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Start date" Foreground="#FF9CA3AF" Margin="0,0,0,6"/>
                    <DatePicker x:Name="StartDate" SelectedDateChanged="OnDateChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="End date" Foreground="#FF9CA3AF" Margin="0,0,0,6"/>
                    <DatePicker x:Name="EndDate" SelectedDateChanged="OnDateChanged"/>
                </StackPanel>

                <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Refresh"
                            Width="110"
                            Height="32"
                            Margin="0,0,10,0"
                            Click="Preview_Click"/>
                    <Button Content="Select All"
                            Width="110"
                            Height="32"
                            Margin="0,0,10,0"
                            Click="SelectAll_Click"/>
                    <Button Content="Clear"
                            Width="90"
                            Height="32"
                            Click="ClearSelection_Click"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Background="#FF111827"
                BorderBrush="#22314A"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="StatusText"
                           Text="Select a date range and click Refresh."
                           Foreground="#FF9CA3AF"
                           Margin="0,0,0,10"/>

                <ListBox x:Name="ResultsList"
                         Grid.Row="1"
                         Background="#FF0B1220"
                         BorderBrush="#22314A"
                         BorderThickness="1"
                         Foreground="#FFE5E7EB"
                         SelectionMode="Extended">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" BorderBrush="#1F3A5C" BorderThickness="0,0,0,1">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Click="SelectionCheckBox_Click"
                                          Foreground="#FFE5E7EB">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Summary}" Foreground="#FF9CA3AF" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </CheckBox>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <DockPanel Grid.Row="2" Margin="0,12,0,0">
                    <TextBlock x:Name="SelectedStatusText"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Foreground="#FF9CA3AF"
                               Text="0 selected"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Export Selected File"
                                Width="160"
                                Height="34"
                                Margin="0,0,10,0"
                                Click="ExportFile_Click"/>
                        <Button Content="Send Selected to Discord"
                                Width="180"
                                Height="34"
                                Click="SendDiscord_Click"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
