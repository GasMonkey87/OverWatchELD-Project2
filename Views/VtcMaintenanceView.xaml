<UserControl x:Class="OverWatchELD.Views.VtcMaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OverWatchELD.Views"
             Background="#07101F">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Panel" Color="#101A2B"/>
        <SolidColorBrush x:Key="Panel2" Color="#0B1424"/>
        <SolidColorBrush x:Key="Input" Color="#0B1220"/>
        <SolidColorBrush x:Key="Border" Color="#26364F"/>
        <SolidColorBrush x:Key="Text" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="Muted" Color="#9FB4D0"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="BorderBrush" Value="#38BDF8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="96"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                    <Setter Property="Foreground" Value="#E5E7EB"/>
                    <Setter Property="Background" Value="#374151"/>
                    <Setter Property="BorderBrush" Value="#4B5563"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Input}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource Input}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,6,14,6"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#22C55E"/>
            <Setter Property="Height" Value="12"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5EEF8"/>
            <Setter Property="RowBackground" Value="#111827"/>
            <Setter Property="AlternatingRowBackground" Value="#0B1220"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E293B"/>
            <Setter Property="VerticalGridLinesBrush" Value="#1E293B"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#CFE8FF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#334155"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="VTC Maintenance" FontSize="30" FontWeight="Bold"/>
                <TextBlock Text="{Binding RandomMalfunctionInfoText}" Foreground="#38BDF8" FontStyle="Italic" FontSize="14"/>
                <TextBlock Text="{Binding LastRequestPostStatus}" Foreground="#22C55E" FontWeight="SemiBold" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
                <Button Content="Add Truck" Command="{Binding AddTruckCommand}"/>
                <Button Content="Save" Command="{Binding SaveCommand}"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Panel}" CornerRadius="14" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Fleet Status" FontSize="18" FontWeight="Bold"/>
                    <UniformGrid Columns="2" Margin="0,10,0,0">
                        <TextBlock Text="Total Trucks" Foreground="{StaticResource Muted}"/>
                        <TextBlock Text="{Binding TotalTrucks}" FontWeight="Bold"/>
                        <TextBlock Text="Active" Foreground="{StaticResource Muted}"/>
                        <TextBlock Text="{Binding ActiveTrucks}" FontWeight="Bold"/>
                        <TextBlock Text="Out of Service" Foreground="{StaticResource Muted}"/>
                        <TextBlock Text="{Binding OutOfServiceTrucks}" FontWeight="Bold" Foreground="#EF4444"/>
                        <TextBlock Text="Open Requests" Foreground="{StaticResource Muted}"/>
                        <TextBlock Text="{Binding OpenRequestCount}" FontWeight="Bold" Foreground="#F59E0B"/>
                        <TextBlock Text="Fleet Readiness" Foreground="{StaticResource Muted}"/>
                        <TextBlock Text="{Binding FleetReadiness, StringFormat={}{0}%}" FontWeight="Bold" Foreground="#22C55E"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource Panel}" CornerRadius="14" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Current Driver Truck" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="{Binding CurrentDriverTruckDisplay}" Foreground="#CBD5E1" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding CurrentDriverIssueDisplay}" Foreground="#F59E0B" FontWeight="Bold" Margin="0,6,0,12"/>
                    <TextBlock Text="Common Truck Issue" Foreground="#CBD5E1" FontWeight="Bold"/>
                    <ComboBox ItemsSource="{Binding CommonIssues}" SelectedItem="{Binding SelectedIssue, Mode=TwoWay}" Margin="0,8,0,8"/>
                    <ProgressBar Value="{Binding RandomMalfunctionProgressValue, Mode=OneWay}" Minimum="0" Maximum="100"/>
                    <TextBlock Text="{Binding RandomMalfunctionProgressText}" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource Panel}" CornerRadius="14" Padding="14">
                <StackPanel>
                    <TextBlock Text="Request Maintenance" FontSize="18" FontWeight="Bold"/>
                    <WrapPanel Margin="0,8,0,4">
                        <CheckBox Content="DOT Inspection" IsChecked="{Binding RequestDotInspection, Mode=TwoWay}"/>
                        <CheckBox Content="Damage" IsChecked="{Binding RequestDamageRepair, Mode=TwoWay}"/>
                        <CheckBox Content="Other Maintenance" IsChecked="{Binding RequestOtherMaintenance, Mode=TwoWay}"/>
                        <CheckBox Content="Repair Malfunctions" IsChecked="{Binding RequestMalfunctionRepair, Mode=TwoWay}"/>
                    </WrapPanel>
                    <TextBox Text="{Binding RequestNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="58" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,4,0,8"/>
                    <WrapPanel>
                        <Button Content="Submit Ticket" Command="{Binding SubmitMaintenanceRequestCommand}" Background="#166534"/>
                        <Button Content="Repair Malfunctions + Ticket" Command="{Binding RepairMalfunctionsAndSubmitTicketCommand}" Background="#B45309"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="190"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource Panel2}" CornerRadius="14" Padding="10" Margin="0,0,10,10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Fleet Trucks" FontSize="19" FontWeight="Bold" Margin="4,0,0,10"/>
                    <DataGrid ItemsSource="{Binding Trucks}" SelectedItem="{Binding SelectedTruck, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Unit" Binding="{Binding UnitNumber}" Width="80"/>
                            <DataGridTextColumn Header="Truck" Binding="{Binding TruckName}" Width="*"/>
                            <DataGridTextColumn Header="Driver" Binding="{Binding AssignedDriver}" Width="140"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="150"/>
                            <DataGridTextColumn Header="Fuel" Binding="{Binding FuelPercent, StringFormat={}{0:0}%}" Width="70"/>
                            <DataGridTextColumn Header="Cond" Binding="{Binding ConditionPercent, StringFormat={}{0:0}%}" Width="70"/>
                            <DataGridTextColumn Header="Issue" Binding="{Binding CurrentIssue}" Width="170"/>
                            <DataGridCheckBoxColumn Header="OOS" Binding="{Binding OutOfService}" Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource Panel2}" CornerRadius="14" Padding="10" Margin="0,0,0,10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Maintenance Requests - double-click request # to fix" FontSize="19" FontWeight="Bold" Margin="4,0,0,10"/>
                    <DataGrid x:Name="RequestsGrid"
                              ItemsSource="{Binding MaintenanceRequests}"
                              SelectedItem="{Binding SelectedMaintenanceRequest, Mode=TwoWay}"
                              MouseDoubleClick="RequestsGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Request #" Binding="{Binding RequestNumber}" Width="145"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedLocalDisplay}" Width="130"/>
                            <DataGridTextColumn Header="Unit" Binding="{Binding UnitNumber}" Width="70"/>
                            <DataGridTextColumn Header="Truck" Binding="{Binding TruckName}" Width="130"/>
                            <DataGridTextColumn Header="Driver" Binding="{Binding DriverName}" Width="125"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding RequestSummary}" Width="140"/>
                            <DataGridTextColumn Header="Issue" Binding="{Binding CurrentIssue}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource Panel}" CornerRadius="14" Padding="10" Margin="0,0,10,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Truck Actions" FontSize="17" FontWeight="Bold" Margin="4,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Apply Issue" Command="{Binding ApplySelectedIssueCommand}" Background="#B45309"/>
                        <Button Content="Random Malfunction" Command="{Binding TriggerRandomMalfunctionCommand}" Background="#7C2D12"/>
                        <Button Content="Clear Malfunction" Command="{Binding ClearCurrentIssueCommand}" Background="#166534"/>
                        <Button Content="Mark Serviced" Command="{Binding MarkServicedCommand}" Background="#2563EB"/>
                        <Button Content="DOT Complete" Command="{Binding AddInspectionCommand}" Background="#2563EB"/>
                        <Button Content="Add Damage" Command="{Binding AddDamageReportCommand}" Background="#7F1D1D"/>
                        <Button Content="Resolve Damage" Command="{Binding ResolveDamageCommand}" Background="#166534"/>
                        <Button Content="Out of Service" Command="{Binding TakeOutOfServiceCommand}" Background="#991B1B"/>
                        <Button Content="Return Active" Command="{Binding ReturnToActiveCommand}" Background="#166534"/>
                    </WrapPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource Panel}" CornerRadius="14" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Maintenance Alerts" FontSize="17" FontWeight="Bold" Margin="4,0,0,6"/>
                    <DataGrid ItemsSource="{Binding Alerts}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100"/>
                            <DataGridTextColumn Header="Unit" Binding="{Binding UnitNumber}" Width="80"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>