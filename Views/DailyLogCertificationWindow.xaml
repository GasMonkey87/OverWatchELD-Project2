<Window x:Class="OverWatchELD.Views.DailyLogCertificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Daily Log Certification" Height="560" Width="820"
        WindowStartupLocation="CenterOwner"
        Background="#0B1220">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Border CornerRadius="12" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" Padding="16" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Daily Log Certification"
                           FontSize="18" FontWeight="SemiBold" Foreground="White"/>

                <TextBlock Grid.Row="1" Text="{Binding LogDateLabel}" Margin="0,6,0,0" Foreground="#94A3B8"/>

                <Border Grid.Row="2" Background="#1F2937" BorderBrush="#374151" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,12,0,0">
                    <TextBlock Text="{Binding CertificationText}" TextWrapping="Wrap" Foreground="#E5E7EB"/>
                </Border>

                <Border Grid.Row="3" Background="#450A0A" BorderBrush="#EF4444" BorderThickness="1"
                        CornerRadius="10" Padding="10" Margin="0,12,0,0"
                        Visibility="{Binding FocusedViolationVisibility}">
                    <StackPanel>
                        <TextBlock Text="Violations detected for this day" Foreground="#FCA5A5" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding FocusedViolationText}" Foreground="#FECACA" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="You can still view the log, but certification is blocked until violations are resolved."
                                   Foreground="#FCA5A5" Margin="0,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="Driver name" Width="110" VerticalAlignment="Center" Foreground="#E5E7EB"/>
                    <ComboBox x:Name="DriverNameBox"
                              Width="260"
                              Background="#1B2430"
                              Foreground="White"
                              BorderBrush="#334155"
                              IsEditable="False"
                              IsTextSearchEnabled="True"
                              SelectionChanged="Input_Changed"/>
                </StackPanel>

                <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Signature" Width="110" VerticalAlignment="Center" Foreground="#E5E7EB"/>
                    <TextBox x:Name="SignatureBox"
                             Width="260"
                             Background="#0F172A"
                             Foreground="White"
                             BorderBrush="#334155"
                             CaretBrush="White"
                             Text="{Binding Signature, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="Input_Changed"/>
                </StackPanel>

                <CheckBox x:Name="CertifyCheck"
                          Grid.Row="6" Margin="0,12,0,0"
                          Content="I certify that my record of duty status for this day is true and correct"
                          IsChecked="{Binding Certified}"
                          Foreground="White"
                          Checked="Input_Changed"
                          Unchecked="Input_Changed"/>

                <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Cancel"
                            Width="90"
                            Margin="0,0,10,0"
                            Background="#1E293B"
                            Foreground="White"
                            BorderBrush="#334155"
                            Click="Cancel_Click"/>

                    <Button Content="Sign this day"
                            Width="110"
                            Background="#14532D"
                            Foreground="White"
                            BorderBrush="#22C55E"
                            Click="Sign_Click"
                            IsEnabled="{Binding CanSignFocusedDay}"/>
                    <Button Content="Export to Discord"
        Height="34"
        Padding="14,6"
        Margin="0,0,8,0"
        Click="ExportDiscord_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" CornerRadius="12" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Unsigned logs" FontWeight="SemiBold" Foreground="White"/>

                <TextBlock Grid.Row="1"
                           Text="{Binding UnsignedHint}"
                           Foreground="#94A3B8"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,6">
                    <Button Content="Select all"
                            Width="92"
                            Height="28"
                            Margin="0,0,8,0"
                            Background="#1E293B"
                            Foreground="White"
                            BorderBrush="#334155"
                            Click="SelectAll_Click"/>

                    <Button Content="Select none"
                            Width="92"
                            Height="28"
                            Background="#1E293B"
                            Foreground="White"
                            BorderBrush="#334155"
                            Click="SelectNone_Click"/>
                </StackPanel>

                <ListView Grid.Row="3"
                          Margin="0,0,0,10"
                          ItemsSource="{Binding UnsignedDays}"
                          SelectionMode="Extended"
                          Background="#0F172A"
                          Foreground="White"
                          BorderBrush="#334155">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding DateText}"
                                           Foreground="White"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Grid.Row="4"
                        Content="Sign selected days"
                        Height="34"
                        Background="#14532D"
                        Foreground="White"
                        BorderBrush="#22C55E"
                        Click="SignSelectedDays_Click"
                        IsEnabled="{Binding CanSignSelectedDays}"/>
            </Grid>
        </Border>
    </Grid>
</Window>