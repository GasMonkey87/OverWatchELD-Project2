<Window x:Class="OverWatchELD.Views.Management.DriverSubmissionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Driver Submissions"
        Width="1100"
        Height="720"
        Background="#0F1012"
        Foreground="White"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Driver Submissions" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Text="Submit BOLs, fuel, tolls, reports, and other driver items. Optional Discord webhook posting is included."
                       Foreground="#C5C9D3"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#17191D" CornerRadius="12" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.0*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.7*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Foreground="#D6DAE3" Margin="0,0,0,5" Text="Submission Type"/>
                    <ComboBox x:Name="SubmissionTypeComboBox" Height="38" SelectedIndex="0">
                        <ComboBoxItem Content="BOL"/>
                        <ComboBoxItem Content="Fuel"/>
                        <ComboBoxItem Content="Tolls"/>
                        <ComboBoxItem Content="Expense"/>
                        <ComboBoxItem Content="Report"/>
                        <ComboBoxItem Content="Vehicle Info"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Foreground="#D6DAE3" Margin="0,0,0,5" Text="Title"/>
                    <TextBox x:Name="TitleTextBox" Height="38"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Foreground="#D6DAE3" Margin="0,0,0,5" Text="Amount"/>
                    <TextBox x:Name="AmountTextBox" Height="38"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                    <TextBlock Foreground="#D6DAE3" Margin="0,0,0,5" Text="Truck"/>
                    <TextBox x:Name="TruckTextBox" Height="38"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,8,0">
                    <TextBlock Foreground="#D6DAE3" Margin="0,0,0,5" Text="Details"/>
                    <TextBox x:Name="DetailsTextBox" Height="38"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Margin="0,0,8,0" VerticalAlignment="Bottom">
                    <CheckBox x:Name="SendWebhookCheckBox" Content="Send to Discord webhook" IsChecked="True"/>
                </StackPanel>

                <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                    <Button x:Name="SubmitButton" Content="Submit" Padding="14,8" Click="SubmitButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  x:Name="SubmissionsGrid"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  Background="#14171C"
                  Foreground="White"
                  BorderBrush="#2E333C"
                  RowBackground="#14171C"
                  AlternatingRowBackground="#1A1E25"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date UTC" Binding="{Binding DateUtc}" Width="1.2*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding SubmissionType}" Width="1*"/>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="1.4*"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="0.8*"/>
                <DataGridTextColumn Header="Truck" Binding="{Binding TruckName}" Width="1.0*"/>
                <DataGridTextColumn Header="User" Binding="{Binding DiscordUsername}" Width="1.1*"/>
                <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="1.7*"/>
                <DataGridCheckBoxColumn Header="Approved" Binding="{Binding IsApproved}" Width="0.7*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
