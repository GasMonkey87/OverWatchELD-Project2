<Window x:Class="OverWatchELD.Views.MaintenanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fleet Maintenance Ledger"
        Width="1380"
        Height="820"
        Background="#0F1012"
        Foreground="White"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#15181D" CornerRadius="14" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Fleet Maintenance &amp; Billing Ledger"
                           FontSize="24"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="StatusText"
                           Text="Track truck billing, maintenance, and alerts."
                           Margin="0,4,0,0"
                           Foreground="#C7D0DB"/>
            </StackPanel>
        </Border>

        <!-- Filters + Entry -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Filter panel -->
            <Border Grid.Column="0" Background="#15181D" CornerRadius="14" Padding="14" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Search / Filter"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Search"
                                       Foreground="#C7D0DB"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="SearchTextBox"
                                     Height="36"
                                     Background="#232833"
                                     Foreground="White"
                                     BorderBrush="#394250"
                                     VerticalContentAlignment="Center"
                                     TextChanged="SearchTextBox_TextChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Bill Type"
                                       Foreground="#C7D0DB"
                                       Margin="0,0,0,4"/>
                            <ComboBox x:Name="BillTypeFilterComboBox"
                                      Height="36"
                                      Background="#232833"
                                      Foreground="White"
                                      BorderBrush="#394250"
                                      SelectionChanged="BillTypeFilterComboBox_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <TextBlock Text="Truck"
                                       Foreground="#C7D0DB"
                                       Margin="0,0,0,4"/>
                            <ComboBox x:Name="TruckFilterComboBox"
                                      Height="36"
                                      Background="#232833"
                                      Foreground="White"
                                      BorderBrush="#394250"
                                      SelectionChanged="TruckFilterComboBox_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,20,10,0" VerticalAlignment="Bottom">
                            <CheckBox x:Name="AlertsOnlyCheckBox"
                                      Content="Alerts Only"
                                      Foreground="White"
                                      Checked="AlertsOnlyCheckBox_Changed"
                                      Unchecked="AlertsOnlyCheckBox_Changed"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="0,20,0,0" VerticalAlignment="Bottom" Orientation="Horizontal">
                            <Button x:Name="RefreshButton"
                                    Content="Refresh"
                                    Padding="14,8"
                                    Margin="0,0,8,0"
                                    Click="RefreshButton_Click"/>
                            <Button x:Name="ClearFiltersButton"
                                    Content="Clear"
                                    Padding="14,8"
                                    Click="ClearFiltersButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Entry panel -->
            <Border Grid.Column="1" Background="#15181D" CornerRadius="14" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Add / Edit Entry"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="1.0*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Truck" Foreground="#C7D0DB" Margin="0,0,0,4"/>
                                <ComboBox x:Name="TruckComboBox"
                                          Height="36"
                                          Background="#232833"
                                          Foreground="White"
                                          BorderBrush="#394250"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Bill Type" Foreground="#C7D0DB" Margin="0,0,0,4"/>
                                <ComboBox x:Name="BillTypeComboBox"
                                          Height="36"
                                          Background="#232833"
                                          Foreground="White"
                                          BorderBrush="#394250"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.0*"/>
                                <ColumnDefinition Width="1.0*"/>
                                <ColumnDefinition Width="1.0*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Amount" Foreground="#C7D0DB" Margin="0,0,0,4"/>
                                <TextBox x:Name="AmountTextBox"
                                         Height="36"
                                         Background="#232833"
                                         Foreground="White"
                                         BorderBrush="#394250"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Odometer" Foreground="#C7D0DB" Margin="0,0,0,4"/>
                                <TextBox x:Name="OdometerTextBox"
                                         Height="36"
                                         Background="#232833"
                                         Foreground="White"
                                         BorderBrush="#394250"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Date" Foreground="#C7D0DB" Margin="0,0,0,4"/>
                                <DatePicker x:Name="EntryDatePicker"
                                            Height="36"
                                            Background="#232833"
                                            Foreground="White"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.0*"/>
                                <ColumnDefinition Width="1.0*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Vendor" Foreground="#C7D0DB" Margin="0,0,0,4"/>
                                <TextBox x:Name="VendorTextBox"
                                         Height="36"
                                         Background="#232833"
                                         Foreground="White"
                                         BorderBrush="#394250"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Location" Foreground="#C7D0DB" Margin="0,0,0,4"/>
                                <TextBox x:Name="LocationTextBox"
                                         Height="36"
                                         Background="#232833"
                                         Foreground="White"
                                         BorderBrush="#394250"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.0*"/>
                                <ColumnDefinition Width="1.0*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Due At Miles" Foreground="#C7D0DB" Margin="0,0,0,4"/>
                                <TextBox x:Name="DueMilesTextBox"
                                         Height="36"
                                         Background="#232833"
                                         Foreground="White"
                                         BorderBrush="#394250"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Due Date" Foreground="#C7D0DB" Margin="0,0,0,4"/>
                                <DatePicker x:Name="DueDatePicker"
                                            Height="36"
                                            Background="#232833"
                                            Foreground="White"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="4" Margin="0,0,0,8">
                            <TextBlock Text="Notes" Foreground="#C7D0DB" Margin="0,0,0,4"/>
                            <TextBox x:Name="NotesTextBox"
                                     Height="72"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#232833"
                                     Foreground="White"
                                     BorderBrush="#394250"/>
                        </StackPanel>

                        <Grid Grid.Row="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox x:Name="RequiresFollowUpCheckBox"
                                      Content="Requires Follow-up"
                                      VerticalAlignment="Center"
                                      Foreground="White"
                                      Margin="0,0,10,0"/>

                            <CheckBox x:Name="ResolvedCheckBox"
                                      Grid.Column="1"
                                      Content="Resolved"
                                      VerticalAlignment="Center"
                                      Foreground="White"
                                      Margin="0,0,10,0"/>

                            <Button x:Name="AddEntryButton"
                                    Grid.Column="3"
                                    Content="Add Entry"
                                    Padding="14,8"
                                    Margin="0,0,8,0"
                                    Click="AddEntryButton_Click"/>

                            <Button x:Name="SaveEditButton"
                                    Grid.Column="4"
                                    Content="Save Edit"
                                    Padding="14,8"
                                    Margin="0,0,8,0"
                                    Click="SaveEditButton_Click"/>

                            <Button x:Name="DeleteEntryButton"
                                    Grid.Column="5"
                                    Content="Delete"
                                    Padding="14,8"
                                    Click="DeleteEntryButton_Click"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Ledger grid -->
        <Border Grid.Row="2" Background="#15181D" CornerRadius="14" Padding="10">
            <DataGrid x:Name="LedgerGrid"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      Background="#11151B"
                      Foreground="White"
                      BorderThickness="0"
                      RowBackground="#11151B"
                      AlternatingRowBackground="#171C24"
                      HorizontalGridLinesBrush="#2A3442"
                      VerticalGridLinesBrush="#2A3442"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      SelectionChanged="LedgerGrid_SelectionChanged">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#202734"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="#334052"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>

                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="8,6"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding DateLocalText}" Width="1.0*"/>
                    <DataGridTextColumn Header="Truck" Binding="{Binding TruckDisplay}" Width="1.5*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding BillType}" Width="1.0*"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding AmountText}" Width="0.9*"/>
                    <DataGridTextColumn Header="Odometer" Binding="{Binding OdometerText}" Width="0.9*"/>
                    <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor}" Width="1.1*"/>
                    <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="1.1*"/>
                    <DataGridTextColumn Header="Due Miles" Binding="{Binding DueMilesText}" Width="0.9*"/>
                    <DataGridTextColumn Header="Due Date" Binding="{Binding DueDateLocalText}" Width="0.9*"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="0.9*"/>
                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2.0*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>