<Window x:Class="OverWatchELD.Views.ExpenseReceiptsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Driver Receipts"
        Width="1180"
        Height="760"
        MinWidth="1000"
        MinHeight="650"
        WindowStartupLocation="CenterOwner"
        Background="#07111F">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#163B65"/>
            <Setter Property="BorderBrush" Value="#3B79B9"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="Background" Value="#132238"/>
            <Setter Property="BorderBrush" Value="#385476"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="RowBackground" Value="#0B1220"/>
            <Setter Property="AlternatingRowBackground" Value="#111827"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#334155"/>
            <Setter Property="VerticalGridLinesBrush" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#182235"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0D1A2B"
                BorderBrush="#263E5C"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Driver Receipts"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="Fuel stops, toll deductions, and tickets detected from ATS telemetry."
                               Foreground="#9FB3CC"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding Filters}"
                              SelectedItem="{Binding SelectedFilter}"
                              Width="130"
                              Margin="0,6,6,6"/>
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"/>
                    <Button Content="Clear"
                            Command="{Binding ClearCommand}"
                            Background="#991B1B"
                            BorderBrush="#DC2626"/>
                    <Button Content="Close"
                            Click="Close_Click"
                            Background="#2A3444"
                            BorderBrush="#4E6077"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#0D1A2B"
                BorderBrush="#263E5C"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14">

            <DataGrid ItemsSource="{Binding Receipts}"
                      SelectedItem="{Binding SelectedReceipt}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Receipt #" Binding="{Binding ReceiptNumber}" Width="170"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding EventType}" Width="90"/>
                    <DataGridTextColumn Header="Driver" Binding="{Binding DriverName}" Width="150"/>
                    <DataGridTextColumn Header="Truck" Binding="{Binding TruckName}" Width="160"/>
                    <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="180"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding AmountDisplay}" Width="100"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding CreatedLocalDisplay}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="4"
                Background="#0D1A2B"
                BorderBrush="#263E5C"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Viewable Receipt"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding SelectedReceipt.ReceiptNumber}"
                               Foreground="#A7F3D0"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding SelectedReceipt.DriverTruckDisplay}"
                               Foreground="#EAF2FF"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding SelectedReceipt.Location}"
                               Foreground="#9FB3CC"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding SelectedReceipt.AmountDisplay}"
                               Foreground="#FDE68A"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,10,0,0"/>
                </StackPanel>

                <TextBox Grid.Column="2"
                         Text="{Binding SelectedReceipt.RawDetails}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="#07111F"
                         Foreground="#EAF2FF"
                         BorderBrush="#263E5C"
                         Padding="10"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="5"
                   Text="{Binding StatusText}"
                   Foreground="#A7F3D0"
                   Margin="4,12,0,0"/>
    </Grid>
</Window>