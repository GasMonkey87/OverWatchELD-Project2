<UserControl x:Class="OverWatchELD.Views.Controls.HosGraphOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto"
             IsHitTestVisible="True">

    
    
    <!-- Transparent overlay that sits on top of your existing graph -->
    <Grid Background="Transparent">
        <!-- Hover line -->
        <Rectangle x:Name="HoverLine"
                   Width="1"
                   HorizontalAlignment="Left"
                   Fill="#BFFFFFFF"
                   Visibility="Collapsed"/>

        <!-- Hover bubble -->
        <Border x:Name="HoverBubble"
                Visibility="Collapsed"
                Background="#E0202632"
                BorderBrush="#BFFFFFFF"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10,6"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="0,10,0,0">
            <TextBlock x:Name="HoverText"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="00:00"/>
        </Border>
    </Grid>
</UserControl>
