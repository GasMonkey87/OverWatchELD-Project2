<Window x:Class="OverWatchELD.Views.ToastNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="420"
        Height="120"
        ShowActivated="False">

    <Border Background="#1A1A1A"
            BorderBrush="#2A2A2A"
            BorderThickness="1"
            CornerRadius="16"
            Padding="14">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="New Message"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding From}"
                           Foreground="White"
                           Opacity="0.85"
                           Margin="0,6,0,0"/>
                <TextBlock Text="{Binding Text}"
                           Foreground="White"
                           Opacity="0.85"
                           TextWrapping="Wrap"
                           MaxHeight="38"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="×"
                    Width="28"
                    Height="28"
                    Margin="10,0,0,0"
                    Background="#2A2A2A"
                    BorderBrush="#3A3A3A"
                    Foreground="White"
                    Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
