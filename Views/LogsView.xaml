<UserControl x:Class="OverWatchELD.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1100"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>

        <!-- ELD dark DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="RowBackground" Value="#0B1220"/>
            <Setter Property="AlternatingRowBackground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#334155"/>
            <Setter Property="VerticalGridLinesBrush" Value="#334155"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#182235"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="{DynamicResource PanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border x:Name="InnerTopBar"
                Grid.Row="0"
                Background="{DynamicResource TopBarBrush}"
                Padding="16,10">
            <DockPanel LastChildFill="True">

                <!-- Day nav -->
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <Button Content="◀"
                            Width="36"
                            Height="28"
                            Margin="0,0,8,0"
                            Click="PrevDay_Click"/>

                    <Button Content="▶"
                            Width="36"
                            Height="28"
                            Click="NextDay_Click"/>
                </StackPanel>

                <!-- Date / badges -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0"
                            DockPanel.Dock="Left">

                    <TextBlock Text="{Binding HeaderDateText}"
                               VerticalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMainBrush}"/>

                    <Border Margin="10,0,0,0"
                            Padding="8,2"
                            CornerRadius="6"
                            Background="#1E3A1E"
                            Visibility="{Binding IsSelectedDayCertified, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="CERTIFIED"
                                   Foreground="#4ADE80"
                                   FontSize="11"
                                   FontWeight="Bold"/>
                    </Border>

                    <Border Margin="10,0,0,0"
                            Padding="8,2"
                            CornerRadius="6"
                            Background="#3A1E1E">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelectedDayCertified}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <TextBlock Text="UNSIGNED"
                                   Foreground="#F87171"
                                   FontSize="11"
                                   FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <Button Content="{Binding UnsignedLogsButtonText}"
                            Height="28"
                            Padding="12,0"
                            Margin="0,0,8,0"
                            Click="UnsignedLogs_Click"/>

                    <Button Content="Review &amp; certify"
                            Height="28"
                            Padding="12,0"
                            Click="Certify_Click"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="300"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Graph card -->
            <Border Grid.Row="0"
                    CornerRadius="10"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="#22314A"
                    BorderThickness="1"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Driver log"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMainBrush}"/>

                    <!-- Graph area: left labels + canvas -->
                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status labels -->
                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Stretch"
                                    Margin="0,6,8,22">
                            <TextBlock Text="ON"  Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,8,0,0"/>
                            <TextBlock Text="D"   Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,44,0,0"/>
                            <TextBlock Text="SB"  Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,44,0,0"/>
                            <TextBlock Text="OFF" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,44,0,0"/>
                        </StackPanel>

                        <!-- Canvas background -->
                        <Border Grid.Column="1"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="#22314A"
                                BorderThickness="1"
                                CornerRadius="8"/>

                        <!-- Grid lines + segments -->
                        <Grid Grid.Column="1" Margin="8,6,8,22">
                            <Canvas>

                                <!-- Hour vertical grid lines -->
                                <ItemsControl ItemsSource="{Binding HourTicks}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas SnapsToDevicePixels="True"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                            <Setter Property="Canvas.Top" Value="0"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Rectangle Width="1"
                                                       Height="{Binding GridHeight}"
                                                       Fill="{DynamicResource GridLineBrush}"
                                                       Opacity="0.35"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Horizontal row lines -->
                                <Rectangle Canvas.Left="0" Canvas.Top="44" Width="{Binding GraphWidth}" Height="1"
                                           Fill="{DynamicResource GridLineBrush}" Opacity="0.35"/>
                                <Rectangle Canvas.Left="0" Canvas.Top="88" Width="{Binding GraphWidth}" Height="1"
                                           Fill="{DynamicResource GridLineBrush}" Opacity="0.35"/>
                                <Rectangle Canvas.Left="0" Canvas.Top="132" Width="{Binding GraphWidth}" Height="1"
                                           Fill="{DynamicResource GridLineBrush}" Opacity="0.35"/>

                                <!-- Segments -->
                                <ItemsControl ItemsSource="{Binding GraphSegments}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas SnapsToDevicePixels="True"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding Width}"
                                                    Height="{Binding Height}"
                                                    Background="{Binding Brush}"
                                                    SnapsToDevicePixels="True"
                                                    Margin="-0.5,0,-0.5,0"
                                                    CornerRadius="4"
                                                    Padding="6,0"
                                                    MouseLeftButtonDown="Segment_MouseLeftButtonDown">
                                                <TextBlock Text="{Binding Label}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextMainBrush}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Opacity="{Binding LabelOpacity}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Canvas>
                        </Grid>

                        <!-- debug source -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DebugSourceText}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Bottom"
                                   Margin="10,0,10,6"/>
                    </Grid>

                    <!-- Hour labels -->
                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding HourLabels}"
                                  Margin="64,0,8,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas SnapsToDevicePixels="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                <Setter Property="Canvas.Top" Value="0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Table card -->
            <Border Grid.Row="2"
                    CornerRadius="10"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="#22314A"
                    BorderThickness="1"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Duty events"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   DockPanel.Dock="Left"/>

                        <TextBlock Text="{Binding DutyEvents.Count, StringFormat={}{0} events}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>

                    <DataGrid x:Name="DutyGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding DutyEvents}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              MouseDoubleClick="DutyGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Start" Binding="{Binding StartLocal}" Width="80"/>
                            <DataGridTextColumn Header="End" Binding="{Binding EndLocal}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                            <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>