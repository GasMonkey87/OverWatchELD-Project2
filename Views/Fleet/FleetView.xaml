<UserControl x:Class="OverWatchELD.Views.Fleet.FleetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F1012"
             Foreground="White">

    <UserControl.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#17191D"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#1B1F26"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D6DAE3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B9C0CD"/>
            <Setter Property="Opacity" Value="0.95"/>
        </Style>

        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#23262D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#414755"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#23262D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#414755"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="38"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E5B87"/>
            <Setter Property="BorderBrush" Value="#4D83B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#242830"/>
            <Setter Property="BorderBrush" Value="#434A57"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="FleetDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#14171C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2E333C"/>
            <Setter Property="RowBackground" Value="#14171C"/>
            <Setter Property="AlternatingRowBackground" Value="#1A1E25"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#202632"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#313846"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2E333C"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="300"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="260"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="320"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="280"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#14171C" CornerRadius="16" Padding="18" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="VTC Fleet" FontSize="26" FontWeight="SemiBold"/>
                        <TextBlock x:Name="PageStatusText"
                                   Text="Fleet access, truck visibility, expenses, reports, and management controls."
                                   Margin="0,4,0,0"
                                   Foreground="#D3D8E2"/>
                        <TextBlock x:Name="RoleStatusText"
                                   Text="Role: Loading..."
                                   Margin="0,4,0,0"
                                   Foreground="#AEB7C7"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="OpenMapButton"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Open Live Map"
                                Click="OpenMapButton_Click"/>
                        <Button x:Name="RefreshAllButton"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0"
                                Content="Refresh"
                                Click="RefreshAllButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,14">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="MY ACCESS" Foreground="#95A1B6" FontSize="11"/>
                        <TextBlock x:Name="AccessSummaryText" Text="Driver" FontSize="20" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="MY TRUCK" Foreground="#95A1B6" FontSize="11"/>
                        <TextBlock x:Name="MyTruckSummaryText" Text="Unassigned" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="FLEET ASSETS" Foreground="#95A1B6" FontSize="11"/>
                        <TextBlock x:Name="FleetAssetCountText" Text="0" FontSize="20" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="OPEN SUBMISSIONS" Foreground="#95A1B6" FontSize="11"/>
                        <TextBlock x:Name="OpenSubmissionsCountText" Text="0" FontSize="20" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Fleet Page"/>
                    <TextBlock Style="{StaticResource MutedTextStyle}"
                               Text="This page is for all VTC users. Drivers can view fleet assets, submit BOLs, expenses, reports, vehicle information, and open the map."
                               Margin="0,4,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.0*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="0.8*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="2.0*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Submission Type"/>
                            <ComboBox x:Name="SubmissionTypeComboBox" Style="{StaticResource DarkComboBoxStyle}" SelectedIndex="0">
                                <ComboBoxItem Content="BOL"/>
                                <ComboBoxItem Content="Expense"/>
                                <ComboBoxItem Content="Report"/>
                                <ComboBoxItem Content="Vehicle Info"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Title"/>
                            <TextBox x:Name="SubmissionTitleTextBox" Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Amount"/>
                            <TextBox x:Name="SubmissionAmountTextBox" Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Truck / Plate / Unit"/>
                            <TextBox x:Name="SubmissionTruckTextBox" Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Details"/>
                            <TextBox x:Name="SubmissionDetailsTextBox" Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="5">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Action"/>
                            <Button x:Name="SubmitDriverItemButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0"
                                    Content="Submit"
                                    Click="SubmitDriverItemButton_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Background="#14171C" CornerRadius="14" Padding="8" Margin="0,0,0,16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Fleet Assets" FontSize="18" FontWeight="SemiBold" Margin="10,6,10,10"/>
                    <DataGrid x:Name="FleetGrid" Style="{StaticResource FleetDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Truck Name" Binding="{Binding TruckName}" Width="1.4*"/>
                            <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="1.4*"/>
                            <DataGridTextColumn Header="Plate" Binding="{Binding PlateNumber}" Width="1*"/>
                            <DataGridTextColumn Header="Discord User" Binding="{Binding DiscordUsername}" Width="1.3*"/>
                            <DataGridTextColumn Header="Driver" Binding="{Binding DriverName}" Width="1.2*"/>
                            <DataGridTextColumn Header="Odometer" Binding="{Binding OdometerMiles}" Width="1*"/>
                            <DataGridTextColumn Header="Last Seen UTC" Binding="{Binding LastSeenUtc}" Width="1.4*"/>
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="0.8*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Grid Grid.Row="4" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="My Assigned Truck"/>
                        <TextBlock x:Name="MyTruckDetailsText"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="No truck assigned yet."
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionBorderStyle}" Grid.Column="1">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Management Access"/>
                        <TextBlock x:Name="ManagementAccessText"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="Management tools are limited to Owner and Manager roles."
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="5" Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="220"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Driver Submissions" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SubmissionStatusText"
                                       Text="Submitted BOLs, expenses, reports, and vehicle info."
                                       Foreground="#C5C9D3"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <Button x:Name="ApproveSubmissionButton"
                                Grid.Column="1"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Approve Selected"
                                Click="ApproveSubmissionButton_Click"/>

                        <Button x:Name="DeleteSubmissionButton"
                                Grid.Column="2"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0"
                                Content="Delete Selected"
                                Click="DeleteSubmissionButton_Click"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              x:Name="SubmissionsGrid"
                              Style="{StaticResource FleetDataGridStyle}"
                              Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date UTC" Binding="{Binding DateUtc}" Width="1.3*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding SubmissionType}" Width="1*"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="1.4*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="0.8*"/>
                            <DataGridTextColumn Header="Truck" Binding="{Binding TruckName}" Width="1*"/>
                            <DataGridTextColumn Header="User" Binding="{Binding DiscordUsername}" Width="1.1*"/>
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="1.8*"/>
                            <DataGridCheckBoxColumn Header="Approved" Binding="{Binding IsApproved}" Width="0.8*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border x:Name="ManagementHeaderBorder" Grid.Row="6" Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Management Console"/>
                        <TextBlock x:Name="ManagementConsoleText"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="Only Owner and Manager roles can use this area."
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button x:Name="ManagementLoginButton"
                            Grid.Column="1"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0"
                            Content="Management Refresh"
                            Click="ManagementLoginButton_Click"/>
                </Grid>
            </Border>

            <Border x:Name="AdminFleetBorder" Grid.Row="7" Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Fleet Management"/>
                    <TextBlock Style="{StaticResource MutedTextStyle}"
                               Text="Create, capture, and manage company fleet assets."
                               Margin="0,4,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.8*"/>
                            <ColumnDefinition Width="1.8*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1.6*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Truck Name"/>
                            <TextBox x:Name="TruckNameTextBox" Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Model"/>
                            <TextBox x:Name="ModelTextBox" Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Plate Number"/>
                            <TextBox x:Name="PlateTextBox" Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Linked Discord User"/>
                            <TextBox x:Name="DriverTextBox" Style="{StaticResource DarkTextBoxStyle}" IsReadOnly="True"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Action"/>
                            <Button x:Name="AddTelemetryButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Add Current Truck"
                                    Click="AddTelemetryButton_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Column="5" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Action"/>
                            <Button x:Name="AddManualButton"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Add Manual"
                                    Click="AddManualButton_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Action"/>
                            <Button x:Name="DeleteFleetButton"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0"
                                    Content="Delete Selected"
                                    Click="DeleteFleetButton_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel x:Name="AdminFinanceBorder" Grid.Row="8" Margin="0,0,0,12">
                <TextBlock Text="Company Finance" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock x:Name="FinanceStatusText"
                           Text="Track company-wide finances."
                           Foreground="#C5C9D3"
                           Margin="0,4,0,10"/>

                <UniformGrid Columns="6" Margin="0,0,0,12">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="Balance" Foreground="#95A1B6" FontSize="11"/><TextBlock x:Name="BalanceText" FontSize="20" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="Income" Foreground="#95A1B6" FontSize="11"/><TextBlock x:Name="IncomeText" FontSize="20" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="Expenses" Foreground="#95A1B6" FontSize="11"/><TextBlock x:Name="ExpenseText" FontSize="20" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="Fuel" Foreground="#95A1B6" FontSize="11"/><TextBlock x:Name="FuelText" FontSize="20" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="Maintenance" Foreground="#95A1B6" FontSize="11"/><TextBlock x:Name="MaintenanceText" FontSize="20" FontWeight="SemiBold"/></StackPanel></Border>
                    <Border Style="{StaticResource CardBorderStyle}"><StackPanel><TextBlock Text="Repairs" Foreground="#95A1B6" FontSize="11"/><TextBlock x:Name="RepairsText" FontSize="20" FontWeight="SemiBold"/></StackPanel></Border>
                </UniformGrid>

                <Border Style="{StaticResource SectionBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.0*"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="0.8*"/>
                            <ColumnDefinition Width="1.0*"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="1.8*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Entry Type"/>
                            <ComboBox x:Name="EntryTypeComboBox" Style="{StaticResource DarkComboBoxStyle}" SelectedIndex="0">
                                <ComboBoxItem Content="Expense"/>
                                <ComboBoxItem Content="Income"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Category"/>
                            <ComboBox x:Name="CategoryComboBox" Style="{StaticResource DarkComboBoxStyle}" SelectedIndex="0">
                                <ComboBoxItem Content="Fuel"/>
                                <ComboBoxItem Content="Maintenance"/>
                                <ComboBoxItem Content="Repairs"/>
                                <ComboBoxItem Content="Tolls"/>
                                <ComboBoxItem Content="Fines"/>
                                <ComboBoxItem Content="Truck Purchase"/>
                                <ComboBoxItem Content="Trailer Purchase"/>
                                <ComboBoxItem Content="Payroll"/>
                                <ComboBoxItem Content="Delivery Revenue"/>
                                <ComboBoxItem Content="Misc"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Amount"/>
                            <TextBox x:Name="AmountTextBox" Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Truck"/>
                            <TextBox x:Name="FinanceTruckTextBox" Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Linked Discord User"/>
                            <TextBox x:Name="FinanceUserTextBox" Style="{StaticResource DarkTextBoxStyle}" IsReadOnly="True"/>
                        </StackPanel>

                        <StackPanel Grid.Column="5" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Description"/>
                            <TextBox x:Name="DescriptionTextBox" Style="{StaticResource DarkTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6" Margin="0,0,8,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Action"/>
                            <Button x:Name="AddFinanceEntryButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Add Entry"
                                    Click="AddFinanceEntryButton_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Column="7">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Action"/>
                            <Button x:Name="DeleteFinanceEntryButton"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0"
                                    Content="Delete Selected"
                                    Click="DeleteFinanceEntryButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <Border x:Name="AdminFinanceGridBorder" Grid.Row="9" Background="#14171C" CornerRadius="14" Padding="8">
                <DataGrid x:Name="FinanceGrid" Style="{StaticResource FleetDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date UTC" Binding="{Binding DateUtc}" Width="1.3*"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding EntryType}" Width="0.8*"/>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1*"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="0.9*"/>
                        <DataGridTextColumn Header="Truck" Binding="{Binding TruckName}" Width="1*"/>
                        <DataGridTextColumn Header="User" Binding="{Binding DiscordUsername}" Width="1.1*"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="1.8*"/>
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="0.8*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
