<Window x:Class="OverWatchELD.Views.NewDispatchMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Message"
        Height="420"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#07101F">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Start New Conversation"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="SemiBold"/>

        <TextBlock Grid.Row="2"
                   Text="Select Driver"
                   Foreground="#CBD5E1"/>

        <ComboBox Grid.Row="4"
                  x:Name="DriverCombo"
                  Height="36"
                  Padding="8,4"
                  Background="#0B1220"
                  Foreground="White"
                  BorderBrush="#26364F"
                  DisplayMemberPath="DisplayText"
                  SelectionChanged="DriverCombo_SelectionChanged"/>

        <Border Grid.Row="6"
                Background="#0B1424"
                BorderBrush="#26364F"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <StackPanel>
                <TextBlock x:Name="SelectedDriverText"
                           Text="Driver: --"
                           Foreground="White"/>
                <TextBlock x:Name="SelectedDiscordText"
                           Text="Discord ID: --"
                           Foreground="#9FB4D0"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <TextBox Grid.Row="8"
                 x:Name="MessageInput"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Padding="10"
                 Background="#0B1220"
                 Foreground="White"
                 BorderBrush="#26364F"/>

        <DockPanel Grid.Row="10">
            <TextBlock x:Name="AttachmentText"
                       Text="No attachment selected"
                       Foreground="#9FB4D0"
                       VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                <Button Content="Attach File"
                        Width="100"
                        Height="32"
                        Margin="8,0,0,0"
                        Click="Attach_Click"/>
                <Button Content="Clear"
                        Width="70"
                        Height="32"
                        Margin="8,0,0,0"
                        Click="ClearAttachment_Click"/>
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="12"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="90"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Send"
                    Width="90"
                    Height="34"
                    Click="Send_Click"/>
        </StackPanel>
    </Grid>
</Window>