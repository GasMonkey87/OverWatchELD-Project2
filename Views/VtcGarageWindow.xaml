<Window x:Class="OverWatchELD.Views.VtcGarageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VTC Garage"
        Width="1120"
        Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#0B1220">

    <Window.Resources>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

    </Window.Resources>

    <Grid Margin="18">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <DockPanel Margin="0,0,0,14">

            <TextBlock Text="VTC Garage Management"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Right">

                <Button Content="Sync to VTC Map"
                        Width="150"
                        Height="40"
                        Margin="0,0,8,0"
                        Command="{Binding SyncToMapCommand}"/>

                <Button Content="Save Garages"
                        Width="140"
                        Height="40"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>

        </DockPanel>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.15*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <Border Background="#111827"
                    CornerRadius="16"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    Padding="10">

                <DataGrid ItemsSource="{Binding Garages}"
          SelectedItem="{Binding SelectedGarage}"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="False"
          Background="#111827"
          Foreground="White"
          RowBackground="#111827"
          AlternatingRowBackground="#0F172A"
          GridLinesVisibility="None"
          HeadersVisibility="Column"
          BorderThickness="0"
          ColumnHeaderHeight="42">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="City"
                    Binding="{Binding CityName, Mode=OneWay}"
                    IsReadOnly="True"
                    Width="*"/>

                        <DataGridTextColumn Header="State"
                    Binding="{Binding State, Mode=OneWay}"
                    IsReadOnly="True"
                    Width="80"/>

                        <DataGridTextColumn Header="Size"
                    Binding="{Binding Size, Mode=OneWay}"
                    IsReadOnly="True"
                    Width="110"/>

                        <DataGridTextColumn Header="Slots"
                    Binding="{Binding SlotDisplay, Mode=OneWay}"
                    IsReadOnly="True"
                    Width="100"/>

                        <DataGridCheckBoxColumn Header="Owned"
                                                Binding="{Binding IsOwned, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="90"/>
                    
                    </DataGrid.Columns>

                </DataGrid>

            </Border>

            <!-- RIGHT -->
            <Border Grid.Column="1"
                    Margin="14,0,0,0"
                    Background="#111827"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel>

                        <TextBlock Text="{Binding SelectedGarage.CityName}"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding SelectedGarage.State}"
                                   Foreground="#94A3B8"
                                   FontSize="14"
                                   Margin="0,2,0,14"/>
                        <Button Content="Add Garage"
        Width="120"
        Height="40"
        Margin="0,0,8,0"
        Click="OpenAddGarage_Click"/>
                        <!-- ECONOMY -->
                        <TextBlock Text="{Binding SelectedGarage.EconomyDisplay}"
                                   Foreground="#CBD5E1"
                                   FontSize="14"
                                   Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,14">

                            <Button Content="Purchase"
                                    Width="92"
                                    Command="{Binding PurchaseGarageCommand}"/>

                            <Button Content="Sell"
                                    Width="70"
                                    Margin="8,0,0,0"
                                    Command="{Binding SellGarageCommand}"/>

                            <Button Content="Upgrade"
                                    Width="86"
                                    Margin="8,0,0,0"
                                    Command="{Binding UpgradeGarageCommand}"/>

                        </StackPanel>

                        <Button Content="Add Fuel Station"
                                Height="36"
                                Margin="0,0,0,16"
                                Command="{Binding AddFuelStationCommand}"/>

                        <!-- SIZE -->
                        <TextBlock Text="Garage Size"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,8,0,14">

                            <Button Content="Small 3"
                                    Width="86"
                                    Height="34"
                                    Command="{Binding SetSmallCommand}"/>

                            <Button Content="Medium 5"
                                    Width="96"
                                    Height="34"
                                    Margin="8,0,0,0"
                                    Command="{Binding SetMediumCommand}"/>

                            <Button Content="Large 7"
                                    Width="86"
                                    Height="34"
                                    Margin="8,0,0,0"
                                    Command="{Binding SetLargeCommand}"/>

                        </StackPanel>

                        <!-- STATS -->
                        <TextBlock Text="{Binding SelectedGarage.SlotDisplay, StringFormat=Slots Used: {0}}"
                                   Foreground="#CBD5E1"
                                   FontSize="14"/>

                        <TextBlock Text="{Binding SelectedGarage.RepairBays, StringFormat=Repair Bays: {0}}"
                                   Foreground="#94A3B8"
                                   Margin="0,6,0,0"/>

                        <TextBlock Text="{Binding SelectedGarage.HasFuelStation, StringFormat=Fuel Station: {0}}"
                                   Foreground="#94A3B8"
                                   Margin="0,4,0,0"/>

                        <TextBlock Text="{Binding SelectedGarage.GarageIncomeBonusPercent, StringFormat=Income Bonus: +{0}%}"
                                   Foreground="#94A3B8"
                                   Margin="0,4,0,16"/>

                        <!-- TRUCK ASSIGN -->
                        <TextBlock Text="Assign Truck Number"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,8,0,12">

                            <ComboBox ItemsSource="{Binding AvailableFleetTrucks}"
          SelectedItem="{Binding SelectedFleetTruck}"
          Width="160"
          Height="36"
          Background="#0B1220"
          Foreground="White"
          BorderBrush="#334155"
          Padding="6">

                                <ComboBox.Resources>

                                    <!-- dropdown background -->
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                         Color="#0B1220"/>

                                    <!-- selected item -->
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                         Color="#2563EB"/>

                                    <!-- control background -->
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                         Color="#111827"/>

                                    <!-- dropdown text -->
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}"
                         Color="White"/>

                                </ComboBox.Resources>

                            </ComboBox>

                            <Button Content="Add"
                                    Width="70"
                                    Height="36"
                                    Margin="8,0,0,0"
                                    Command="{Binding AddTruckCommand}"/>

                        </StackPanel>

                        <!-- ASSIGNED -->
                        <TextBlock Text="Assigned Trucks"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <ListBox ItemsSource="{Binding SelectedGarage.AssignedTruckNumbers}"
                                 Height="230"
                                 Margin="0,8,0,12"
                                 Background="#0B1220"
                                 Foreground="White"
                                 BorderBrush="#334155"/>

                        <Button Content="Remove Selected Truck"
                                Height="38"
                                Command="{Binding RemoveTruckCommand}"
                                CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>

                        <!-- NOTE -->
                        <Border Margin="0,20,0,0"
                                Padding="10"
                                CornerRadius="10"
                                Background="#0F172A">

                            <TextBlock Text="Owned garage icons will appear brighter and bolder on the live map."
                                       TextWrapping="Wrap"
                                       Foreground="#94A3B8"/>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

            </Border>

        </Grid>

    </Grid>

</Window>