<Window x:Class="OverWatchELD.Views.FleetTruckEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fleet Truck"
        Height="560"
        Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#111111"
        ResizeMode="NoResize">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#1E1E1E" CornerRadius="10" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Truck Number" Foreground="White"/>
                <TextBox Grid.Row="2" x:Name="TruckNumberBox"/>

                <TextBlock Grid.Row="4" Text="Assigned Driver" Foreground="White"/>
                <ComboBox Grid.Row="6" x:Name="AssignedDriverBox" IsEditable="False"/>

                <TextBlock Grid.Row="8" Text="Driver Discord ID" Foreground="White"/>
                <TextBox Grid.Row="10" x:Name="DriverDiscordIdBox"/>

                <TextBlock Grid.Row="12" Text="Status" Foreground="White"/>
                <ComboBox Grid.Row="14" x:Name="StatusBox" SelectedIndex="0">
                    <ComboBoxItem Content="Active"/>
                    <ComboBoxItem Content="Unassigned"/>
                    <ComboBoxItem Content="Needs Service"/>
                    <ComboBoxItem Content="Needs Inspection"/>
                    <ComboBoxItem Content="Out of Service"/>
                </ComboBox>

                <Grid Grid.Row="16" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Location" Foreground="White"/>
                        <TextBox x:Name="LocationBox" Margin="0,6,0,0"/>

                        <TextBlock Text="Health %" Foreground="White" Margin="0,12,0,0"/>
                        <TextBox x:Name="HealthBox" Margin="0,6,0,0"/>

                        <TextBlock Text="Service Due (MM/dd/yyyy)" Foreground="White" Margin="0,12,0,0"/>
                        <TextBox x:Name="ServiceDueBox" Margin="0,6,0,0"/>

                        <TextBlock Text="Inspection Due (MM/dd/yyyy)" Foreground="White" Margin="0,12,0,0"/>
                        <TextBox x:Name="InspectionDueBox" Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Last Service (MM/dd/yyyy)" Foreground="White"/>
                        <TextBox x:Name="LastServiceBox" Margin="0,6,0,0"/>

                        <TextBlock Text="Last Inspection (MM/dd/yyyy)" Foreground="White" Margin="0,12,0,0"/>
                        <TextBox x:Name="LastInspectionBox" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="110" Height="34" Margin="0,0,10,0" Click="Save_Click"/>
            <Button Content="Cancel" Width="110" Height="34" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>