<Window x:Class="OverWatchELD.Views.DailyLogsExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OverWatchELD.Views"
        Title="Select Logs to Export"
        Width="980" Height="720"
        MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#FF0B1220">

    <Border Margin="14"
            Background="#FF111827"
            BorderBrush="#22314A"
            BorderThickness="1"
            CornerRadius="14"
            Padding="0">
        <local:DailyLogsExportView/>
    </Border>
</Window>
