<Window x:Class="OverWatchELD.Views.CompanyLoadBoardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Company Loads"
        Width="1180"
        Height="760"
        MinWidth="1040"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#07111F">

    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#EAF2FF"/><Setter Property="FontSize" Value="14"/></Style>
        <Style TargetType="TextBox"><Setter Property="Height" Value="34"/><Setter Property="Margin" Value="0,4,0,10"/><Setter Property="Foreground" Value="#EAF2FF"/><Setter Property="Background" Value="#132238"/><Setter Property="BorderBrush" Value="#385476"/><Setter Property="Padding" Value="8,6"/></Style>
        <Style TargetType="ComboBox"><Setter Property="Height" Value="34"/><Setter Property="Margin" Value="0,4,0,10"/><Setter Property="Foreground" Value="#EAF2FF"/><Setter Property="Background" Value="#132238"/><Setter Property="BorderBrush" Value="#385476"/><Setter Property="Padding" Value="8,4"/><Setter Property="IsTextSearchEnabled" Value="True"/></Style>
        <Style TargetType="Button"><Setter Property="Height" Value="36"/><Setter Property="MinWidth" Value="120"/><Setter Property="Margin" Value="6"/><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#163B65"/><Setter Property="BorderBrush" Value="#3B79B9"/><Setter Property="Padding" Value="12,4"/><Setter Property="Cursor" Value="Hand"/></Style>
        <Style TargetType="DataGrid"><Setter Property="Background" Value="#0B1220"/><Setter Property="Foreground" Value="#E5E7EB"/><Setter Property="RowBackground" Value="#0B1220"/><Setter Property="AlternatingRowBackground" Value="#111827"/><Setter Property="GridLinesVisibility" Value="Horizontal"/><Setter Property="HorizontalGridLinesBrush" Value="#334155"/><Setter Property="VerticalGridLinesBrush" Value="#334155"/><Setter Property="BorderBrush" Value="#334155"/><Setter Property="BorderThickness" Value="1"/></Style>
        <Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#182235"/><Setter Property="Foreground" Value="#E5E7EB"/><Setter Property="BorderBrush" Value="#334155"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="8,6"/></Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="12"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0D1A2B" BorderBrush="#263E5C" BorderThickness="1" CornerRadius="10" Padding="16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left"><TextBlock Text="Company Loads" FontSize="24" FontWeight="Bold"/><TextBlock Text="Owners/admins can create company loads and assign them to other drivers." Foreground="#9FB3CC" Margin="0,4,0,0"/></StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Refresh" Command="{Binding RefreshCommand}"/><Button Content="Close" Click="Close_Click" Background="#2A3444" BorderBrush="#4E6077"/></StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="420"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#0D1A2B" BorderBrush="#263E5C" BorderThickness="1" CornerRadius="10" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel>
                    <TextBlock Text="Create Company Load" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="Load Number"/><TextBox Text="{Binding LoadNumber, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Pickup Company"/><ComboBox ItemsSource="{Binding PickupCompanies}" SelectedItem="{Binding SelectedPickupCompany}" DisplayMemberPath="DisplayName"/>
                    <TextBlock Text="Drop-off Company"/><ComboBox ItemsSource="{Binding DropOffCompanies}" SelectedItem="{Binding SelectedDropOffCompany}" DisplayMemberPath="DisplayName"/>
                    <TextBlock Text="Cargo"/><ComboBox ItemsSource="{Binding CargoOptions}" SelectedItem="{Binding SelectedCargo}"/>
                    <TextBlock Text="Trailer"/><ComboBox ItemsSource="{Binding TrailerOptions}" SelectedItem="{Binding SelectedTrailer}"/>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0"><TextBlock Text="Weight LBS"/><TextBox Text="{Binding WeightLbs, UpdateSourceTrigger=PropertyChanged}"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Miles"/><TextBox Text="{Binding Miles, UpdateSourceTrigger=PropertyChanged}"/></StackPanel></Grid>
                    <TextBlock Text="Assign Driver"/><ComboBox ItemsSource="{Binding DriverOptions}" SelectedItem="{Binding AssignedDriver}"/>
                    <TextBlock Text="Assign Truck"/><ComboBox ItemsSource="{Binding TruckOptions}" SelectedItem="{Binding AssignedTruck}"/>
                    <TextBlock Text="Notes"/><TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Height="78" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    <Button Content="Create Company Load" Command="{Binding CreateCompanyLoadCommand}" Background="#1F7A4D" BorderBrush="#35B474" HorizontalAlignment="Right"/>
                </StackPanel></ScrollViewer>
            </Border>
            <Border Grid.Column="2" Background="#0D1A2B" BorderBrush="#263E5C" BorderThickness="1" CornerRadius="10" Padding="14">
                <Grid><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <DataGrid Grid.Row="0" ItemsSource="{Binding CompanyLoads}" SelectedItem="{Binding SelectedLoad}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column" RowHeaderWidth="0">
                        <DataGrid.Columns><DataGridTextColumn Header="Load #" Binding="{Binding LoadNumber}" Width="120"/><DataGridTextColumn Header="Route" Binding="{Binding RouteDisplay}" Width="*"/><DataGridTextColumn Header="Load" Binding="{Binding LoadDisplay}" Width="240"/><DataGridTextColumn Header="Driver" Binding="{Binding AssignedDriver}" Width="150"/><DataGridTextColumn Header="Truck" Binding="{Binding AssignedTruck}" Width="100"/><DataGridTextColumn Header="Miles" Binding="{Binding Miles}" Width="80"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/></DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0"><Button Content="Dispatch Selected" Command="{Binding DispatchSelectedCommand}" Background="#245B8F" BorderBrush="#4A91D0"/><Button Content="Delete Selected" Command="{Binding DeleteSelectedCommand}" Background="#991B1B" BorderBrush="#DC2626"/></StackPanel>
                </Grid>
            </Border>
        </Grid>
        <TextBlock Grid.Row="3" Text="{Binding StatusText}" Foreground="#A7F3D0" Margin="4,12,0,0"/>
    </Grid>
</Window>
