<Window x:Class="OverWatchELD.Views.InspectionEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DOT Inspection"
        Width="640" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#111111">
    <Window.Resources>
        <!-- Group checklist items by Category and render as collapsible sections -->
        <Style x:Key="ChecklistGroupItemStyle" TargetType="{x:Type GroupItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupItem}">
                        <Expander IsExpanded="True"
                                  Margin="0,0,0,10"
                                  Background="#141414"
                                  BorderBrush="#2A2A2A"
                                  BorderThickness="1">
                            <Expander.Header>
                                <DockPanel Margin="10,8">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                </DockPanel>
                            </Expander.Header>
                            <ItemsPresenter />
                        </Expander>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="DOT Inspection"
                   Foreground="#00FF80"
                   FontSize="22"
                   Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Type" Foreground="#9AA0A6" Margin="0,0,0,6"/>
                <TextBox x:Name="TypeText"
         IsReadOnly="True"
         Text="Pre-Trip"
         Height="28"
         VerticalContentAlignment="Center"
         BorderThickness="1"
         Opacity="0.95"/>

            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Vehicle ID" Foreground="#9AA0A6" Margin="0,0,0,6"/>
                <TextBox x:Name="VehicleBox" Height="34" Background="#151515" Foreground="White" BorderBrush="#2A2A2A"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
    <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TabControl Background="#111111" BorderBrush="#2A2A2A" Foreground="White">
        <TabItem Header="Checklist">
            <Grid Margin="8">
                <ListView x:Name="ChecklistList"
                          Background="#111111"
                          BorderBrush="#2A2A2A"
                          Foreground="White">
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="{x:Type GroupItem}" BasedOn="{StaticResource ChecklistGroupItemStyle}"/>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </ListView.GroupStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#2A2A2A" BorderThickness="0,0,0,1" Padding="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontSize="14" Foreground="White" />
                                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,6,0,0"
                                                 Height="28"
                                                 Background="#151515"
                                                 Foreground="White"
                                                 BorderBrush="#2A2A2A"
                                                 VerticalContentAlignment="Center"
                                                 Padding="8,0"
                                                 />
                                    </StackPanel>

                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding IsOk}"
                                              Content="OK"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center"
                                              Foreground="#00FF80"/>

                                    <CheckBox Grid.Column="2"
                                              IsChecked="{Binding IsDefect}"
                                              Content="Defect"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center"
                                              Foreground="#FFAA00"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </TabItem>

        <TabItem Header="Notes">
            <Grid Margin="8">
                <TextBox x:Name="NotesBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="#151515"
                         Foreground="White"
                         BorderBrush="#2A2A2A"/>
            </Grid>
        </TabItem>
    </TabControl>

    <StackPanel Grid.Row="1" Margin="0,12,0,0">
        <TextBlock x:Name="LockMsg" Foreground="#FF5252" Margin="0,0,0,8" Visibility="Collapsed"
                   Text="Locked while vehicle is moving. Stop the truck to complete or sign this inspection."/>
        <TextBlock Text="Signature (type your name)" Foreground="#9AA0A6" Margin="0,0,0,6"/>
        <TextBox x:Name="SignatureBox" Height="34" Background="#151515" Foreground="White" BorderBrush="#2A2A2A"/>

        <CheckBox x:Name="CertifyBox" Margin="0,10,0,0" Foreground="White"
                  Content="I certify that this inspection is true and correct to the best of my knowledge."/>
    </StackPanel>

    <TextBlock Grid.Row="2" x:Name="SavedMsg" Foreground="#00FF80" Margin="0,10,0,0" Visibility="Collapsed"
               Text="Saved ✔"/>
</Grid>
<StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="NoDefectsButton"
        Content="No Defects"
        Width="120"
        Height="34"
        Margin="0,0,8,0"
        Background="#166534"
        Foreground="White"
        FontWeight="SemiBold"
        Click="NoDefects_Click"/>
            <Button Content="Cancel" Width="110" Height="36" Margin="0,0,10,0"
                    Background="#1A1A1A" Foreground="White" BorderBrush="#2A2A2A"
                    Click="Cancel_Click"/>
            <Button x:Name="SaveButton" Content="Save" Width="110" Height="36"
                    Background="#00FF80" Foreground="Black" BorderBrush="#00FF80"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
