<UserControl x:Class="OverWatchELD.Views.DriverPerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF0B1220">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Driver Performance"
                   Foreground="#FFE5E7EB"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                Background="#FF111A2B"
                BorderBrush="#22314A"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">

            <StackPanel>
                <TextBlock Text="Coming online next: scoring + charts"
                           Foreground="#FF9CA3AF"
                           Margin="0,0,0,16"/>

                <UniformGrid Columns="3" Margin="0,0,0,10">
                    <Border Background="#FF0F172A" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Safety Score" Foreground="#FF9CA3AF" FontSize="12"/>
                            <TextBlock Text="{Binding SafetyScore}" Foreground="#FFE5E7EB" FontSize="28" FontWeight="Bold"/>
                            <ProgressBar Height="10"
                                         Maximum="100"
                                         Value="{Binding SafetyScore, Mode=OneWay}"
                                         Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <UniformGrid Columns="3" Margin="0,0,0,10">
                        <Border Background="#FF0F172A" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Hard Brakes" Foreground="#FF9CA3AF" FontSize="12"/>
                                <TextBlock Text="{Binding HardBrakes}" Foreground="#FFE5E7EB" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FF0F172A" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Idle %" Foreground="#FF9CA3AF" FontSize="12"/>
                                <TextBlock Text="{Binding IdlePercent, StringFormat={}{0}%}" Foreground="#FFE5E7EB" FontSize="28" FontWeight="Bold"/>
                                <TextBlock Text="{Binding IdleMinutes, StringFormat={}Idle Minutes: {0}}" Foreground="#FF9CA3AF" FontSize="12" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FF0F172A" CornerRadius="10" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Speeding" Foreground="#FF9CA3AF" FontSize="12"/>
                                <TextBlock Text="{Binding SpeedingMinutes, StringFormat={}{0} min}" Foreground="#FFE5E7EB" FontSize="28" FontWeight="Bold"/>
                                <TextBlock Text="{Binding OverspeedEvents, StringFormat={}Events: {0}}" Foreground="#FF9CA3AF" FontSize="12" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding HosViolations, StringFormat={}HOS Violations: {0}}"
           Foreground="#FF9CA3AF"
           Margin="0,0,0,10"/>

                            </StackPanel>
                        </Border>
                    </UniformGrid>


                    <Border Background="#FF0F172A" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="On-Time %" Foreground="#FF9CA3AF" FontSize="12"/>
                            <TextBlock Text="{Binding OnTimePercent}" Foreground="#FFE5E7EB" FontSize="28" FontWeight="Bold"/>
                            <ProgressBar Height="10"
                                         Maximum="100"
                                         Value="{Binding OnTimePercent, Mode=OneWay}"
                                         Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FF0F172A" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="HOS Compliance" Foreground="#FF9CA3AF" FontSize="12"/>
                            <TextBlock Text="{Binding HosCompliance}" Foreground="#FFE5E7EB" FontSize="28" FontWeight="Bold"/>
                            <ProgressBar Height="10"
                                         Maximum="100"
                                         Value="{Binding HosCompliance, Mode=OneWay}"
                                         Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

               

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
