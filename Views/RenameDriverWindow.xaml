<Window x:Class="OverWatchELD.Views.RenameDriverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Driver Name"
        Height="185"
        Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#111111">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Change Driver Name"
                   Foreground="White"
                   FontSize="18"
                   FontWeight="SemiBold"/>

        <TextBox x:Name="NameBox"
                 Grid.Row="2"
                 Height="34"
                 Padding="8,4"
                 Background="#1B1B1B"
                 Foreground="White"
                 BorderBrush="#2A2A2A"
                 VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="90"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Save"
                    Width="90"
                    Height="32"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>