<UserControl x:Class="OverWatchELD.Views.DispatchInboxTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#1B1B1B"
                CornerRadius="10"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="VTC Messaging Hub"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding HeaderSubtitle}"
                               Foreground="#A0A0A0"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Background="#202A20"
                            CornerRadius="8"
                            Padding="10,4"
                            Margin="0,0,10,0">
                        <TextBlock Text="{Binding UnreadSummary}"
                                   Foreground="#6FCF97"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <Button Content="New Message"
        Padding="12,6"
        Margin="0,0,10,0"
        Click="NewMessage_Click"
        Visibility="{Binding CanStartNewConversationVisibility}"/>

                    <Button Content="Refresh"
                            Padding="12,6"
                            Click="Refresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: conversation list -->
            <Border Grid.Column="0"
                    Background="#1B1B1B"
                    CornerRadius="10"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SearchBox"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Padding="10,4"
                                 Background="#131313"
                                 Foreground="White"
                                 BorderBrush="#2A2A2A"
                                 TextChanged="SearchBox_TextChanged"/>

                        <StackPanel Grid.Column="1"
            Orientation="Horizontal">
                            <Button Content="Mark Read"
            Padding="10,6"
            Margin="10,0,0,0"
            Click="MarkThreadRead_Click"/>

                            <Button Content="Delete"
            Padding="10,6"
            Margin="8,0,0,0"
            Background="#7F1D1D"
            BorderBrush="#EF4444"
            Foreground="White"
            Click="DeleteThread_Click"/>
                        </StackPanel>
                    </Grid>

                    <ListBox Grid.Row="2"
                             x:Name="ThreadsList"
                             ItemsSource="{Binding FilteredThreads}"
                             SelectedItem="{Binding SelectedThread, Mode=TwoWay}"
                             SelectionChanged="ThreadsList_SelectionChanged"
                             Background="#131313"
                             BorderBrush="#2A2A2A"
                             BorderThickness="1"
                             Foreground="White"
                             Padding="6">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#181818"
                                        BorderBrush="#2A2A2A"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="10"
                                                         Height="10"
                                                         Fill="{Binding StatusBrush}"
                                                         Margin="0,3,8,0"/>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                                    Background="#2A2230"
                                                    CornerRadius="8"
                                                    Padding="8,2"
                                                    Visibility="{Binding UnreadVisibility}">
                                                <TextBlock Text="{Binding UnreadBadgeText}"
                                                           Foreground="#D8B4FE"
                                                           FontWeight="SemiBold"
                                                           FontSize="11"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding RoleLine}"
                                                   Foreground="#8F8F8F"
                                                   FontSize="11"
                                                   Margin="18,5,0,0"/>

                                        <Grid Grid.Row="2" Margin="18,8,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="{Binding LastMessagePreview}"
                                                       Foreground="#DADADA"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="38"/>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding LastMessageTimeDisplay}"
                                                       Foreground="#7A7A7A"
                                                       FontSize="11"
                                                       Margin="0,6,0,0"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- RIGHT: chat pane -->
            <Border Grid.Column="2"
                    Background="#1B1B1B"
                    CornerRadius="10"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Selected thread header -->
                    <Border Grid.Row="0"
                            Background="#131313"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding SelectedThreadTitle}"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SelectedThreadSubtitle}"
                                           Foreground="#9A9A9A"
                                           Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="Profile"
                                        Padding="10,6"
                                        Margin="0,0,8,0"
                                        Click="Profile_Click"/>
                                <Button Content="Delete Conversation"
        Padding="10,6"
        Click="DeleteThread_Click"
        Background="#7F1D1D"
        BorderBrush="#EF4444"
        Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Messages -->
                    <ListBox Grid.Row="2"
                             x:Name="MessagesList"
                             ItemsSource="{Binding SelectedMessages}"
                             Background="#131313"
                             BorderBrush="#2A2A2A"
                             BorderThickness="1"
                             Padding="10"
                             Foreground="White">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Border x:Name="Bubble"
                                            Background="{Binding BubbleBrush}"
                                            CornerRadius="10"
                                            Padding="10"
                                            MaxWidth="620"
                                            HorizontalAlignment="{Binding BubbleAlignment}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SenderLine}"
                                                       Foreground="{Binding SenderBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="11"/>

                                            <TextBlock Text="{Binding Body}"
                                                       Foreground="White"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0"/>

                                            <TextBlock Text="{Binding TimeDisplay}"
                                                       Foreground="#9A9A9A"
                                                       FontSize="11"
                                                       Margin="0,8,0,0"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Composer -->
                    <Border Grid.Row="4"
                            Background="#131313"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding ComposeHint}"
                                       Foreground="#8A8A8A"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="ComposeBox"
         Grid.Column="0"
         MinHeight="74"
         MaxHeight="150"
         AcceptsReturn="True"
         TextWrapping="Wrap"
         VerticalScrollBarVisibility="Auto"
         Padding="10"
         Background="#181818"
         Foreground="White"
         BorderBrush="#2A2A2A"
         IsEnabled="{Binding CanReplyToSelectedThread}"/>

                                <Button Grid.Column="2"
        Content="Send"
        Width="96"
        Height="40"
        VerticalAlignment="Bottom"
        Click="Send_Click"
        IsEnabled="{Binding CanReplyToSelectedThread}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>