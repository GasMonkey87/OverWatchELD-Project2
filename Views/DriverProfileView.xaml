<Window x:Class="OverWatchELD.Views.DriverProfileView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Driver Profile"
        Height="760"
        Width="1080"
        MinHeight="700"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        Background="#111111">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="RowBackground" Value="#1F2937"/>
            <Setter Property="AlternatingRowBackground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="10" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Driver Profile"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="View driver profile, awards, endorsements, current truck, and connected trucks."
                               Foreground="#BFBFBF"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Width="84"
                        Height="84"
                        Background="#1F2937"
                        CornerRadius="42"
                        BorderBrush="#334155"
                        BorderThickness="1">
                    <Grid>
                        <Border x:Name="ProfileImageFallback"
                                Background="#1F2937"
                                CornerRadius="42">
                            <TextBlock Text="👤"
                                       FontSize="32"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Image x:Name="ProfileImage"
                               Stretch="UniformToFill"
                               Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.8*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="10" Padding="14">
                <StackPanel>
                    <TextBlock Text="Profile Picture"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <Border Margin="0,12,0,0"
                            Height="260"
                            Background="#0F172A"
                            CornerRadius="12"
                            BorderBrush="#334155"
                            BorderThickness="1">
                        <Grid>
                            <Border x:Name="LargeProfileFallback"
                                    Background="#1E293B"
                                    CornerRadius="12">
                                <TextBlock Text="No profile image"
                                           Foreground="#CBD5E1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"/>
                            </Border>

                            <Image x:Name="LargeProfileImage"
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="Upload Picture"
                                Width="130"
                                Margin="0,0,8,8"
                                Click="UploadPicture_Click"/>
                        <Button Content="Remove Picture"
                                Width="130"
                                Margin="0,0,0,8"
                                Click="RemovePicture_Click"/>
                    </WrapPanel>

                    <TextBlock Text="Notes / Bio"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,14,0,0"/>

                    <TextBox x:Name="BioTextBox"
                             Height="180"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="10" Padding="14">
                <TabControl>

                    <TabItem Header="Profile">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <TextBlock Text="Profile Details"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Driver Name" Foreground="#9CA3AF"/>
                                        <TextBox x:Name="DriverNameTextBox"/>

                                        <TextBlock Text="Discord Name" Foreground="#9CA3AF" Margin="0,12,0,0"/>
                                        <TextBox x:Name="DiscordNameTextBox"/>

                                        <TextBlock Text="Discord User ID" Foreground="#9CA3AF" Margin="0,12,0,0"/>
                                        <TextBox x:Name="DiscordUserIdTextBox"/>

                                        <TextBlock Text="Role" Foreground="#9CA3AF" Margin="0,12,0,0"/>
                                        <TextBox x:Name="RoleTextBox"/>

                                        <TextBlock Text="Status" Foreground="#9CA3AF" Margin="0,12,0,0"/>
                                        <TextBox x:Name="StatusTextBox"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Truck Number" Foreground="#9CA3AF"/>
                                        <TextBox x:Name="TruckNumberTextBox"/>

                                        <TextBlock Text="Truck Name" Foreground="#9CA3AF" Margin="0,12,0,0"/>
                                        <TextBox x:Name="TruckNameTextBox"/>

                                        <TextBlock Text="Favorite Route" Foreground="#9CA3AF" Margin="0,12,0,0"/>
                                        <TextBox x:Name="FavoriteRouteTextBox"/>

                                        <TextBlock Text="Home Terminal" Foreground="#9CA3AF" Margin="0,12,0,0"/>
                                        <TextBox x:Name="HomeTerminalTextBox"/>

                                        <TextBlock Text="Profile ID" Foreground="#9CA3AF" Margin="0,12,0,0"/>
                                        <TextBox x:Name="ProfileIdTextBox" IsReadOnly="True"/>
                                    </StackPanel>
                                </Grid>

                                <Border Margin="0,16,0,0"
                                        Background="#111827"
                                        CornerRadius="10"
                                        Padding="12">
                                    <TextBlock x:Name="ProfileStatusText"
                                               Text="Ready."
                                               Foreground="#CBD5E1"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Awards">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <TextBlock Text="Driver Awards &amp; Achievements"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="Awards display as icon badges. Hover over an award to see details."
                                           Foreground="#9CA3AF"
                                           FontSize="12"
                                           Margin="0,4,0,10"
                                           TextWrapping="Wrap"/>

                                <ItemsControl x:Name="AwardsList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="56"
                                                    Height="56"
                                                    Background="#1F2937"
                                                    BorderBrush="#334155"
                                                    BorderThickness="1"
                                                    Margin="0,0,10,10"
                                                    Padding="4"
                                                    CornerRadius="28">
                                                <Border.ToolTip>
                                                    <ToolTip>
                                                        <StackPanel MaxWidth="260">
                                                            <TextBlock Text="{Binding Award.Name}"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"/>
                                                            <TextBlock Text="{Binding Award.Description}"
                                                                       Foreground="#CBD5E1"
                                                                       Margin="0,4,0,0"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding AwardedUtc, StringFormat={}{0:MMM d, yyyy}}"
                                                                       Foreground="#93C5FD"
                                                                       FontSize="11"
                                                                       Margin="0,6,0,0"/>
                                                            <TextBlock Text="{Binding Note}"
                                                                       Foreground="#FDE68A"
                                                                       FontSize="11"
                                                                       Margin="0,2,0,0"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Border.ToolTip>

                                                <TextBlock Text="{Binding Award.IconEmoji}"
                                                           FontSize="28"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Endorsements">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <TextBlock Text="DOT License Endorsements"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="DOT endorsements and qualifications for this driver. Manager/Admin/Owner users can manually add or remove endorsements."
                                           Foreground="#9CA3AF"
                                           FontSize="12"
                                           Margin="0,4,0,10"
                                           TextWrapping="Wrap"/>

                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock x:Name="DotEndorsementStatusText"
                                               Text="DOT endorsements ready."
                                               Foreground="#CBD5E1"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>

                                    <Button x:Name="ManageDotEndorsementsButton"
                                            Content="Manage DOT"
                                            Width="120"
                                            Height="30"
                                            DockPanel.Dock="Right"
                                            Click="ManageDotEndorsements_Click"
                                            Visibility="Visible"/>
                                </DockPanel>

                                <ItemsControl x:Name="DotEndorsementsList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border MinWidth="60"
                                                    Height="38"
                                                    Background="#0F172A"
                                                    BorderBrush="#38BDF8"
                                                    BorderThickness="1"
                                                    Margin="0,0,10,10"
                                                    Padding="10,4"
                                                    CornerRadius="18">
                                                <Border.ToolTip>
                                                    <ToolTip>
                                                        <StackPanel MaxWidth="280">
                                                            <TextBlock Text="{Binding Code}"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"/>
                                                            <TextBlock Text="{Binding Name}"
                                                                       Foreground="#CBD5E1"
                                                                       Margin="0,4,0,0"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding Source}"
                                                                       Foreground="#93C5FD"
                                                                       FontSize="11"
                                                                       Margin="0,6,0,0"/>
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Border.ToolTip>

                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Icon}"
                                                               FontSize="15"
                                                               Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding Code}"
                                                               FontWeight="Bold"
                                                               Foreground="White"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Connected Trucks">
                        <Grid Margin="8">
                            <DataGrid x:Name="ConnectedTrucksGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Active" Binding="{Binding ActiveMarker}" Width="70"/>
                                    <DataGridTextColumn Header="Truck #" Binding="{Binding TruckNumber}" Width="90"/>
                                    <DataGridTextColumn Header="Truck Name" Binding="{Binding TruckName}" Width="150"/>
                                    <DataGridTextColumn Header="Make / Model" Binding="{Binding MakeModel}" Width="170"/>
                                    <DataGridTextColumn Header="Plate" Binding="{Binding Plate}" Width="110"/>
                                    <DataGridTextColumn Header="Mileage" Binding="{Binding Mileage}" Width="110"/>
                                    <DataGridTextColumn Header="Damage %" Binding="{Binding DamagePercent}" Width="100"/>
                                    <DataGridTextColumn Header="Fuel" Binding="{Binding FuelPercent}" Width="80"/>
                                    <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="160"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Log Out"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="Logout_Click"/>
            <Button Content="Save Profile"
                    Width="130"
                    Margin="0,0,8,0"
                    Click="Save_Click"/>
            <Button Content="Close"
                    Width="120"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>