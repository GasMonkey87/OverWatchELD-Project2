<Window x:Class="OverWatchELD.Views.FleetCommandCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Fleet Command Center"
        Height="900"
        Width="1460"
        MinHeight="780"
        MinWidth="1260"
        WindowStartupLocation="CenterOwner"
        Background="#0B1220">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CaretBrush" Value="#60A5FA"/>
            <Setter Property="SelectionBrush" Value="#2563EB"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="RowBackground" Value="#0B1220"/>
            <Setter Property="AlternatingRowBackground" Value="#111827"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#334155"/>
            <Setter Property="VerticalGridLinesBrush" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#182235"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Fleet Command Center"
                               Foreground="#E5E7EB"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Unified fleet management, driver assignment, load tracking, service, inspection, and live telemetry sync."
                               Foreground="#94A3B8"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="FleetBolsButton" Content="View All BOLs" Width="120" Height="34" Margin="0,0,10,0" Click="OpenFleetBols_Click"/>
                    <Button Content="Load Board" Width="110" Height="34" Margin="0,0,10,0" Click="OpenLoadBoard_Click"/>
                    <Button Content="Receipts/Tickets" Width="140" Height="34" Margin="0,0,10,0" Click="OpenReceiptTickets_Click"/>
                    <Button Content="Refresh" Width="110" Height="34" Margin="0,0,10,0" Click="Refresh_Click"/>
                    <Button Content="Close" Width="110" Height="34" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" Columns="7">
            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Total Fleet" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding TotalFleetText}" Foreground="#E5E7EB" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Assigned" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding AssignedText}" Foreground="#86EFAC" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Unassigned" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding UnassignedText}" Foreground="#FCD34D" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Needs Service" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding NeedsServiceText}" Foreground="#FCA5A5" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Needs Inspection" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding NeedsInspectionText}" Foreground="#FCA5A5" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Active Drivers" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding ActiveDriversText}" Foreground="#93C5FD" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14">
                <StackPanel>
                    <TextBlock Text="Receipts / Tickets" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding ReceiptTicketsText}" Foreground="#FDE68A" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="410"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <ComboBox Grid.Column="2"
                                  Height="34"
                                  ItemsSource="{Binding Filters}"
                                  SelectedItem="{Binding SelectedFilter}"/>
                    </Grid>

                    <DataGrid x:Name="TruckGrid"
                              Grid.Row="2"
                              ItemsSource="{Binding Trucks}"
                              SelectedItem="{Binding SelectedTruck}"
                              SelectionChanged="TruckGrid_SelectionChanged"
                              CellEditEnding="TruckGrid_CellEditEnding"
                              MouseDoubleClick="TruckGrid_MouseDoubleClick"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{Binding RowBackground}"/>
                                <Setter Property="BorderBrush" Value="{Binding RowBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Truck ID" Binding="{Binding TruckNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                            <DataGridTextColumn Header="Plate" Binding="{Binding PlateNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="Truck Name" Binding="{Binding TruckName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                            <DataGridTextColumn Header="Truck / Model" Binding="{Binding Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="170"/>
                            <DataGridTextColumn Header="Driver" Binding="{Binding AssignedDriver, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="Load #" Binding="{Binding LoadNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                            <DataGridTextColumn Header="Speed" Binding="{Binding Speed}" IsReadOnly="True" Width="80"/>
                            <DataGridTextColumn Header="Fuel" Binding="{Binding FuelPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                            <DataGridTextColumn Header="Condition" Binding="{Binding HealthPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                            <DataGridTextColumn Header="Truck Dmg" Binding="{Binding TruckDamage}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="Trailer Dmg" Binding="{Binding TrailerDamage}" IsReadOnly="True" Width="95"/>
                            <DataGridTextColumn Header="Trailer" Binding="{Binding TrailerName}" IsReadOnly="True" Width="140"/>
                            <DataGridTextColumn Header="Cargo" Binding="{Binding CargoName}" IsReadOnly="True" Width="140"/>
                            <DataGridTextColumn Header="Destination" Binding="{Binding Destination}" IsReadOnly="True" Width="200"/>
                            <DataGridTextColumn Header="Miles Left" Binding="{Binding RemainingMiles}" IsReadOnly="True" Width="95"/>
                            <DataGridTextColumn Header="Warnings" Binding="{Binding Warnings}" IsReadOnly="True" Width="170"/>
                            <DataGridTextColumn Header="Odometer" Binding="{Binding OdometerMiles, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                            <DataGridTextColumn Header="Updated" Binding="{Binding LastUpdatedDisplay}" IsReadOnly="True" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#111827" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Truck Management" Foreground="#E5E7EB" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="Management can edit truck information. Live telemetry keeps plate, speed, fuel, damage, trailer, cargo, destination, location, and odometer updated."
                                   Foreground="#94A3B8"
                                   Margin="0,6,0,12"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Truck ID" Foreground="#E5E7EB"/>
                        <ComboBox x:Name="TruckNumberBox"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  Margin="0,6,0,0"
                                  Height="34"
                                  ItemsSource="{Binding Trucks}"
                                  DisplayMemberPath="TruckNumber"/>

                        <TextBlock Text="Driver" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <ComboBox x:Name="DriverBox"
                                  IsEditable="False"
                                  IsTextSearchEnabled="True"
                                  Margin="0,6,0,0"
                                  Height="34"/>

                        <TextBlock Text="Load Number" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <ComboBox x:Name="LoadNumberBox"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  Margin="0,6,0,0"
                                  Height="34"
                                  ItemsSource="{Binding LoadOptions}"/>

                        <TextBlock Text="Truck Name" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="TruckNameBox" Margin="0,6,0,0" Height="34"/>

                        <TextBlock Text="Model" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="ModelBox" Margin="0,6,0,0" Height="34"/>

                        <TextBlock Text="Plate" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="PlateBox" Margin="0,6,0,0" Height="34"/>

                        <TextBlock Text="Location" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="LocationBox" Margin="0,6,0,0" Height="34"/>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Condition %" Foreground="#E5E7EB"/>
                                <TextBox x:Name="ConditionBox" Margin="0,6,0,0" Height="34" Text="100"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Fuel %" Foreground="#E5E7EB"/>
                                <TextBox x:Name="FuelBox" Margin="0,6,0,0" Height="34" Text="100"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Odometer Miles" Foreground="#E5E7EB" Margin="0,12,0,0"/>
                        <TextBox x:Name="OdometerBox" Margin="0,6,0,0" Height="34" Text="0"/>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="Add Truck" Height="36" Click="AddTruck_Click"/>
                            <Button Grid.Column="2" Content="Update Truck" Height="36" Click="UpdateTruck_Click"/>
                        </Grid>

                        <Button Content="Add From Telemetry"
                                Height="36"
                                Margin="0,10,0,0"
                                Click="AddFromTelemetry_Click"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="Assign Driver" Height="36" Click="AssignDriverOnly_Click"/>
                            <Button Grid.Column="2" Content="Assign Load" Height="36" Click="AssignLoad_Click"/>
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="Unassign Driver" Height="36" Click="UnassignDriver_Click"/>
                            <Button Grid.Column="2" Content="Delete Selected Truck" Height="36" Click="DeleteTruck_Click"/>
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="Mark Service Complete" Height="36" Click="MarkService_Click"/>
                            <Button Grid.Column="2" Content="Mark Inspection Complete" Height="36" Click="MarkInspection_Click"/>
                        </Grid>

                        <Button Content="Open Dispatch Inbox"
                                Height="36"
                                Margin="0,10,0,0"
                                Click="OpenDispatchForSelectedTruck_Click"/>

                        <Button Content="Open Receipt / Ticket History"
                                Height="36"
                                Margin="0,10,0,0"
                                Background="#7C3AED"
                                BorderBrush="#A78BFA"
                                Click="OpenReceiptTickets_Click"/>

                        <Border Background="#0B1220" BorderBrush="#22314A" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Selected Truck" Foreground="#94A3B8" FontSize="12"/>
                                <TextBlock Text="{Binding SelectedTruck.TruckNumber}" Foreground="#E5E7EB" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding SelectedTruck.AssignedDriver}" Foreground="#D1D5DB" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding SelectedTruck.LoadNumber}" Foreground="#93C5FD" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedTruck.Location}" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedTruck.Status}" Foreground="#86EFAC" Margin="0,8,0,0"/>
                                <TextBlock Text="{Binding SelectedTruck.Speed, StringFormat=Speed: {0}}" Foreground="#D1D5DB" Margin="0,8,0,0"/>
                                <TextBlock Text="{Binding SelectedTruck.TruckDamage, StringFormat=Truck Damage: {0}}" Foreground="#FCA5A5" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedTruck.TrailerDamage, StringFormat=Trailer Damage: {0}}" Foreground="#FCA5A5" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedTruck.TrailerName, StringFormat=Trailer: {0}}" Foreground="#D1D5DB" Margin="0,8,0,0"/>
                                <TextBlock Text="{Binding SelectedTruck.CargoName, StringFormat=Cargo: {0}}" Foreground="#D1D5DB" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedTruck.Destination, StringFormat=Destination: {0}}" Foreground="#93C5FD" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedTruck.RemainingMiles, StringFormat=Miles Left: {0}}" Foreground="#D1D5DB" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedTruck.Warnings, StringFormat=Warnings: {0}}" Foreground="#FBBF24" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>