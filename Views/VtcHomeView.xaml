<UserControl x:Class="OverWatchELD.Views.VtcHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1100"
             d:DesignWidth="1380"
             Background="#111111">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header / Branding -->
            <Border Grid.Row="0"
                    CornerRadius="10"
                    Background="#1E1E1E"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="180"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Banner -->
                    <Grid Grid.Row="0">
                        <Border x:Name="BannerFallback"
                                Background="#252525"/>

                        <Image x:Name="BannerImage"
                               Stretch="UniformToFill"
                               Visibility="Collapsed"/>

                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#22000000" Offset="0"/>
                                    <GradientStop Color="#AA000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- branding action buttons -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="12">
                            <Button x:Name="ChangeBannerButton"
                                    Content="Change Banner"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    Visibility="Collapsed"
                                    Click="ChangeBanner_Click"/>

                            <Button x:Name="RemoveBannerButton"
                                    Content="Remove Banner"
                                    Padding="12,6"
                                    Visibility="Collapsed"
                                    Click="RemoveBanner_Click"/>
                        </StackPanel>

                        <!-- Banner title content -->
                        <Grid VerticalAlignment="Bottom"
                              Margin="18,18,18,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- VTC Icon -->
                            <Grid Width="110" Height="110">
                                <Border x:Name="IconFallback"
                                        CornerRadius="18"
                                        Background="#2B2B2B"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1"/>

                                <Image x:Name="VtcIconImage"
                                       Stretch="UniformToFill"
                                       Visibility="Collapsed"/>

                                <Border CornerRadius="18"
                                        BorderBrush="#D0D0D0"
                                        BorderThickness="2"
                                        Background="#00000000"/>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,0,-42">
                                    <Button x:Name="ChangeIconButton"
                                            Content="Change Icon"
                                            Padding="10,4"
                                            Margin="0,0,8,0"
                                            Visibility="Collapsed"
                                            Click="ChangeIcon_Click"/>

                                    <Button x:Name="RemoveIconButton"
                                            Content="Remove Icon"
                                            Padding="10,4"
                                            Visibility="Collapsed"
                                            Click="RemoveIcon_Click"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,0,8">
                                <TextBlock x:Name="VtcHeaderTitle"
                                           Text="VTC"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock x:Name="BotStatusText"
                                               Text="Bot API: --"
                                               Foreground="#D6D6D6"
                                               Margin="0,0,16,0"/>
                                    <TextBlock x:Name="VtcNameText"
                                               Text="VTC: --"
                                               Foreground="#D6D6D6"/>
                                </StackPanel>

                                <TextBlock x:Name="SelectedGuildText"
                                           Text="GuildId: (none)"
                                           Foreground="#B0B0B0"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Navigation and actions -->
                    <Grid Grid.Row="1" Margin="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <WrapPanel Grid.Column="0" Margin="0,0,12,0">
                            <Button Content="Performance"
            Padding="12,6"
            Margin="0,0,10,10"
            Click="DriverScores_Click"/>
                            <Button Content="Dispatch"
            Padding="12,6"
            Margin="0,0,10,10"
            Click="NavigateDispatch_Click"/>
                            <Button Content="Maintenance"
            Padding="12,6"
            Margin="0,0,10,10"
            Click="NavigateMaintenance_Click"/>
                            <Button Content="Achievements"
            Padding="12,6"
            Margin="0,0,10,10"
            Click="OpenAchievements_Click"/>
                            <Button Content="Garage"
        Padding="12,6"
        Margin="0,0,10,10"
        Click="OpenGarage_Click"/>
                            <Button Content="Events"
            Padding="12,6"
            Margin="0,0,10,10"
            Click="OpenEventsPage_Click"/>
                            <Button Content="Roster"
            Padding="12,6"
            Margin="0,0,10,10"
            Click="OpenRoster_Click"/>
                            <Button Content="Fleet"
            Padding="12,6"
            Margin="0,0,10,10"
            Click="NavigateFleet_Click"/>
                            <Button Content="Convoy"
            Padding="12,6"
            Margin="0,0,10,10"
            Click="OpenConvoy_Click"/>
                            <Button Content="Live Map"                                 
            Padding="12,6"
            Margin="0,0,10,10"
            Click="OpenLiveMap_Click"/>
                            <Button Content="Fuel"
Padding="12,6"
Margin="0,0,10,10"
Click="FuelMaintenance_Click"/>
                        </WrapPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right">
                            <Button x:Name="ChangeVtcButton"
                                    Content="Change VTC"
                                    Padding="12,6"
                                    Margin="0,0,10,0"
                                    Click="ChangeVtc_Click"/>
                            <Button Content="Refresh"
                                    Padding="12,6"
                                    Margin="0,0,10,0"
                                    Click="RefreshAll_Click"/>
                            <Button x:Name="AdminPanelButton"
                                    Content="Admin"
                                    Padding="12,6"
                                    Visibility="Collapsed"
                                    Click="OpenAdminPanel_Click"/>

                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            
            
            <!-- Main -->
            <!-- Main -->
            <Grid Grid.Row="2" x:Name="MainDashboardPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Left main -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="280"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="220"/>
                    </Grid.RowDefinitions>

                    <!-- Summary cards -->
                    <UniformGrid Grid.Row="0" Columns="5" Margin="0">
                        <Border Background="#1E1E1E" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Drivers" Foreground="#9E9E9E" FontSize="12"/>
                                <TextBlock x:Name="DriversCountText"
                                           Text="0"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E1E" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Online" Foreground="#9E9E9E" FontSize="12"/>
                                <TextBlock x:Name="OnlineDriversText"
                                           Text="0"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E1E" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Fleet Trucks" Foreground="#9E9E9E" FontSize="12"/>
                                <TextBlock x:Name="FleetCountText"
                                           Text="0"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E1E" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Weekly Miles" Foreground="#9E9E9E" FontSize="12"/>
                                <TextBlock x:Name="WeeklyMilesText"
                                           Text="0"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E1E" CornerRadius="10" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Monthly Miles" Foreground="#9E9E9E" FontSize="12"/>
                                <TextBlock x:Name="MonthlyMilesText"
                                           Text="0"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Pairing -->
                    <!-- Pairing -->
                    <Border x:Name="PairingPanel"
        Grid.Row="2"
        CornerRadius="10"
        Background="#1E1E1E"
        Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Vertical">
                                <TextBlock Text="Pair this ELD to your Discord/VTC"
                                           Foreground="White"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Use the pairing code you get from the Discord bot (example: !link 123456)"
                                           Foreground="#9E9E9E"
                                           Margin="0,4,0,0"/>

                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBox x:Name="PairCodeTextBox"
                                             Width="200"
                                             Height="30"
                                             Margin="0,0,10,0"/>
                                    <Button Content="Pair"
                                            Padding="16,6"
                                            Click="Pair_Click"/>
                                    <TextBlock x:Name="PairStatusText"
                                               Foreground="#BFBFBF"
                                               Margin="12,6,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Help"
                                    Padding="12,6"
                                    Margin="10,0,0,0"
                                    Click="PairHelp_Click"/>
                        </Grid>
                    </Border>

                    <!-- Leaderboard + Activity + Fleet Snapshot -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Leaderboard -->
                        <Border Grid.Column="0" CornerRadius="10" Background="#1E1E1E" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Top Drivers"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="15"/>
                                    <TextBlock Text="  •  Live Status"
                                               Foreground="#9E9E9E"
                                               FontSize="13"
                                               Margin="6,1,0,0"/>
                                </StackPanel>

                                <ListBox Grid.Row="2"
                                         x:Name="TopDriversList"
                                         Background="#141414"
                                         Foreground="White"
                                         BorderBrush="#2A2A2A"
                                         BorderThickness="1"
                                         Padding="6">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Ellipse Width="10"
                                                         Height="10"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding StatusBrush}"
                                                         Margin="2,0,0,0"/>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Name}"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"/>

                                                <Border Grid.Column="2"
                                                        Background="#202A20"
                                                        CornerRadius="8"
                                                        Padding="8,2"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding MilesDisplay}"
                                                               Foreground="#6FCF97"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Activity -->
                        <Border Grid.Column="2" CornerRadius="10" Background="#1E1E1E" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Activity Feed"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="15"/>

                                <ListBox Grid.Row="2"
                                         x:Name="ActivityFeedList"
                                         Background="#141414"
                                         Foreground="White"
                                         BorderBrush="#2A2A2A"
                                         BorderThickness="1"
                                         Padding="6">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#181818"
                                                    BorderBrush="#2A2A2A"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="True">
                                                        <Ellipse Width="10"
                                                                 Height="10"
                                                                 Fill="{Binding StatusBrush}"
                                                                 Margin="0,2,8,0"
                                                                 VerticalAlignment="Top"
                                                                 DockPanel.Dock="Left"/>

                                                        <TextBlock Text="{Binding Message}"
                                                                   Foreground="White"
                                                                   TextWrapping="Wrap"/>
                                                    </DockPanel>

                                                    <TextBlock Text="{Binding TimeDisplay}"
                                                               Foreground="#8A8A8A"
                                                               FontSize="11"
                                                               Margin="18,6,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Fleet Snapshot -->
                        <Border Grid.Column="4" CornerRadius="10" Background="#1E1E1E" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Fleet Snapshot"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="15"/>
                                    <TextBlock Text="  •  Service / Inspection / Health"
                                               Foreground="#9E9E9E"
                                               FontSize="13"
                                               Margin="6,1,0,0"/>
                                </StackPanel>

                                <ListBox Grid.Row="2"
         x:Name="FleetSnapshotList"
         MouseDoubleClick="FleetSnapshotList_MouseDoubleClick"
                                         Background="#141414"
                                         Foreground="White"
                                         BorderBrush="#2A2A2A"
                                         BorderThickness="1"
                                         Padding="6">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#181818"
                                                    BorderBrush="#2A2A2A"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="16"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Ellipse Width="10"
                                                                 Height="10"
                                                                 VerticalAlignment="Center"
                                                                 Fill="{Binding StatusBrush}"
                                                                 Margin="2,0,0,0"/>

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Truck}"
                                                                   Foreground="White"
                                                                   FontWeight="SemiBold"
                                                                   Margin="8,0,0,0"/>

                                                        <Border Grid.Column="2"
                                                                Background="#1F2A36"
                                                                CornerRadius="8"
                                                                Padding="8,2"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Status}"
                                                                       Foreground="#9FD3FF"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </Grid>

                                                    <StackPanel Grid.Row="1" Margin="18,6,0,0">
                                                        <TextBlock Text="{Binding Driver}"
                                                                   Foreground="#DADADA"/>
                                                        <TextBlock Text="{Binding Location}"
                                                                   Foreground="#8A8A8A"
                                                                   FontSize="11"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <Grid Grid.Row="2" Margin="18,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding ServiceDue}"
                                                                       Foreground="#D7D7D7"
                                                                       FontSize="11"/>
                                                            <TextBlock Text="{Binding InspectionStatus}"
                                                                       Foreground="#D7D7D7"
                                                                       FontSize="11"
                                                                       Margin="0,2,0,0"/>
                                                        </StackPanel>

                                                        <Border Grid.Column="1"
                                                                Background="{Binding HealthBrush}"
                                                                CornerRadius="8"
                                                                Padding="8,3"
                                                                VerticalAlignment="Center"
                                                                Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding Health}"
                                                                       Foreground="White"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="11"/>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Event Card -->
                    <Border Grid.Row="6" CornerRadius="10" Background="#1E1E1E" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Upcoming Event"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   FontSize="15"/>
                                        <TextBlock Text="  •  Calendar Snapshot"
                                                   Foreground="#9E9E9E"
                                                   FontSize="13"
                                                   Margin="6,1,0,0"/>
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Background="#1F2A36"
                                            CornerRadius="8"
                                            Padding="10,3"
                                            VerticalAlignment="Center">
                                        <TextBlock x:Name="UpcomingEventTypeText"
                                                   Text="Event"
                                                   Foreground="#9FD3FF"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="2"
                                        Background="#141414"
                                        BorderBrush="#2A2A2A"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="UpcomingEventTitleText"
                                                   Text="No upcoming events"
                                                   Foreground="White"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Grid.Row="1"
                                                   x:Name="UpcomingEventDateTimeText"
                                                   Text="--"
                                                   Foreground="#9FD3FF"
                                                   FontWeight="SemiBold"
                                                   Margin="0,10,0,0"/>

                                        <TextBlock Grid.Row="2"
                                                   x:Name="UpcomingEventMetaText"
                                                   Text="Location: --   •   Host: --"
                                                   Foreground="#DADADA"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0"/>

                                        <TextBlock Grid.Row="3"
                                                   x:Name="UpcomingEventAttendeeText"
                                                   Text="Attending: 0"
                                                   Foreground="#6FCF97"
                                                   FontWeight="SemiBold"
                                                   Margin="0,10,0,0"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border Grid.Column="2"
                                    Background="#141414"
                                    BorderBrush="#2A2A2A"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Event Actions"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="15"/>

                                    <Button Grid.Row="2"
                                            Content="Open Events"
                                            Height="34"
                                            Click="OpenEventsPage_Click"/>

                                    <Button Grid.Row="4"
                                            Content="Create Event"
                                            Height="34"
                                            Click="CreateEventQuick_Click"/>

                                    <Button Grid.Row="6"
                                            Content="Post Event"
                                            Height="34"
                                            Click="PostUpcomingEventQuick_Click"/>

                                    <Border Grid.Row="8"
                                            Background="#181818"
                                            CornerRadius="8"
                                            Padding="10">
                                        <StackPanel>
                                            <TextBlock Text="Event Notes"
                                                       Foreground="#8E8E8E"
                                                       FontSize="12"/>
                                            <TextBlock x:Name="UpcomingEventNotesText"
                                                       Text="No event notes."
                                                       Foreground="#DADADA"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- spacer -->
                    <Border Grid.Row="8"
                            CornerRadius="10"
                            Background="#1E1E1E"
                            Padding="14"
                            Visibility="Collapsed"/>
                </Grid>

                <!-- Right: Announcements -->
                <!-- Right: Announcements -->
                <Border Grid.Column="2" CornerRadius="10" Background="#1E1E1E" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Discord Announcements"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="15"/>
                                <Ellipse x:Name="AnnouncementsDot"
                         Width="10"
                         Height="10"
                         Fill="#FFCC00"
                         Margin="10,3,0,0"
                         Visibility="Collapsed"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                    Background="#1F2937"
                    CornerRadius="8"
                    Padding="10,3"
                    VerticalAlignment="Center">
                                <TextBlock Text="Live Feed"
                           Foreground="#9FD3FF"
                           FontWeight="SemiBold"
                           FontSize="12"/>
                            </Border>
                        </Grid>

                        <ListBox Grid.Row="2"
                 x:Name="AnnouncementsList"
                 Background="#141414"
                 Foreground="White"
                 BorderBrush="#2A2A2A"
                 BorderThickness="1"
                 Padding="8"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}"
                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#181818"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="10"
                                             Height="10"
                                             Fill="{Binding StatusBrush}"
                                             Margin="0,3,8,0"
                                             VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding Author}"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="1"
                                           Text="{Binding TimeDisplay}"
                                           Foreground="#8A8A8A"
                                           FontSize="11"/>
                                            </Grid>

                                            <TextBlock Text="{Binding Message}"
                                       Foreground="#DADADA"
                                       TextWrapping="Wrap"
                                       Margin="18,8,0,0"/>

                                            <Border Background="#1F2937"
                                    CornerRadius="8"
                                    Padding="8,2"
                                    Margin="18,8,0,0"
                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding SourceLabel}"
                                           Foreground="#9FD3FF"
                                           FontWeight="SemiBold"
                                           FontSize="11"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
                            <Button Content="Mark Read"
                    Padding="12,6"
                    Margin="0,0,10,0"
                    Click="AnnouncementsMarkRead_Click"/>
                            <Button Content="Refresh"
                    Padding="12,6"
                    Click="RefreshAnnouncements_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>