<Window x:Class="OverWatchELD.VtcInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VTC Info"
        Height="620" Width="700"
        Background="{StaticResource UiBgBrush}"
        Foreground="{StaticResource TextMainBrush}"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="16"/>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Company / VTC Name" Margin="0,0,10,8" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="CompanyBox" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Driver Name" Margin="0,0,10,8" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="DriverBox" Margin="0,0,0,8" IsEditable="False" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Unit / Truck #" Margin="0,0,10,8" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="UnitBox" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="DOT #" Margin="0,0,10,8" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="3" Grid.Column="1" x:Name="DotBox" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="MC #" Margin="0,0,10,8" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="4" Grid.Column="1" x:Name="McBox" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Home Terminal" Margin="0,0,10,8" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="5" Grid.Column="1" x:Name="TerminalBox" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Notes" Margin="0,0,10,8" VerticalAlignment="Top"/>
                <TextBox   Grid.Row="6" Grid.Column="1" x:Name="NotesBox" Margin="0,0,0,8"
                           AcceptsReturn="True" Height="110" TextWrapping="Wrap"
                           VerticalScrollBarVisibility="Auto"/>

                <!-- spacer row 7 -->

                <Border Grid.Row="8" Grid.ColumnSpan="2" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,6,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Discord VTC Lock (optional)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock Text="If configured, your VTC is locked to your Discord guild. Leave the guild to unlock." Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#0B000000" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="12,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Status" Foreground="{StaticResource TextDim}" FontSize="12"/>
                                <TextBlock x:Name="DiscordLockStatusText" Text="Not configured" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Bot API Base URL" Margin="0,10,10,8" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="9" Grid.Column="1" x:Name="BotApiBox" Margin="0,10,0,8"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Guild ID" Margin="0,0,10,8" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="10" Grid.Column="1" x:Name="GuildIdBox" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="11" Grid.Column="0" Text="Discord User ID" Margin="0,0,10,8" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="11" Grid.Column="1" x:Name="UserIdBox" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="12" Grid.Column="0" Text="Locked VTC (read-only)" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="12" Grid.Column="1" x:Name="LockedVtcBox" Margin="0,0,0,0" IsReadOnly="True" Opacity="0.85"/>

            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource NavButtonStyle}" Width="110" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Style="{StaticResource NavButtonStyle}" Width="110" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
