<UserControl x:Class="OverWatchELD.Controls.CircularRing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="170" Width="260">
    <UserControl.Resources>
        <!-- Local ring colors (keeps overall look; only arc changes) -->
        <SolidColorBrush x:Key="RingWarnBrush" Color="#FFC107"/>
        <SolidColorBrush x:Key="RingViolateBrush" Color="#FF3B30"/>
    </UserControl.Resources>

    <Border Background="{StaticResource CardBgBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="14"
            Margin="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Ring -->
            <Grid Width="110" Height="110" VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Track -->
                <Ellipse x:Name="PART_Track"
                         Stroke="{StaticResource CardBorderBrush}"
                         StrokeThickness="{Binding StrokeThickness, RelativeSource={RelativeSource AncestorType=UserControl}}"
                         Fill="Transparent"/>

                <!-- Progress Arc -->
                <Path x:Name="PART_Arc"
                      Stroke="{StaticResource AccentBrush}"
                      StrokeThickness="{Binding StrokeThickness, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Severity, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="1">
                                    <Setter Property="Stroke" Value="{StaticResource RingWarnBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Severity, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="2">
                                    <Setter Property="Stroke" Value="{StaticResource RingViolateBrush}"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding IsPulsing, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="PulseStoryboard">
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1.0" To="0.35" Duration="0:0:0.6"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>

                <!-- Center Text -->
                <Grid>
                    <TextBlock x:Name="PART_CenterText"
                               Text="{Binding ValueText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Foreground="{StaticResource TextMainBrush}"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Grid>

            <!-- Text -->
            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding RingLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Foreground="{StaticResource TextMainBrush}"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Remaining"
                           Foreground="{StaticResource TextDim}"
                           FontSize="12"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
