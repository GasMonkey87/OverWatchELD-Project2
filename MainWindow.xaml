<Window x:Class="OverWatchELD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OverWatch ELD"
        Height="920"
        Width="1460"
        MinHeight="820"
        MinWidth="1240"
        WindowStartupLocation="CenterScreen"
        Background="#02040A"
        Icon="/Assets/OverWatchELD.ico"
        Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="BlackGlass" Color="#030914"/>
        <SolidColorBrush x:Key="PanelDark" Color="#050D18"/>
        <SolidColorBrush x:Key="PanelBlue" Color="#071426"/>
        <SolidColorBrush x:Key="LineBlue" Color="#0B83D8"/>
        <SolidColorBrush x:Key="SoftLine" Color="#1F3A5C"/>
        <SolidColorBrush x:Key="TextMain" Color="#F4F8FF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#9BB4D0"/>
        <SolidColorBrush x:Key="NeonBlue" Color="#008CFF"/>
        <SolidColorBrush x:Key="NeonGreen" Color="#5CFF37"/>

        <LinearGradientBrush x:Key="TabletSurface" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#071629" Offset="0"/>
            <GradientStop Color="#020813" Offset="1"/>
        </LinearGradientBrush>

        <!-- Invisible scrollbars, usable with mouse wheel / touch pad -->
        <Style x:Key="InvisibleScrollBar" TargetType="{x:Type ScrollBar}">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Width" Value="0"/>
            <Setter Property="Height" Value="0"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="#F4F8FF"/>
            <Setter Property="Background" Value="#071426"/>
            <Setter Property="BorderBrush" Value="#1F3A5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0B2440"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#008CFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#063D73"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5CC8FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BottomNavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="132"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#061525"/>
            <Setter Property="BorderBrush" Value="#174C78"/>
        </Style>

        <Style x:Key="RailButton"
       TargetType="Button"
       BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="198"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="Background" Value="#09182A"/>
            <Setter Property="BorderBrush" Value="#24476E"/>
        </Style>

        <Style x:Key="FooterButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Background="#02040A">
        <!-- Rugged tablet shell -->
        <Border Margin="8"
                CornerRadius="40"
                Background="#050505"
                BorderBrush="#222"
                BorderThickness="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.75"/>
            </Border.Effect>

            <Border CornerRadius="32"
                    Background="#080B10"
                    BorderBrush="#30343B"
                    BorderThickness="2">
                <Border Margin="20"
                        CornerRadius="22"
                        Background="{StaticResource BlackGlass}"
                        BorderBrush="#1A5F9D"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="104"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="78"/>
                            <RowDefinition Height="48"/>
                        </Grid.RowDefinitions>

                        <!-- Header without crowded navigation -->
                        <Border Grid.Row="0"
                                CornerRadius="20,20,0,0"
                                Background="#050A12"
                                BorderBrush="#11395F"
                                BorderThickness="0,0,0,1">
                            <Grid Margin="16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="430"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Smaller real logo -->
                                    <Border Width="112"
                                            Height="74"
                                            CornerRadius="12"
                                            Background="#061525"
                                            BorderBrush="#0B83D8"
                                            BorderThickness="1"
                                            ClipToBounds="True"
                                            Margin="0,0,16,0">
                                        <Image Source="/Assets/OverWatchLogo.png"
                                               Stretch="Uniform"
                                               Margin="5"/>
                                    </Border>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="OverWatch ELD"
                                                   Foreground="{StaticResource TextMain}"
                                                   FontSize="30"
                                                   FontWeight="Black"/>
                                        <TextBlock Text="Electronic Logging Device"
                                                   Foreground="#D8E7F8"
                                                   FontSize="16"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Border Background="#061525"
                                            BorderBrush="#0B83D8"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Height="42"
                                            Margin="0,0,22,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="54"
                                                    BorderBrush="#0B83D8"
                                                    BorderThickness="0,0,1,0">
                                                <TextBlock x:Name="VtcBadgeFallbackTextBlock"
                                                           Text="VL"
                                                           Foreground="#F4F8FF"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock x:Name="VtcBadgeTextBlock"
                                                       Text="Standalone"
                                                       Foreground="#00A3FF"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="16,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Image x:Name="VtcBadgeIconImage" Width="1" Height="1" Visibility="Collapsed"/>
                                    <Border x:Name="VtcBadgeFallbackBorder" Visibility="Collapsed"/>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Online"
                                                   Foreground="{StaticResource TextMain}"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <ToggleButton x:Name="OnlineToggle"
                                                      Width="68"
                                                      Height="36"
                                                      Checked="OnlineToggle_Changed"
                                                      Unchecked="OnlineToggle_Changed"
                                                      Cursor="Hand">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Grid>
                                                        <Border x:Name="SwitchTrack"
                                                                CornerRadius="18"
                                                                Background="#374151"/>
                                                        <Ellipse x:Name="SwitchThumb"
                                                                 Width="30"
                                                                 Height="30"
                                                                 Fill="White"
                                                                 Margin="3"
                                                                 HorizontalAlignment="Left"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="SwitchTrack" Property="Background" Value="#22C55E"/>
                                                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                    </StackPanel>
                                </StackPanel>

                                <Button x:Name="ProfileButton"
                                        Grid.Column="2"
                                        Width="54"
                                        Height="54"
                                        MinWidth="54"
                                        Padding="0"
                                        Margin="0,0,0,0"
                                        ToolTip="Profile"
                                        Click="ProfileButton_Click">
                                    <Grid>
                                        <Border x:Name="ProfileButtonImageBorder"
                                                Width="38"
                                                Height="38"
                                                CornerRadius="19"
                                                Background="#061525"
                                                BorderBrush="#0B83D8"
                                                BorderThickness="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                        <Ellipse x:Name="ProfileButtonImageEllipse"
                                                 Width="38"
                                                 Height="38"
                                                 Visibility="Collapsed"
                                                 Stroke="#0B83D8"
                                                 StrokeThickness="1"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ProfileButtonFallbackText"
                                                   Text="👤"
                                                   FontSize="17"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Main content + right rail -->
                        <Grid Grid.Row="1" Background="#020915">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="258"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="16,14,10,10"
                                    CornerRadius="14"
                                    Background="#020915">
                                <ContentControl x:Name="MainContent"/>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="0,14,14,10"
                                    CornerRadius="10"
                                    Background="#050D18"
                                    BorderBrush="#0B83D8"
                                    BorderThickness="1">
                                <Grid Margin="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <Button Style="{StaticResource RailButton}" Click="ExportLogs_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="▤" FontSize="20" Width="42"/>
                                                <TextBlock Text="EXPORT LOGS" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource RailButton}" Click="ExportInspections_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="▣" FontSize="20" Width="42"/>
                                                <TextBlock Text="EXPORT INSPECTIONS" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="BtnCompanionQr" Style="{StaticResource RailButton}" Click="ShowCompanionQr_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="▦" FontSize="20" Width="42"/>
                                                <TextBlock Text="COMPANION QR" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Rectangle Height="1" Fill="#1F3A5C" Margin="0,10,0,14"/>

                                        <Button Style="{StaticResource RailButton}" Click="OpenPortal_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="◎" FontSize="27" Width="42"/>
                                                <TextBlock Text="OPEN PORTAL" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource RailButton}" Click="OpenMediaPlayer_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="▶" FontSize="20" Width="42"/>
                                                <TextBlock Text="MEDIA PLAYER" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource RailButton}" Click="RequestMaintenance_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🔧" FontSize="22" Width="42"/>
                                                <TextBlock Text="REQUEST MAINTENANCE" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2">
                                        <Rectangle Height="1" Fill="#1F3A5C" Margin="0,10,0,14"/>
                                        <Button x:Name="AddTruckButton" Style="{StaticResource RailButton}" Click="AddTruck_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="▰" FontSize="23" Width="42"/>
                                                <TextBlock Text="ADD TRUCK" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource RailButton}" Click="CheckUpdatesButton_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="☁" FontSize="25" Width="42"/>
                                                <TextBlock Text="CHECK UPDATES" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <Border x:Name="UpdateStatusBox"
                                            Grid.Row="3"
                                            CornerRadius="10"
                                            Background="#061525"
                                            BorderBrush="#0B83D8"
                                            BorderThickness="1"
                                            Padding="12,10"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="UpdateStatusBox_MouseLeftButtonUp">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse x:Name="UpdateAvailableLight"
                                                     Width="14"
                                                     Height="14"
                                                     Fill="#334155"
                                                     Stroke="#64748B"
                                                     StrokeThickness="1"
                                                     Margin="0,0,8,0"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock x:Name="UpdateAvailableText"
                                                       Grid.Column="1"
                                                       Text="Updates: Checking..."
                                                       Foreground="#94A3B8"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"/>
                                            <Button x:Name="CloseUpdateStatusButton"
                                                    Grid.Column="2"
                                                    Content="✕"
                                                    Width="22"
                                                    Height="22"
                                                    MinWidth="22"
                                                    Padding="0"
                                                    Margin="6,0,0,0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Visibility="Collapsed"
                                                    Click="CloseUpdateStatusButton_Click"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Bottom navigation dock with invisible scroll bars -->
                        <Border Grid.Row="2"
                                Background="#050A12"
                                BorderBrush="#11395F"
                                BorderThickness="0,1,0,1"
                                Padding="14,7">
                            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          CanContentScroll="False">
                                <ScrollViewer.Resources>
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource InvisibleScrollBar}"/>
                                </ScrollViewer.Resources>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <Button Style="{StaticResource BottomNavButton}" Click="NavDashboard_Click">
                                        <StackPanel>
                                            <TextBlock Text="⌂" FontSize="24" HorizontalAlignment="Center" Foreground="#00A3FF"/>
                                            <TextBlock Text="Dashboard" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource BottomNavButton}" Click="NavLogs_Click">
                                        <StackPanel>
                                            <TextBlock Text="▤" FontSize="23" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Logs" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource BottomNavButton}" Click="NavDispatch_Click">
                                        <StackPanel>
                                            <TextBlock Text="◴" FontSize="23" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Dispatch" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="NavVtcBtn" Style="{StaticResource BottomNavButton}" Click="NavVtc_Click">
                                        <StackPanel>
                                            <TextBlock Text="♙" FontSize="23" HorizontalAlignment="Center"/>
                                            <TextBlock Text="VTC" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource BottomNavButton}" Click="NavSupport_Click">
                                        <StackPanel>
                                            <TextBlock Text="☎" FontSize="23" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Support" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource BottomNavButton}" Click="NavDocuments_Click">
                                        <StackPanel>
                                            <TextBlock Text="▣" FontSize="23" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Documents" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="NavSettingsBtn" Style="{StaticResource BottomNavButton}" Click="NavSettings_Click" ToolTip="Settings">
                                        <StackPanel>
                                            <TextBlock Text="⚙" FontSize="23" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Settings" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Footer -->
                        <Border Grid.Row="3"
                                CornerRadius="0,0,20,20"
                                Background="#050A12"
                                Padding="18,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Companion:"
                                           Foreground="#EAF4FF"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock x:Name="CompanionUrlText"
                                           Grid.Column="1"
                                           Text="http://127.0.0.1:5234"
                                           Foreground="#00A3FF"
                                           FontSize="14"
                                           TextDecorations="Underline"
                                           Cursor="Hand"
                                           VerticalAlignment="Center"
                                           MouseLeftButtonUp="CompanionUrlText_MouseLeftButtonUp"/>
                                <TextBlock x:Name="CompanionStatusText"
                                           Grid.Column="2"
                                           Text="🔴 Companion Offline"
                                           Foreground="#FCA5A5"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="16,0,16,0"/>
                                <TextBlock Grid.Column="3"
                                           Text="Phone and PC must be on the same Wi-Fi"
                                           Foreground="#B4C6DD"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>
                                <Button Grid.Column="4" Style="{StaticResource FooterButton}" Content="COPY" Margin="0,0,8,0" Click="CopyCompanionUrl_Click"/>
                                <Button Grid.Column="5" Style="{StaticResource FooterButton}" Content="ALLOW FIREWALL" Margin="0,0,8,0" Click="AllowCompanionFirewallAccess_Click"/>
                                <Button Grid.Column="6" Style="{StaticResource FooterButton}" Content="SECURE COMPANION" Margin="0" Click="EnsureCompanionAccessPin_Click"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Border>
        </Border>

        <!-- Tablet camera dot -->
        <Ellipse Width="8" Height="8" Fill="#0B83D8" Stroke="#111827" StrokeThickness="2"
                 HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,13,0,0"/>

        <!-- Check engine overlay -->
        <Border x:Name="CheckEngineAlertBorder"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,118,54,0"
                Background="#7F1D1D"
                BorderBrush="#EF4444"
                BorderThickness="2"
                CornerRadius="14"
                Padding="14,10"
                Panel.ZIndex="999">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Width="42" Height="28" Margin="0,0,10,0">
                    <Path Fill="#FACC15"
                          Stretch="Uniform"
                          Data="M6,8 L13,8 L13,5 L19,5 L19,8 L25,8 L30,13 L36,13 L36,20 L31,20 L28,24 L12,24 L8,20 L4,20 L4,13 Z"/>
                    <Rectangle Width="5" Height="8" Fill="#FACC15" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    <Rectangle Width="6" Height="4" Fill="#FACC15" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                </Grid>
                <StackPanel>
                    <TextBlock Text="CHECK ENGINE" FontSize="18" FontWeight="Black" Foreground="White"/>
                    <TextBlock x:Name="CheckEngineAlertText"
                               Text=""
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#FECACA"
                               TextWrapping="Wrap"
                               MaxWidth="360"/>
                </StackPanel>
                <Button Content="Clear"
                        Margin="14,0,0,0"
                        Padding="10,4"
                        Background="#111827"
                        Foreground="White"
                        BorderBrush="#FCA5A5"
                        Click="ClearCheckEngineAlert_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>